    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "요즘 산책할 때 꽃가루 많이 날리더라. 뉴스에서도 꽃가루 알레르기 조심하라던데 그게 뭘까?",
            "turn_id": "BK22018052-1",
            "utterance_id": "BK22018052.1"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "꽃가루 알레르기는 특정 계절에 발생하는 ‘계절성 알레르기 비염’이다.",
                    "value_time": "44841.0",
                    "value_type": "constant"
                },
                {
                    "value": "꽃가루가 원인인 알레르기로 꽃이 피는 5월을 특히 조심해야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "꽃가루 알레르기",
            "terminate": false,
            "text": "꽃가루 알레르기는 특정 계절에 나타나는 계절성 알레르기 비염이야. 꽃가루가 원인이 되는 알레르기이기 때문에, 꽃이 개화하는 5월엔 특히 주의해야 해.",
            "turn_id": "BK22018052-1",
            "utterance_id": "BK22018052.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "지금 5월이니까 조심해야겠다. 개도 꽃가루 알레르기가 생길 수 있을까?",
            "turn_id": "BK22018052-2",
            "utterance_id": "BK22018052.3"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "꽃가루 알레르기는 사람에게만 발생하는 질병이라고 생각하지 쉽지만 강아지의 피부에도 안 좋은 영향을 미친다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "강아지 꽃가루 알레르기",
            "terminate": false,
            "text": "꽃가루 알레르기가 사람한테만 생기는 병이라고 생각하기 쉽지만, 개의 피부에도 안 좋은 영향을 줘.",
            "turn_id": "BK22018052-2",
            "utterance_id": "BK22018052.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알레르기가 개한테도 생긴다니 조심해야겠다. 꽃가루 알레르기 증상은 뭐야?",
            "turn_id": "BK22018052-3",
            "utterance_id": "BK22018052.5"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "사람의 경우 꽃가루 알레르기의 증상으로 재채기, 콧물, 코막힘 등 비염 증상이 주로 나타나는 반면 강아지는 피부로 증상이 나타난다.",
                    "value_time": "44841.0",
                    "value_type": "constant"
                },
                {
                    "value": "상대적으로 민감한 눈가 피부가 붉어지거나 습진이 발생했다면 꽃가루 알레르기를 의심해 봐야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "강아지 꽃가루 알러지 증상",
            "terminate": false,
            "text": "사람은 꽃가루 알레르기의 증상이 코막힘, 재채기, 콧물 등의 비염 증상이지만 개는 피부로 증상이 나타나. 상대적으로 민감한 눈가 피부가 빨개지거나, 습진이 생겼다면 꽃가루 알레르기를 의심할 수 있어.",
            "turn_id": "BK22018052-3",
            "utterance_id": "BK22018052.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "산책 후에 눈가 주변을 잘 봐야겠다. 피부에 문제가 생기면 개들은 어떤 행동을 해?",
            "turn_id": "BK22018052-4",
            "utterance_id": "BK22018052.7"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "강아지는 피부가 가려우면 바닥에 몸을 문지르고 긁기 때문에 2차 감염으로 이어질 수 있다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "심각한 경우 강아지의 눈가가 부어 오르거나 상처가 날 정도로 심각한 가려움증을 야기할 수도 있다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "강아지 꽃가루 알레르기 피부",
            "terminate": false,
            "text": "심한 경우 개의 눈가가 붓거나 상처가 날 정도로 심한 가려움증이 생길 수 있어. 개는 피부가 가려우면 바닥에 몸을 비비고 긁어대기 때문에 2차 감염으로 이어질 수 있어.",
            "turn_id": "BK22018052-4",
            "utterance_id": "BK22018052.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "가려움증이 생기는구나. 개한테 이런 증상이 반복되면 어떡해야 해?",
            "turn_id": "BK22018052-5",
            "utterance_id": "BK22018052.9"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "이런 증상이 자주 반복된다면 반드시 진찰을 받아야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "아직 예방접종을 하지 않은 어린 강아지들에게는 피부병도 치명적일 수 있기 때문이다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "꽃가루 알레르기 진찰",
            "terminate": false,
            "text": "증상이 곧잘 반복된다면, 꼭 병원 진찰을 받아야 해. 아직 예방접종이 안된 어린 강아지들한테는 피부병도 치명적일 수 있기 때문이야.",
            "turn_id": "BK22018052-5",
            "utterance_id": "BK22018052.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "꽃가루 알레르기 증상이 보이면 바로 병원 가봐야겠다. 꽃가루로부터 반려견을 보호해주는 방법은 없을까?",
            "turn_id": "BK22018052-6",
            "utterance_id": "BK22018052.11"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "봄철 꽃가루 알레르기로부터 반려견을 보호하기 위해서는 강아지가 불편해하더라도 옷을 입혀서 산책을 시켜주는 것이 좋다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "강아지 꽃가루 알레르기 옷",
            "terminate": false,
            "text": "봄철 꽃가루 알레르기로부터 강아지를 지켜주기 위해선, 개가 불편하더라도 옷을 입힌 다음 산책을 하는 게 좋아.",
            "turn_id": "BK22018052-6",
            "utterance_id": "BK22018052.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "옷을 잘 입혀서 산책해야겠어. 또 산책할 때 어떻게 해줘야 예방을 할 수 있을까?",
            "turn_id": "BK22018052-7",
            "utterance_id": "BK22018052.13"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "풀숲보다는 흙바닥 위주로 산책 코스를 바꿔주는 것도 방법이다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "꽃가루 알레르기 산책코스",
            "terminate": false,
            "text": "산책 코스를 풀이 우거진 수풀보다 흙으로 된 바닥 위주로 바꿔주는 것도 방법이야.",
            "turn_id": "BK22018052-7",
            "utterance_id": "BK22018052.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "산책 경로를 바꿔 봐야겠다. 꽃가루가 날리는 곳을 산책했다면 어떻게 해야 해?",
            "turn_id": "BK22018052-8",
            "utterance_id": "BK22018052.15"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "산책 후에는 목욕으로 알레르기 유발 물질을 씻어내 가려움증과 질환을 완화시키자.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "꽃가루 알레르기 산책 후 목욕",
            "terminate": false,
            "text": "산책 후에는 목욕을 해서 알레르기 유발 물질을 씻어내면 가려움증과 질환을 완화 시킬 수 있어.",
            "turn_id": "BK22018052-8",
            "utterance_id": "BK22018052.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "씻어내는 게 중요한 거 같아. 집에서도 꽃가루 알레르기를 예방하는 방법이 있을까?",
            "turn_id": "BK22018052-9",
            "utterance_id": "BK22018052.17"
        },
        {
            "reference_date": "44322.0",
            "reference_text": [
                {
                    "value": "실내도 청결한 상태를 유지해야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "청소기를 자주 돌려주거나 구석구석 닦아내 먼지를 없애는 것이 좋다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.busan.com/view/busan/view.php?code=2021050518105330242",
            "search_query": "꽃가루 알레르기 실내청소",
            "terminate": false,
            "text": "먼지를 구석구석 닦아 없애고, 청소기를 자주 돌리는 게 좋아. 실내도 깨끗한 상태를 지속해야 해.",
            "turn_id": "BK22018052-9",
            "utterance_id": "BK22018052.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 집 청소도 깨끗하게 잘해야겠다.",
            "turn_id": "BK22018052-10",
            "utterance_id": "BK22018052.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "꽃가루가 심한 날에는 나가지 마. 집안에서 내가 강아지랑 놀아 줄게.",
            "turn_id": "BK22018052-10",
            "utterance_id": "BK22018052.20"
        }
    ]
}