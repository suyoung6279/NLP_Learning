    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "집에서 키우는 강아지 항문낭을 관리해줘야 한다고 들었는데 항문낭액은 저절로 배출되는 거 아닌가요?",
            "turn_id": "BK22018888-1",
            "utterance_id": "BK22018888.1"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "요즘에는 사료가 잘 나와 변이 부드럽고 실내생활로 영역표시를 하지도 않다 보니 강아지가 항문낭액을 배출할 일이 거의 없다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                },
                {
                    "value": "따라서 보호자가 항문낭을 주기적으로 짜주면서 항문낭액이 쌓이는 것을 막아줘야 한다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 관리 필요성",
            "terminate": false,
            "text": "요즘 반려견들은 실내 생활을 주로 하다 보니 영역표시를 거의 하지 않고 좋은 사료를 먹어서 부드러운 변을 보기 때문에 항문낭액이 저절로 배출되는 일이 거의 드물어요. 그래서 강아지에게 항문낭액이 쌓이지 않도록 견주분들이 주기적으로 직접 항문낭을 짜주시면서 관리하셔야 해요.",
            "turn_id": "BK22018888-1",
            "utterance_id": "BK22018888.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 항문낭액이 쌓이면 강아지에게 안 좋은 영향이 있는 건가요?",
            "turn_id": "BK22018888-2",
            "utterance_id": "BK22018888.3"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "항문낭액이 쌓이면 강아지는 불편함을 느껴 엉덩이를 바닥에 대고 비비거나 질질 끌고 다니는 모습을 보인다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                },
                {
                    "value": "항문 주변을 핥는다거나 물기도 하며 배변할 때 통증이 나타나기도 한다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                },
                {
                    "value": "심하게는 항문낭이 파열되기도 하니 주의해야 한다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭액 쌓이면",
            "terminate": false,
            "text": "항문낭액이 배출되지 않고 쌓이게 되면 강아지는 불편감을 느끼게 됩니다. 이로 인해 엉덩이를 바닥에 대고 끌거나 비비는 행동을 하거나 항문 주변을 핥고 무는 모습을 보이기도 해요. 쌓인 항문낭액을 방치할 경우 배변 시에 통증을 느끼기도 하고 심할 경우 항문낭이 파열되기도 합니다.",
            "turn_id": "BK22018888-2",
            "utterance_id": "BK22018888.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "요즘 엉덩이를 바닥에 끄는 행동을 가끔 보이던데 항문낭액 때문이었군요. 강아지에게 항문낭액이 있는 이유가 있을 것 같은데 어떤 기능을 하나요?",
            "turn_id": "BK22018888-3",
            "utterance_id": "BK22018888.5"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "항문낭에는 항문낭액이 들어있어 각자만의 서로 다른 고유한 냄새를 만들어낸다.",
                    "value_time": "44846.0",
                    "value_type": "constant"
                },
                {
                    "value": "따라서 강아지가 자신의 존재를 알리거나 강아지끼리 서로를 파악할 때 사용하며 영역표시를 할 때도 사용된다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 냄새",
            "terminate": false,
            "text": "항문낭에 들어있는 항문낭액은 강아지마다 다른 각자의 고유한 냄새를 만드는 역할을 합니다. 이 냄새를 통해 스스로의 존재를 알리거나 다른 강아지와 서로 탐색을 하기도 하고 영역표시를 하기도 해요.",
            "turn_id": "BK22018888-3",
            "utterance_id": "BK22018888.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그런 역할을 하는군요. 항문낭액이 갖고 있는 생물학적인 기능도 있으면 알려주시겠어요?",
            "turn_id": "BK22018888-4",
            "utterance_id": "BK22018888.7"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "또 항문낭액은 배변할 때 배출돼 딱딱한 변이 잘 나올 수 있도록 윤활제 역할을 하기도 한다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 역할",
            "terminate": false,
            "text": "항문낭액은 강아지가 변을 볼 때 함께 배출되는데 이때 항문낭액이 윤활제 기능을 하기 때문에 딱딱한 변을 쉽게 배출할 수 있도록 돕기도 합니다.",
            "turn_id": "BK22018888-4",
            "utterance_id": "BK22018888.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "배변 활동에도 중요한 역할을 하는군요. 항문낭액이 지나치게 쌓이지 않도록 직접 관리해주고 싶은데 항문낭은 어디에 있나요?",
            "turn_id": "BK22018888-5",
            "utterance_id": "BK22018888.9"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "항문낭은 2개의 작은 주머니로 항문을 중심으로 봤을 때 항문 양쪽으로 4시와 8시 방향에 있다.",
                    "value_time": "44846.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 위치",
            "terminate": false,
            "text": "항문낭은 강아지의 항문 중앙에서 양 옆 4시와 8시 방향에 두 개의 작은 주머니 형태를 띠고 있습니다.",
            "turn_id": "BK22018888-5",
            "utterance_id": "BK22018888.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇군요, 그럼 강아지의 항문낭을 어떻게 짜야하는지도 설명해주세요.",
            "turn_id": "BK22018888-6",
            "utterance_id": "BK22018888.11"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "먼저 보호자는 한쪽 손으로 꼬리를 살짝 들어 올려 항문이 보이게 한다.",
                    "value_time": "44846.0",
                    "value_type": "constant"
                },
                {
                    "value": "그리고는 반대쪽 손의 엄지와 검지를 항문낭이 있는 부분에 대고 항문 쪽을 향해 부드럽게 밀어 올리면 된다.",
                    "value_time": "44846.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 관리 방법",
            "terminate": false,
            "text": "우선 강아지의 항문이 보일 수 있도록 견주분의 한쪽 손으로 강아지의 꼬리를 약간만 들어 올립니다. 그다음 나머지 한쪽 손의 엄지와 검지를 항문낭이 있는 위치에 올려두고 강아지의 항문 방향으로 부드럽게 밀어 올려서 짜주시면 됩니다.",
            "turn_id": "BK22018888-6",
            "utterance_id": "BK22018888.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 이 항문낭을 짤 때는 맨손으로 짜면 되나요?",
            "turn_id": "BK22018888-7",
            "utterance_id": "BK22018888.13"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "항문낭액은 냄새가 심해 항문에 휴지를 대고 항문낭을 짜거나 목욕을 하면서 항문낭을 짜는 것을 추천한다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 관리 방법",
            "terminate": false,
            "text": "항문낭액에서 고약한 냄새가 나기 때문에 항문낭을 짜실 때 휴지를 사용하시거나 목욕을 시키실 때 짜주시는 것이 좋습니다.",
            "turn_id": "BK22018888-7",
            "utterance_id": "BK22018888.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그런 팁이 있었군요. 항문낭은 어느 정도 주기로 관리해줘야 하는지도 알려주시겠어요?",
            "turn_id": "BK22018888-8",
            "utterance_id": "BK22018888.15"
        },
        {
            "reference_date": "44835.0",
            "reference_text": [
                {
                    "value": "항문낭액이 만들어지는 속도와 양은 강아지마다 차이가 있어 항문낭을 짜는 주기는 반려견마다 달라질 수 있다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                },
                {
                    "value": "그러니 보호자가 반려견에 맞게 제대로 관리해주는 것이 중요하다.",
                    "value_time": "44846.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=61400",
            "search_query": "강아지 항문낭 관리 주기",
            "terminate": false,
            "text": "강아지마다 항문낭액이 생성되는 양과 속도가 각기 다르기 때문에 관리 주기를 일괄적으로 정하기는 어렵습니다. 보호자분께서 기르는 강아지의 사이클에 맞게 항문낭을 관리해주시면 됩니다.",
            "turn_id": "BK22018888-8",
            "utterance_id": "BK22018888.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지의 행동을 잘 관찰해봐야겠네요. 항문낭을 짤 때 강아지가 거부감을 갖지 않도록 조심해서 관리해줘야겠어요.",
            "turn_id": "BK22018888-9",
            "utterance_id": "BK22018888.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "제가 알려드린 방법대로 하면 무리 없이 관리하실 수 있을 거예요.",
            "turn_id": "BK22018888-9",
            "utterance_id": "BK22018888.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "항문낭액이 강아지의 건강과도 직결된다고 하니 알려주신 대로 잘 관리해 볼게요.",
            "turn_id": "BK22018888-10",
            "utterance_id": "BK22018888.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "주기적으로 항문낭을 잘 짜주는 것만으로도 반려견의 건강을 지킬 수 있으니 신경 써서 관리해주세요.",
            "turn_id": "BK22018888-10",
            "utterance_id": "BK22018888.20"
        }
    ]
}