        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "생각보다 비싸네. 혹시 임산부 바우처로 입덧약을 살 수 있어?",
            "turn_id": "BK22015345-6",
            "utterance_id": "BK22015345.11"
        },
        {
            "reference_date": "2020-06-30",
            "reference_text": [
                {
                    "value": "7월부터 산부인과 등 일반 양방 병원에서 처방 받은 약을 살 때도 임신·출산 바우처(지원금)를 쓸 수 있게 된다.",
