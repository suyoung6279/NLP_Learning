    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아내가 임신 10주에요. 오늘 초음파를 보고 왔는데 너무 신기하더라고요. 첫 아이라 그런지 궁금한 것도 너무 많고요.",
            "turn_id": "BK22015264-1",
            "utterance_id": "BK22015264.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어머, 아내 분 임신을 정말 축하드려요. 어떤 점이 궁금하세요?",
            "turn_id": "BK22015264-1",
            "utterance_id": "BK22015264.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "음, 임신 10주면 아기의 크기는 어느 정도 인가요?",
            "turn_id": "BK22015264-2",
            "utterance_id": "BK22015264.3"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": " 크기: 태아는 약 3cm의 포도알 크기만큼 자랐답니다.",
                    "value_time": "2022-10-07",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "임신 10주 태아 크기",
            "terminate": false,
            "text": "임신 10주의 태아는 약 3cm 정도로 포도알 크기에요.",
            "turn_id": "BK22015264-2",
            "utterance_id": "BK22015264.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "엄청 작네요. 이렇게 작은데 손가락 발가락이 다 생겼나요?",
            "turn_id": "BK22015264-3",
            "utterance_id": "BK22015264.5"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": " 특징: 태아의 몸은 곧게 펴지고, 손가락, 발가락 5개가 완전히 분리되어 알아볼 수 있어요.",
                    "value_time": "2022-10-07",
                    "value_type": "constant"
                },
                {
                    "value": "얼굴 피부밑으로 눈두덩, 입술, 아래턱, 뺨도 발달하기 시작하여 기초적인 안면 골격이 나타나요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "임신 10주 태아 특징",
            "terminate": false,
            "text": "그럼요, 태아의 몸은 곧게 펴지고 손가락과 발가락 5개가 완전히 분리되어 형태를 알아볼 수 있어요. 또 얼굴 피부밑으로 눈두덩이, 입술, 아래턱, 뺨도 발달하기 시작할 시기이며 얼굴에 기초적인 안면 골격이 보이기 시작해요.",
            "turn_id": "BK22015264-3",
            "utterance_id": "BK22015264.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 그럼 임신 10주인 아내의 몸 상태는 어떤가요?",
            "turn_id": "BK22015264-4",
            "utterance_id": "BK22015264.7"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": "자궁이 주먹 크기 정도로 커지면서 소변보는 횟수가 잦아져요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                },
                {
                    "value": "질의 분비물이 늘어 질의 세균이 자궁으로 들어가는 것을 막는데 만약 진한 노란색이거나 가려움증이 있으면 진료를 받도록 하세요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "임신 10주 엄마의 증상",
            "terminate": false,
            "text": "자궁이 주먹만큼 커지면서 소변보는 횟수가 늘어나요. 또 질의 분비물이 늘어 질의 세균이 자궁으로 들어가는 것을 막는데, 만약 분비물이 진한 노란색이거나 가려움증이 있다면 병원 진료를 받아보는 게 좋아요.",
            "turn_id": "BK22015264-4",
            "utterance_id": "BK22015264.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 와이프가 요즘 화장실을 자주 가던데, 그런 이유였군요. 혹시 이 시기에 어떤 음식들을 챙겨 먹으면 좋을까요?",
            "turn_id": "BK22015264-5",
            "utterance_id": "BK22015264.9"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": "임신 기간에는 우유나 멸치 등 칼슘이 풍부한 음식을 많이 섭취하세요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                },
                {
                    "value": "체내 칼슘 레벨을 조절하는 비타민 D도 함께 섭취하면 칼슘 흡수에 도움이 돼요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "임신 10주 필요한 음식",
            "terminate": false,
            "text": "우유나 멸치 등 칼슘이 많이 들어있는 음식들을 많이 드시는 게 좋아요. 이때 비타민 D와 함께 먹으면 체내 칼슘을 흡수하는 데에 도움이 돼요.",
            "turn_id": "BK22015264-5",
            "utterance_id": "BK22015264.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 칼슘과 비타민 D, 꼭 기억해 둬야겠네요. 참, 주변에서 들어보니 태교를 하면 좋다고 하던데, 어떤 태교를 하는 게 좋을까요?",
            "turn_id": "BK22015264-6",
            "utterance_id": "BK22015264.11"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": "정서가 풍부한 임신부가 태아의 뇌 발달을 돕는답니다.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                },
                {
                    "value": "엄마가 좋아하는 그림이나 사진을 보거나 음악을 들어 편안하고 사랑스러운 마음이 된다면 그 감정이 태아의 뇌에 전해져 좋은 영향을 미친답니다.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "임신 10주 필요한 태교",
            "terminate": false,
            "text": "정서가 풍부한 임산부가 태아의 뇌 발달을 도와요. 엄마가 좋아하는 그림이나 사진을 보거나 좋아하는 음악을 듣도록 해보세요. 엄마의 마음이 편안해진다면 그 감정이 태아에게 전달되어 좋은 영향을 미치게 되거든요.",
            "turn_id": "BK22015264-6",
            "utterance_id": "BK22015264.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "태교가 그렇게 어려운 게 아니었네요. 아내가 좋아하는 걸 하고 마음이 편해지면 되는 거였어요. 참, 요즘 와이프가 감기 기운이 좀 있는 것 같던데, 감기 기운이 있을 때 목욕을 해도 괜찮을까요?",
            "turn_id": "BK22015264-7",
            "utterance_id": "BK22015264.13"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": "A. 목욕하고 난 뒤엔 체온 변화가 평소보다 심해지므로 목욕을 하고 나서 감기에 걸려 고생을 하게 되는 일이 많으므로 임신부의 경우 감기 기운이 있을 때는 목욕을 피하는 것이 좋아요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "임신 중 감기 기운이 있을 때 목욕",
            "terminate": false,
            "text": "목욕을 하고 나면 체온 변화가 평소보다 더 심해져요. 그렇기 때문에 감기 기운이 있을 때에는 목욕을 하지 않는 게 좋아요.",
            "turn_id": "BK22015264-7",
            "utterance_id": "BK22015264.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇겠죠? 아내에게 잘 얘기해 봐야겠어요. 그리고 요즘 와이프가 입덧을 많이 하는데, 혹시 입덧에 좋은 음식들은 뭐가 있나요?",
            "turn_id": "BK22015264-8",
            "utterance_id": "BK22015264.15"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": "1. 레몬 = 신맛이 나는 음식은 입맛을 돋우고 더부룩한 속을 달래주는 효과가 있어요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                },
                {
                    "value": "2. 모과 = 모과는 유기산 함량이 많아 소화촉진을 도와주고 소화 기능을 강화하는데 도움을 줘요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                },
                {
                    "value": "3. 매실 = 매실은 식욕을 촉진하고 소화불량 증상을 완화하는 데 효과가 있어요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "입덧이 심할 때 먹으면 좋은 음식",
            "terminate": false,
            "text": "먼저 신맛이 나는 레몬은 입맛을 돋우고 더부룩한 속을 달래주는 효과가 있어 입덧에 좋아요. 또 모과는 유기산 함량이 많이 들어 있어 소화가 잘되도록 도와주고 매실은 식욕을 촉진하고 소화불량을 완화하는 데 좋아요.",
            "turn_id": "BK22015264-8",
            "utterance_id": "BK22015264.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저희 와이프는 음식 냄새만 맡아도 입덧이 너무 심해서요. 음식 자체를 가까이하기 힘들어해요. 그럴 땐 어떻게 해야 하나요?",
            "turn_id": "BK22015264-9",
            "utterance_id": "BK22015264.17"
        },
        {
            "reference_date": "2015-09-04",
            "reference_text": [
                {
                    "value": "4. 차가운 음식 = 냄새가 싫어서 음식을 가까이하지 못할 때 수분 보충용으로 물 대신 얼음을 먹어도 좋아요.",
                    "value_time": "2022-10-07",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000107652",
            "search_query": "입덧이 심할 때 먹으면 좋은 음식",
            "terminate": false,
            "text": "냄새 때문에 음식을 가까이하지 못할 때에는 냄새가 덜 나는 차가운 음식을 먹거나 수분 보충용으로 물 대신 얼음을 먹어도 좋아요.",
            "turn_id": "BK22015264-9",
            "utterance_id": "BK22015264.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 정말 좋은 정보네요. 잘 기억해 뒀다가 아내가 입덧이 심해지면 옆에서 챙겨줘야겠어요.",
            "turn_id": "BK22015264-10",
            "utterance_id": "BK22015264.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "참 자상한 남편이시네요. 아내 분이 정말 좋아하시겠어요.",
            "turn_id": "BK22015264-10",
            "utterance_id": "BK22015264.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아니에요, 당연히 같이해야 할 일들인데요. 오늘 덕분에 많이 배우고 정말 큰 도움이 되었어요.",
            "turn_id": "BK22015264-11",
            "utterance_id": "BK22015264.21"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "도움이 되셨다니 다행이네요. 또 궁금한 점 있으면 언제든지 물어보세요.",
            "turn_id": "BK22015264-11",
            "utterance_id": "BK22015264.22"
        }
    ]
}