    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저는 올해 2살이 된 포메라니아 강아지 한 마리를 키우고 있는데 궁금한 게 너무 많아요. 몇 가지만 질문드려도 될까요?",
            "turn_id": "BK22008788-1",
            "utterance_id": "BK22008788.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼요 궁금한 건 뭐든 물어보세요.",
            "turn_id": "BK22008788-1",
            "utterance_id": "BK22008788.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "요즘 강아지가 사료를 잘 안 먹어서 사료 종류를 좀 바꿔주고 싶은데 사료를 고를 때 주의할 점이 있을까요?",
            "turn_id": "BK22008788-2",
            "utterance_id": "BK22008788.3"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "강아지도 나이와 건강 상태에 따라 필요한 영양 성분이 달라지는데요.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                },
                {
                    "value": "몸이 쑥쑥 크는 성장기의 강아지는 많은 열량과 단백질을 필요로 합니다.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                },
                {
                    "value": "이에 맞춰 나온 사료가 바로 퍼피 사료인데요.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                },
                {
                    "value": "성견용 사료에 비해 칼로리와 단백질이 높답니다.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                },
                {
                    "value": "성장기 강아지가 성견용 사료를 먹는다면 열량 부족뿐만 아니라 칼슘 섭취에도 문제가 생겨요.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/121237/",
            "search_query": "강아지 사료 고르는 법",
            "terminate": false,
            "text": "강아지도 나이와 건강 상태에 따라 필요시 되는 영양 성분이 다른데요, 특히 한창 몸이 크는 성장기의 강아지의 경우에는 고열량과 단백질이 필요해요. 이 시기에 맞춰서 먹일 수 있는 사료가 퍼피 사료인데, 퍼피사료는 성견 사료에 비해서 칼로리와 단백질이 높은 게 특징이에요. 만약 성장기의 강아지가 성견 사료를 먹게 되는 경우에는 열량 부족과 더불어 칼슘 섭취에도 문제가 생길 수 있기 때문에 주의해주시는 게 좋아요.",
            "turn_id": "BK22008788-2",
            "utterance_id": "BK22008788.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "성장기 강아지에게 적합한 사료가 따로 있는 거였네요. 그런데 요즘 화식에도 관심이 가고 있는데요. 화식으로 먹이면 좋은 점은 어떤 게 있나요?",
            "turn_id": "BK22008788-3",
            "utterance_id": "BK22008788.5"
        },
        {
            "reference_date": "2022-07-27",
            "reference_text": [
                {
                    "value": "강아지 화식은 가공을 많이 거치지 않아 원재료의 형태가 많이 살아있어 맛과 향이 좋아요.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "그래서 강아지 기호성이 매우 좋은 편입니다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "건사료 수분 함량이 약 10% 내외인 반면 화식은 평균적으로 60% 이상입니다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "자연스럽게 강아지의 음수량을 높일 수 있습니다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "화식에는 인공 첨가물이 없는 경우가 많기 때문에, 화식 급여 후 피모가 개선되는 경우가 많습니다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/128211/",
            "search_query": "강아지 확식 장점",
            "terminate": false,
            "text": "강아지 화식의 경우에는 가공을 많이 거치지 않기 때문에 원재료 그대로의 형태가 많이 살아있어서 맛과 향이 좋아 강아지의 기호성이 좋은 편이에요. 그리고 건사료의 경우에는 수분 함량이 10% 내외이지만 화식의 경우에는 수분 함량이 평균적으로 60% 이상이기 때문에 자연스럽게 강아지의 음수량을 높을 수 있는 장점이 있어요. 또한 화식에는 인공적인 첨가물이 없는 경우가 많기 때문에 화식을 먹으면 피모가 좋아지는 경우가 많은 편이에요.",
            "turn_id": "BK22008788-3",
            "utterance_id": "BK22008788.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "화식이 장점이 많네요. 저도 한번 바꿔봐야겠어요. 아 참, 그리고 두 달 뒤가 저희 강아지 생일이라 케이크를 주고 싶은데 강아지 케이크가 따로 있더라고요, 혹시 강아지 케이크를 구매할 때 주의해야 할 점이 있을까요?",
            "turn_id": "BK22008788-4",
            "utterance_id": "BK22008788.7"
        },
        {
            "reference_date": "2022-07-21",
            "reference_text": [
                {
                    "value": "1. 건강을 위한 성분 확인",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "그런데 재료가 갈려 들어가거나 뭉쳐있어 어떤 재료가 들어갔는지 명확히 알 수 없는 경우도 많습니다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "만약 알레르기가 있는 강아지라면, 케이크에 알레르기 유발 성분이 있는지 성분표를 자세히 확인해 주세요.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "강아지 케이크의 경우 인공 감미료나 색소 등의 화학 첨가물이 들어가지 않은 경우가 많지만, 종종 들어가 있는 경우도 있습니다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "구매 전 성분표를 확인해 화학 첨가물이 들어가지 않았는지 체크해 주세요.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/126696/",
            "search_query": "강아지 케이크 고르는 법",
            "terminate": false,
            "text": "강아지의 건강을 위해서 성분을 확인하는 것이 무엇보다 중요한데요, 케이크에 재료들이 갈리거나 뭉쳐져 어떤 재료가 들어갔는지에 대해 명확하게 알 수 없는 경우가 많기 때문에 알레르기가 있는 강아지인 경우에는 케이크에 알레르기 유발성분이 있는지 성분표를 자세히 확인해 주시는 게 좋아요. 그리고 강아지 케이크에는 보통 인공 감미료나 색소 등의 화학 첨가물이 들어가지 않는 경우가 대부분이지만 종종 들어갈 때도 있으니까 구매하기 전에 성분표를 한 번 더 확인한 후 화학 첨가물 여부를 체크해 주실 필요가 있어요.",
            "turn_id": "BK22008788-4",
            "utterance_id": "BK22008788.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "화학 첨가물 여부를 반드시 확인하고 구매하는 게 좋겠네요. 그리고 저희 강아지가 고구마말랭이를 엄청나게 좋아하거든요. 집에서 직접 수제 간식으로 고구마말랭이를 만들어주고 싶은데 레시피를 좀 알려주실 수 있나요?",
            "turn_id": "BK22008788-5",
            "utterance_id": "BK22008788.9"
        },
        {
            "reference_date": "2022-05-04",
            "reference_text": [
                {
                    "value": "1) 고구마를 깨끗이 씻어 준비한다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "2) 세로로 반을 가른 후 에어프라이어에 넣고 180도 30분 조리한다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "3) 껍질을 벗긴 후 1cm*5cm 스틱 모양으로 길게 썬다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "4) 서로 겹치지 않게 접시에 담고, 에어프라이어에서 160도 30분 조리한다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "5) 완성된 고구마 말랭이는 완전히 식힌 후 냉동에 넣어 보관한다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1395081/%EC%9C%84%EB%93%9C%ED%8E%AB-%EC%9A%B0%EB%A6%AC-%EA%B0%95%EC%95%84%EC%A7%80%EB%8F%84-%EA%B0%84%EC%8B%9D%EC%9D%B4-%ED%95%84%EC%9A%94%ED%95%B4-%EC%88%98%EC%A0%9C-%EA%B0%84%EC%8B%9D-%EB%A0%88%EC%8B%9C/",
            "search_query": "강아지 수제간식 레시피",
            "terminate": false,
            "text": "그럼요, 일단 깨끗하게 씻은 고구마를 세로로 잘라 에어프라이어에 넣고 180도에서 30분간 구워주세요. 그다음에는 껍질을 벗겨 스틱 모양으로 알맞게 잘라주고 서로 겹치지 않도록 접시에 담아서 다시 에어프라이어로 구워주는데 이번에는 160도에서 30분간 조리해주세요. 이렇게 완성된 고구마말랭이는 완전하게 식힌 다음에 냉동실에 보관해주시면 돼요.",
            "turn_id": "BK22008788-5",
            "utterance_id": "BK22008788.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "생각보다 레시피가 간단하네요, 충분히 잘 만들 수 있을 것 같아요. 아 그리고 저희 강아지가 우유를 좋아하는데 꼭 강아지 전용으로 나오는 우유만 먹여야 하는지 궁금해요. 사람이 마시는 우유는 강아지가 마시면 안 되나요?",
            "turn_id": "BK22008788-6",
            "utterance_id": "BK22008788.11"
        },
        {
            "reference_date": "2022-04-02",
            "reference_text": [
                {
                    "value": "우유와 치즈만 먹으면 복통에 시달리다 설사하는 사람이 있다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "이는 우유 속 유당(Lactose)을 분해하는 락타아제(Lactase)가 부족해 발생한다.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                },
                {
                    "value": "반려견도 마찬가지로 락타아제가 없어 우유를 소화하지 못하고, 구토와 설사 등의 위장장애가 생긴다.",
                    "value_time": "2022-09-17",
                    "value_type": "constant"
                },
                {
                    "value": "우유와 치즈 섭취가 심각한 질병으로 이어지진 않지만, 장기간 섭취 시 소화·위장 질환이 발생한다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "반려견이 우유를 좋아한다면 유당이 빠지고 지방 함량을 조절한 ‘강아지 전용 우유’로 급여하자.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1389649/%EC%9C%84%EB%93%9C%ED%8E%AB-%EB%B0%98%EB%A0%A4%EA%B2%AC%EC%97%90%EA%B2%90-%EB%8F%85%EC%95%BD-%EC%A0%88%EB%8C%80-%EB%A8%B9%EC%9C%BC%EB%A9%B4-%EC%95%88-%EB%90%98%EB%8A%94-%EC%8B%9D%ED%92%88/",
            "search_query": "사람우유를 강아지가 마시면 안되는 이유",
            "terminate": false,
            "text": "맞아요, 사람도 우유나 치즈를 먹으면 복통에 시달리는 사람들이 있잖아요. 이는 우유 속에 있는 유당을 분해하는 성분인 락타아제가 부족해서 발생하는 현상인데 강아지들도 마찬가지로 락타아제가 없기 때문에 우유를 소화하지 못해요. 그렇기 때문에 강아지가 우유나 치즈를 장기간 먹게 되면 소화나 위장 질환이 발생하게 되죠. 그러니까 강아지에게는 유당이 빠지고 지방 함령을 조절한 강아지 전용 우유를 주는 게 가장 좋습니다.",
            "turn_id": "BK22008788-6",
            "utterance_id": "BK22008788.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "완전히 이해가 됐어요. 강아지 전용 우유가 따로 나오는 이유가 있었네요. 저 그리고 강아지한테 가장 많이 주는 간식이 개껌인데요, 개껌이 강아지들에게 주는 효과는 어떤게 있나요?",
            "turn_id": "BK22008788-7",
            "utterance_id": "BK22008788.13"
        },
        {
            "reference_date": "2021-06-24",
            "reference_text": [
                {
                    "value": "먼저, 치석 제거 효과를 들 수 있다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "실제로 치석 제거 껌과 식이요법을 병행하면 치석을 70%까지 줄일 수 있다고.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "또 하나 개껌의 주요 효능으로 스트레스 해소를 꼽는다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
                    "value": "개들에게 씹는 행위는 매우 자연스럽고 큰 만족감을 느끼게 한다.",
                    "value_time": "2022-09-17",
                    "value_type": "variable"
                },
                {
