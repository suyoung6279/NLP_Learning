    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아내가 벌써 임신 36주가 되었어요. 출산일이 가까워지니 걱정도 많고 궁금한 것들도 많네요.",
            "turn_id": "BK22015994-1",
            "utterance_id": "BK22015994.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 어떤 점들이 궁금하세요?",
            "turn_id": "BK22015994-1",
            "utterance_id": "BK22015994.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "36주의 아기는 키가 어느정도 되나요?",
            "turn_id": "BK22015994-2",
            "utterance_id": "BK22015994.3"
        },
        {
            "reference_date": "2017-03-02",
            "reference_text": [
                {
                    "value": "아기의 키는 47.5cm, 체중은 2,600g 정도입니다.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.ksmnews.co.kr/default/index_view_page.php?idx=168583&part_idx=197",
            "search_query": "임신 36주 태아 크기",
            "terminate": false,
            "text": "네, 36주 아기의 키는 약 47.5cm, 체중은 약 2,600g 정도예요.",
            "turn_id": "BK22015994-2",
            "utterance_id": "BK22015994.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 이 시기의 태아는 어떤 특징이 있나요?",
            "turn_id": "BK22015994-3",
            "utterance_id": "BK22015994.5"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "내장기능도 원활해지고 근육도 제법 발달합니다.",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "출산 시기가 가까워져 머리를 점차 골반 안으로 집어넣게 돼 태아의 움직임이 점점 둔해지죠.",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "태반을 통해 모체로부터 질병에 대한 면역력이 전달됩니다.",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "임신 36주 태아 특징",
            "terminate": false,
            "text": "36주면 태아의 내장 기능이 원활해지고 근육도 꽤 발달을 해요. 태아가 머리를 점점 골만 안으로 집어넣게 되어 움직임이 둔해지며 모체로부터 질병에 대한 면역력이 전달되죠.",
            "turn_id": "BK22015994-3",
            "utterance_id": "BK22015994.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그럼 36주차 엄마의 몸 상태는 어떤가요?",
            "turn_id": "BK22015994-4",
            "utterance_id": "BK22015994.7"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "속이 한결 편해집니다.",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "태아가 골반 속으로 내려가면서 눌려 있던 숨도 덜 차고 식욕도 좋아집니다.",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "배가 커지면서 등이 당기고 부종이 생길 수 있습니다.",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "임신 36주 엄마의 증상",
            "terminate": false,
            "text": "태아가 골반 쪽으로 내려가면서 눌려 있던 숨도 덜 차고 식욕도 좋아져요. 속이 한결 편안해지죠. 하지만 배가 커지기 때문에 등이 당기고 부종이 생길 수 있어요.",
            "turn_id": "BK22015994-4",
            "utterance_id": "BK22015994.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 아내가 요즘 많이 불안해하는 것 같던데 제가 도울 방법이 없을까요?",
            "turn_id": "BK22015994-5",
            "utterance_id": "BK22015994.9"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "출산 일이 점차 다가오며 출산에 대한 불안감으로 인해 밤잠을 설치는 임신부들이 많은데요, 혼자서만 초조, 불안에 떨지 말고 남편과 이런 감정에 대해 솔직한 대화를 나누는 게 좋습니다.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "임신 36주 출산 불안감",
            "terminate": false,
            "text": "많은 임산부들이 출산일이 다가오면 불안해하거나 초조해하는데, 남편분과 이런 감정에 대해 함께 솔직한 대화를 나누면 좀 좋아질 거에요.",
            "turn_id": "BK22015994-5",
            "utterance_id": "BK22015994.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 아내 이야기를 많이 들어줘야겠네요. 참, 저희가 작은 병원을 다니는데, 큰 병원으로 옮기는 게 좋을까요?",
            "turn_id": "BK22015994-6",
            "utterance_id": "BK22015994.11"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "A: 간혹 개인병원에 다니던 임신부의 경우 출산에 대한 불안감에 큰 병원으로 옮길지 고민하는 경우가 있어요.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                },
                {
                    "value": "하지만 임신 초기부터 다녔던 병원에서 출산까지 하는 것이 안전합니다.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "임신 36주 큰병원",
            "terminate": false,
            "text": "간혹, 개인 병원에 다니던 임산부들이 출산에 대한 불안감으로 병원을 큰 곳으로 옮길 지 고민하는데, 임신 초기부터 다녔던 병원에서 출산하는 게 안전해요.",
            "turn_id": "BK22015994-6",
            "utterance_id": "BK22015994.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어떤 점 때문에 안전하다는 거죠? 아무래도 작은 병원보다는 큰 병원이 더 안전할 것 같은데요.",
            "turn_id": "BK22015994-7",
            "utterance_id": "BK22015994.13"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "출산이 임박해서 병원을 바꾸게 될 경우, 혹시 바뀐 의사가 임신부의 여러 상황을 제대로 파악하기도 전에 출산하게 된다면, 만일에 생길지도 모를 비상사태의 대처 능력이 떨어질 수 있기 때문이죠.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "임신 36주 병원을 바꾸게 될 경우",
            "terminate": false,
            "text": "출산이 가까워져서 병원을 바꾸게 된다면 바뀐 의사가 임산부의 여러 상황을 제대로 파악하기도 전에 출산을 할 수가 있고, 그렇게 되면 혹시 모를 비상사태의 대처 능력이 떨어질 수 있어요.",
            "turn_id": "BK22015994-7",
            "utterance_id": "BK22015994.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 이제 출산이 가까워지면서 주변에서 출산 징후를 잘 살펴보라고 하던데, 출산 징후에는 어떤 증상들이 있나요?",
            "turn_id": "BK22015994-8",
            "utterance_id": "BK22015994.15"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "여러 가지 출산 징후를 미리 알아두는 것이 좋습니다.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                },
                {
                    "value": "1. 위 주위가 가벼워진다",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "2. 배가 자주 당긴다",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "3. 태아의 움직임이 적어진다",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                },
                {
                    "value": "6. 주기적으로 진통이 찾아온다",
                    "value_time": "2022-10-13",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "출산징후",
            "terminate": false,
            "text": "먼저 위 주위가 가벼워지고 배가 자꾸 당긴다거나 태아의 움직임이 적어지고 주기적으로 진통이 오는 것들이 출산 징후라고 볼 수 있어요.",
            "turn_id": "BK22015994-8",
            "utterance_id": "BK22015994.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "주기적으로 진통이 올 수 있다니, 예정일이 정해져 있는데, 그 전에 진통이 올 수 있다는 건가요?",
            "turn_id": "BK22015994-9",
            "utterance_id": "BK22015994.17"
        },
        {
            "reference_date": "2021-09-21",
            "reference_text": [
                {
                    "value": "아기가 꼭 예정일에 태어나는 것이 아니므로 자궁이 수축하는 듯하면 주기가 일정한지 체크해 병원에서 상담을 받습니다.",
                    "value_time": "2022-10-13",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108510",
            "search_query": "임신 예정일 자궁 수축",
            "terminate": false,
            "text": "네, 맞아요. 아이가 꼭 예정일에 태어나는 건 아니에요. 그렇기 때문에 말씀드렸던 출산 징후를 보인다거나 자궁이 수축하는 듯하면 주기가 일정한지 체크하고 병원으로 가는 게 좋아요.",
            "turn_id": "BK22015994-9",
            "utterance_id": "BK22015994.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 이제 수시로 아내의 상태를 잘 살펴야겠네요. 오늘 친절한 설명 덕분에 많은 도움이 되었어요. 정말 감사해요.",
            "turn_id": "BK22015994-10",
            "utterance_id": "BK22015994.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "별말씀을요, 도움이 되셨다니 정말 다행이네요. 또 궁금한 점 있으시면 언제든지 물어보세요.",
            "turn_id": "BK22015994-10",
            "utterance_id": "BK22015994.20"
        }
    ]
}