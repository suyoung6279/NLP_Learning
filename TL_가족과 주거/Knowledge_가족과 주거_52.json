    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지의 체온이 사람보다 높다던데 혹시 알아?",
            "turn_id": "BK22012652-1",
            "utterance_id": "BK22012652.1"
        },
        {
            "reference_date": "2018-08-10",
            "reference_text": [
                {
                    "value": "게다가 강아지 평균체온은 사람보다 약 2℃ 가량 높은 37.5~39℃입니다.",
                    "value_time": "2022-08-02",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.amnews.co.kr/news/articleView.html?idxno=33668",
            "search_query": "강아지 평균체온",
            "terminate": false,
            "text": "강아지의 평균 체온은 37.5도에서 39도 사이라서 사람보다 약 2도 정도 높아.",
            "turn_id": "BK22012652-1",
            "utterance_id": "BK22012652.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "사람보다 2도나 높구나! 요즘 날씨가 너무 더운데 산책시켜도 될까?",
            "turn_id": "BK22012652-2",
            "utterance_id": "BK22012652.3"
        },
        {
            "reference_date": "2022-07-21",
            "reference_text": [
                {
                    "value": "강아지 산책은 햇볕이 뜨거운 낮 시간대를 피하고 상대적으로 선선한 이른 아침과 저녁에 진행하는 것을 추천한다.",
                    "value_time": "2022-08-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.insight.co.kr/news/403438",
            "search_query": "강아지 산책시간",
            "terminate": false,
            "text": "볕이 뜨거운 낮에는 산책을 피해주고 선선한 아침 일찍이나 저녁에 산책을 시키는 게 좋아.",
            "turn_id": "BK22012652-2",
            "utterance_id": "BK22012652.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아예 일찍 산책을 시켜야겠다. 혹시 털을 깎아주면 덜 덥지 않을까?",
            "turn_id": "BK22012652-3",
            "utterance_id": "BK22012652.5"
        },
        {
            "reference_date": "2022-06-07",
            "reference_text": [
                {
                    "value": "강아지의 털은 자외선을 차단해주는 역할을 하는데, 이 털이 너무 짧아지면 자외선이 직접적으로 피부에 닿아 피부병을 유발한다.",
                    "value_time": "2022-08-02",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.dailypop.kr/news/articleView.html?idxno=60449",
            "search_query": "강아지 짧은 털 자외선",
            "terminate": false,
            "text": "털을 너무 짧게 깎아주지 않는 게 좋아. 강아지의 털은 자외선을 막아주는 역할을 하는데 털이 짧아지게 되면 자외선이 피부에 직접 닿아서 피부병을 발생시키거든.",
            "turn_id": "BK22012652-3",
            "utterance_id": "BK22012652.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 몇 센티 정도를 남겨두고 털을 깎아주는 게 좋아?",
            "turn_id": "BK22012652-4",
            "utterance_id": "BK22012652.7"
        },
        {
            "reference_date": "2022-06-07",
            "reference_text": [
                {
                    "value": "만약 미용을 해야 한다면 털의 길이는 3cm 이상이 되게 하자.",
                    "value_time": "2022-08-02",
                    "value_type": "variable"
                },
                {
                    "value": "털을 미는 것보다는 자주 빗질을 해주는 것이 좋다.",
                    "value_time": "2022-08-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.dailypop.kr/news/articleView.html?idxno=60449",
            "search_query": "털 미용 길이",
            "terminate": false,
            "text": "최소 3cm 이상의 털을 남겨두고 미용을 시키는 게 좋아. 또한 자주 빗질을 해주는 게 털을 밀어주는 것보다 좋아.",
            "turn_id": "BK22012652-4",
            "utterance_id": "BK22012652.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나. 그럼 스트레스도 덜 받게 빗질을 자주 해줘야겠다.",
            "turn_id": "BK22012652-5",
            "utterance_id": "BK22012652.9"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그런데 키우는 강아지의 종류가 뭐야?",
            "turn_id": "BK22012652-5",
            "utterance_id": "BK22012652.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리 집 강아지는 슈나우저야! 슈나우저가 가축을 몰고 다녔던 품종이었던 거 알아?",
            "turn_id": "BK22012652-6",
            "utterance_id": "BK22012652.11"
        },
        {
            "reference_date": "2022-03-06",
            "reference_text": [
                {
                    "value": "슈나우저는 1400년대 말부터 독일에서 농장개로 길러져, 쥐를 잡고 가축을 몰고 다니며 외양간을 지켰다고 한다.",
                    "value_time": "2022-08-02",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://ko.wikipedia.org/wiki/%EC%8A%88%EB%82%98%EC%9A%B0%EC%A0%80",
            "search_query": "슈나우저",
            "terminate": false,
            "text": "그럼 알고 있지. 슈나우저는 독일에서 1400년 말부터 농장 개로 사육됐는데 가축을 몰고 다니고 쥐를 사냥하면서 외양간을 지켰어.",
            "turn_id": "BK22012652-6",
            "utterance_id": "BK22012652.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "슈나우저에 대해서 잘 아는구나? 그런데 슈나우저가 원래 털이 잘 안 빠지는 품종인가?",
            "turn_id": "BK22012652-7",
            "utterance_id": "BK22012652.13"
        },
        {
            "reference_date": "2020-09-08",
            "reference_text": [
                {
                    "value": "슈나우저는 푸들과 함께 대표적인 장모종이지만 털이 많이 빠지지 않는다.",
                    "value_time": "2022-08-02",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://sisunnews.co.kr/news/articleView.html?idxno=129925",
            "search_query": "슈나우저 털빠짐",
            "terminate": false,
            "text": "강아지를 좋아하거든. 슈나우저는 푸들처럼 대표적인 장모종에 속하지만 털 빠짐이 심하지 않아.",
            "turn_id": "BK22012652-7",
            "utterance_id": "BK22012652.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맞아! 털 빠짐이 그렇게 심하진 않은데 그래도 빗질을 해주는 게 좋겠지?",
            "turn_id": "BK22012652-8",
            "utterance_id": "BK22012652.15"
        },
        {
            "reference_date": "2020-03-16",
            "reference_text": [
                {
                    "value": "반려견의 건강한 모질을 위해서는 일주일에 3번 이상, 되도록이면 매일 빗겨주는 것이 좋다.",
                    "value_time": "2022-08-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.news1.kr/articles/?3874293",
            "search_query": "강아지 빗질",
            "terminate": false,
            "text": "당연하지. 강아지의 건강한 털을 위해서는 되도록 매일 빗질을 해주는 게 좋고 일주일에 3번 이상 해주는 게 좋아.",
            "turn_id": "BK22012652-8",
            "utterance_id": "BK22012652.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지를 위해서 매일 빗질을 해줘야겠다. 그런데 날이 더우니까 목욕을 자주 시켜줘도 괜찮을까?",
            "turn_id": "BK22012652-9",
            "utterance_id": "BK22012652.17"
        },
        {
            "reference_date": "2022-06-18",
            "reference_text": [
                {
                    "value": "강아지는 일반적으로 2~3주에 한 번 목욕하는 것이 적당합니다.",
                    "value_time": "2022-08-02",
                    "value_type": "variable"
                },
                {
                    "value": "또한 최소 3개월에 한 번은 꼭 하는 것이 좋습니다.",
                    "value_time": "2022-08-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/202206171725499427",
            "search_query": "강아지 목욕",
            "terminate": false,
            "text": "보통 2주에서 3주에 한 번 목욕을 시키는 게 좋고, 최소 3달에 한 번은 목욕을 꼭 시켜주는 게 좋지.",
            "turn_id": "BK22012652-9",
            "utterance_id": "BK22012652.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "한 달에 한두 번 정도가 적당하구나. 말 나온 김에 강아지 목욕시키러 갈게!",
            "turn_id": "BK22012652-10",
            "utterance_id": "BK22012652.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "그래. 강아지 목욕 잘 시키고 빗질도 잘 해줘!",
            "turn_id": "BK22012652-10",
            "utterance_id": "BK22012652.20"
        }
    ]
}