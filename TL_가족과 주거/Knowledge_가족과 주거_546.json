    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "남편 없이 아이들을 홀로 키우는데 가정 형편이 좋지 않아 너무 힘드네요.",
            "turn_id": "BK22001637-1",
            "utterance_id": "BK22001637.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아이고, 남편 분 없이 혼자서 아이들을 키우시는 거군요. 혹시 한부모 가족이 맞으실까요?",
            "turn_id": "BK22001637-1",
            "utterance_id": "BK22001637.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "네, 혼자 아이를 키우고 있는 한부모 가족이 맞아요.",
            "turn_id": "BK22001637-2",
            "utterance_id": "BK22001637.3"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 그러면 한부모 가족 아동 양육비 지원 내용에 대해서도 아시나요?",
            "turn_id": "BK22001637-2",
            "utterance_id": "BK22001637.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저소득 한부모 가족 지원이요? 혹시 어떤 지원을 받을 수 있는 건가요?",
            "turn_id": "BK22001637-3",
            "utterance_id": "BK22001637.5"
        },
        {
            "reference_date": "2019-12-13",
            "reference_text": [
                {
                    "value": "아동양육비는 조건에 해당되는 자녀 한 명당 한 달에 20만 원씩 지원된다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.woodkorea.co.kr/news/articleView.html?idxno=41201",
            "search_query": "한부모가족 아동양육비",
            "terminate": false,
            "text": "아동 양육비 조건에 해당한다면 자녀 한 명당 한 달에 20만 원씩 지원받을 수 있어요.",
            "turn_id": "BK22001637-3",
            "utterance_id": "BK22001637.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "한 명당 20만 원이라니 정말 큰 도움이 될 것 같네요.",
            "turn_id": "BK22001637-4",
            "utterance_id": "BK22001637.7"
        },
        {
            "reference_date": "2019-12-08",
            "reference_text": [
                {
                    "value": "한부모가족 아동양육비에 선정될 경우 만 18세 미만의 자녀 한 명당 아동양육비를 지원하고 학용품비, 생활보조금까지 지원받을 수 있다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.woodkorea.co.kr/news/articleView.html?idxno=40689",
            "search_query": "한부모가족 아동양육비 혜택",
            "terminate": false,
            "text": "그뿐만 아니라 한부모 가족 아동 양육비에 선정이 된다면 양육비 말고도 학용품비나 생활보조금도 지원받을 수 있죠. 만 18세 미만 자녀 한 명당이니 부담이 조금 덜할 거예요.",
            "turn_id": "BK22001637-4",
            "utterance_id": "BK22001637.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "와, 혜택이 정말 많네요. 그런데 학용품비는 한부모 가족 아동 양육비 혜택을 받는 가정이라면 모두가 받을 수 있는 건가요?",
            "turn_id": "BK22001637-5",
            "utterance_id": "BK22001637.9"
        },
        {
            "reference_date": "2019-12-23",
            "reference_text": [
                {
                    "value": "학용품비는 한부모가족의 중학생 및 고등학생 자녀가 해당된다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.dailysecu.com/news/articleView.html?idxno=89848",
            "search_query": "한부모가족 학용품비",
            "terminate": false,
            "text": "아니요, 아쉽게도 학용품비는 중학생이나 고등학생 자녀들만 받을 수 있는 지원이에요.",
            "turn_id": "BK22001637-5",
            "utterance_id": "BK22001637.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아하, 학용품비의 경우는 연령대에 따라 지원되는 경우도 있고 아닌 경우도 있는 거군요.",
            "turn_id": "BK22001637-6",
            "utterance_id": "BK22001637.11"
        },
        {
            "reference_date": "2021-04-24",
            "reference_text": [
                {
                    "value": "종전에는 저소득 조손가족 혹은 만 25세 이상 미혼 한부모가족의 만 5세 이하 아동에게 추가아동양육비 월 5만 원이 지원됐다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                },
                {
                    "value": "하지만 5월부터는 만 25세~34세 이하 청년 한부모가구도 자녀 나이에 따라 추가아동양육비를 차등 지원된다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.jeollailbo.com/news/articleView.html?idxno=625672",
            "search_query": "한부모가족 추가양육비 만 5세",
            "terminate": false,
            "text": "네, 맞아요. 또 나이 제한이 있는 다른 지원을 말씀드리자면 추가 아동 양육비 역시 만 5세 이하 아동만 받을 수 있는 지원이에요. 이전까지는 25세 이상 미혼 한부모 가족에게만 지원했지만 이제는 만 25세에서 34세 이하 청년 한부모 가구라면 추가 아동 양육비를 차등 지원받을 수 있어요.",
            "turn_id": "BK22001637-6",
            "utterance_id": "BK22001637.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "추가 양육비도 나이에 따라 수급 여부가 달라지는 거군요. 잘 알아두어야겠어요. 그런데 이렇게 혜택이 많으면 자격요건도 까다롭겠죠?",
            "turn_id": "BK22001637-7",
            "utterance_id": "BK22001637.13"
        },
        {
            "reference_date": "2019-12-18",
            "reference_text": [
                {
                    "value": "한부모가족 혜택 신청 조건은 소득인정액이 기준 중위소득 52% 이하이면서 만 18세 미만의 아동을 양육하는 한부모가족 및 조손가족이다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.woodkorea.co.kr/news/articleView.html?idxno=41573",
            "search_query": "한부모가족 아동양육비 소득기준",
            "terminate": false,
            "text": "몇 가지의 자격요건이 있기는 해요. 소득인정액이 중위소득 52퍼센트 이하여야 하고 만 18세 아동들을 양육하는 한부모가족과 조손가족만이 신청 가능하죠.",
            "turn_id": "BK22001637-7",
            "utterance_id": "BK22001637.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나머지 요건들은 충족이 되긴 하는데 소득인정액이 아슬아슬하게 통과되거나 넘어서 못 받을 것 같아요. 어떡하죠?",
            "turn_id": "BK22001637-8",
            "utterance_id": "BK22001637.15"
        },
        {
            "reference_date": "2022-02-02",
            "reference_text": [
                {
                    "value": "또 일하는 한부모의 경제적 자립을 지원하기 위해 근로‧사업소득을 30% 공제해 소득을 산정한다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.breaknews.com/869009",
            "search_query": "한부모가족 소득 공제",
            "terminate": false,
            "text": "아, 제가 미처 말씀드리지 못한 부분이 있네요. 일하는 한부모의 경제적 자립을 위해 근로 사업 소득은 30퍼센트를 공제해서 소득을 산정하고 있어요.",
            "turn_id": "BK22001637-8",
            "utterance_id": "BK22001637.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "30퍼센트라면 꽤 크네요. 그 기준을 적용하면 가뿐하게 통과하겠어요. 그런데 혹시 내년에 월급이 오르거나 하면 지원이 끊길까 봐 걱정이네요.",
            "turn_id": "BK22001637-9",
            "utterance_id": "BK22001637.17"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "정부는 한부모가족 양육비 지원 기준도 현행 기준중위소득 52% 이하에서 63% 이하로 단계적으로 높여 한부모가족 보호를 강화할 방침이다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nocutnews.co.kr/news/5772033",
            "search_query": "한부모가족 세금 면제",
            "terminate": false,
            "text": "그 부분에 대해서는 정부가 현 기준 중위소득 52퍼센트 이하에서 63퍼센트 이하로 단계적으로 높여 한부모 가족 보호를 강화할 예정이니 걱정 마세요.",
            "turn_id": "BK22001637-9",
            "utterance_id": "BK22001637.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "기준을 높인다니 한결 안심이 되네요. 그런데 혹시 어디서 신청하는지도 알려주실 수 있을까요?",
            "turn_id": "BK22001637-10",
            "utterance_id": "BK22001637.19"
        },
        {
            "reference_date": "2022-02-20",
            "reference_text": [
                {
                    "value": "만 18세 미만 자녀를 둔 저소득 한부모 가족은 주민등록상 주소지가 있는 동주민센터 또는 한부모상담전화(1644-6621), 온라인(online.bokjiro.go.kr)으로 지원을 신청하면 된다.",
                    "value_time": "2022-07-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.khan.co.kr/national/national-general/article/202202202137015",
            "search_query": "한부모가족자녀 온라인 신청",
            "terminate": false,
            "text": "주민등록상 주소지가 있는 동주민센터나 한부모 상담전화를 통해 신청하시면 돼요. 복지로 홈페이지에서 온라인상으로도 신청이 가능하고요.",
            "turn_id": "BK22001637-10",
            "utterance_id": "BK22001637.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "온라인이나 전화로도 신청이 가능한 점이 좋네요. 일까지 하고 아이들을 돌보려면 방문할 시간이 없을 것 같아서 걱정이 많았거든요.",
            "turn_id": "BK22001637-11",
            "utterance_id": "BK22001637.21"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러게요. 말씀을 들어보니 방문하지 않고 신청할 수 있어서 다행이네요.",
            "turn_id": "BK22001637-11",
            "utterance_id": "BK22001637.22"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "정말 집에 가자마자 신청해야겠어요. 오늘 알려주신 정보 덕에 저희 가족이 숨통이 트일 것 같아요. 정말 감사합니다.",
            "turn_id": "BK22001637-12",
            "utterance_id": "BK22001637.23"
        }
    ]
}