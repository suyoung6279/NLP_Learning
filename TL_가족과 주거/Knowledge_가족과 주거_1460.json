    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "결혼 후 처음 맞는 명절이라 양가 가족들을 모두 만나 뵙기로 했어요. 그런데 호칭 문제가 너무 어렵게 느껴져요. 저만 이렇게 호칭이 어려운 걸까요?",
            "turn_id": "BK22011413-1",
            "utterance_id": "BK22011413.1"
        },
        {
            "reference_date": "2013-09-10",
            "reference_text": [
                {
                    "value": "연합뉴스에 따르면 경기도 여성능력개발센터가 운영하는 온라인평생학습사이트 ’홈런‘이 추석을 맞아 회원 2467명을 대상으로 가족 호칭 설문조사를 해보니 응답자의 51%(1249명)가 ’호칭을 잘 모른다‘고 답했다.",
                    "value_time": "2022-09-29",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://news.heraldcorp.com/view.php?ud=20130910000357",
            "search_query": "헷갈리는 가족호칭",
            "terminate": false,
            "text": "궁금이님만 어려워하는 건 아니에요. 경기도 여성능력개발센터에서 운영 중인 온라인평생학습사이트에서 2467명을 대상으로 가족 호칭에 관한 설문 조사를 실시했는데요. 응답자의 51%인 1249명이 이런 가족 호칭을 잘 모른다고 답했어요.",
            "turn_id": "BK22011413-1",
            "utterance_id": "BK22011413.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저 뿐만 아니라 많은 분들이 호칭에 대한 어려움을 느끼고 있는 거네요. 그럼 남편이 저희 친정에 갔을 때 제 친언니에게 어떤 호칭을 써야 하나요?",
            "turn_id": "BK22011413-2",
            "utterance_id": "BK22011413.3"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "우선, 아내의 언니의 경우 남편이 '처형'이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "아내의 언니 호칭",
            "terminate": false,
            "text": "남편이 아내의 언니를 부를 때는 처형이라고 하면 돼요.",
            "turn_id": "BK22011413-2",
            "utterance_id": "BK22011413.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아 그렇군요. 그럼 제 남편이 저의 형부를 부를 때는 어떻게 불러야 할까요?",
            "turn_id": "BK22011413-3",
            "utterance_id": "BK22011413.5"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "언니의 남편이 자신보다 나이가 많을 때에는 '형님'이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                },
                {
                    "value": "나이가 어릴 때에는 '동서'라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "언니의 남편 가족호칭",
            "terminate": false,
            "text": "언니의 남편이 궁금이님의 남편보다 나이가 많다면 형님으로, 나이가 어린 경우라면 동서라고 부르시면 돼요.",
            "turn_id": "BK22011413-3",
            "utterance_id": "BK22011413.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알겠어요. 제가 남동생도 있는데 저희 남편이 남동생을 부를 땐 어떤 호칭을 써야 하죠?",
            "turn_id": "BK22011413-4",
            "utterance_id": "BK22011413.7"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "아내의 남동생의 경우, 처남이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "아내의 남동생 가족호칭",
            "terminate": false,
            "text": "아내의 남동생을 부를 때는 처남이라는 호칭을 사용해주면 돼요.",
            "turn_id": "BK22011413-4",
            "utterance_id": "BK22011413.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저희 남동생도 결혼을 했는데 남동생의 부인한테는 어떤 호칭이 맞는 건가요?",
            "turn_id": "BK22011413-5",
            "utterance_id": "BK22011413.9"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "그의 아내를 부를 때에는 처남댁이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "아내의 남동생 아내 가족호칭",
            "terminate": false,
            "text": "남동생의 아내는 처남댁으로 부르면 돼요.",
            "turn_id": "BK22011413-5",
            "utterance_id": "BK22011413.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "댁만 붙이면 되는거네요. 남편이 누나와 여동생이 있는데 제가 시댁에 방문했을 때 남편의 누나에게는 뭐라고 부르면 되죠?",
            "turn_id": "BK22011413-6",
            "utterance_id": "BK22011413.11"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "남편의 누나를 '형님'이라고 부르고 그의 남편을 '아주버님'이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "남편의 누나 가족호칭",
            "terminate": false,
            "text": "남편의 누나는 형님이라고 부르시면 돼요.",
            "turn_id": "BK22011413-6",
            "utterance_id": "BK22011413.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 남편의 여동생에게도 형님이라고 해야 하나요?",
            "turn_id": "BK22011413-7",
            "utterance_id": "BK22011413.13"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "여동생의 경우 '아가씨' 그의 남편을 '서방님'이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "남편 여동생 가족호칭",
            "terminate": false,
            "text": "아니에요. 남편의 여동생이라면 아가씨, 아가씨의 남편은 서방님이라 부르시면 돼요.",
            "turn_id": "BK22011413-7",
            "utterance_id": "BK22011413.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 동서는 누구에게 사용하는 호칭인가요?",
            "turn_id": "BK22011413-8",
            "utterance_id": "BK22011413.15"
        },
        {
            "reference_date": "2019-02-05",
            "reference_text": [
                {
                    "value": "남편의 남동생의 경우 미혼일 때에는 '도련님', 기혼일 때에는 '서방님'이라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                },
                {
                    "value": "그의 아내에게는 '동서'라고 부른다.",
                    "value_time": "2022-09-23",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20190130001737023",
            "search_query": "동서 가족호칭",
            "terminate": false,
            "text": "남편의 결혼한 남동생의 아내에게 동서라는 호칭을 사용할 수 있어요.",
            "turn_id": "BK22011413-8",
            "utterance_id": "BK22011413.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇군요. 이 정도면 알면 이번 모임에서 호칭 실수 할 일은 없을 것 같아요.",
            "turn_id": "BK22011413-9",
            "utterance_id": "BK22011413.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "네. 조금은 헷갈리고 어렵게 느껴질 수 있지만 미리 알고 외워두시면 될 거예요.",
            "turn_id": "BK22011413-9",
            "utterance_id": "BK22011413.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알려주신 것들 꼭 외워서 갈게요. 어떤 호칭을 써야 할지 너무 어렵게 느껴졌는데 도움 주셔서 감사해요.",
            "turn_id": "BK22011413-10",
            "utterance_id": "BK22011413.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "별말씀을요. 결혼 후 첫 가족모임 즐겁게 하시고 다음에 또 봬요. 안녕히 가세요.",
            "turn_id": "BK22011413-10",
            "utterance_id": "BK22011413.20"
        }
    ]
}