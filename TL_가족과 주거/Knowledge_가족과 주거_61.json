    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지가 토를 했는데 어떻게 해야 할까?",
            "turn_id": "BK22012777-1",
            "utterance_id": "BK22012777.1"
        },
        {
            "reference_date": "43872.0",
            "reference_text": [
                {
                    "value": "반려견이 구토를 하더라도 활력이 어느정도 남아있고, 발열이나 설사 등의 증상이 없다면 크게 문제삼을 것 없이 1~2끼 정도 금식을 시키고 물을 준 다음 소량의 사료를 주기 시작하는 것이 좋다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.mt.co.kr/mtview.php?no=2020021015222623763",
            "search_query": "강아지 구토",
            "terminate": false,
            "text": "강아지가 토를 한 후에 열이 나거나 설사를 하지 않는 등, 활력이 어느 정도 남아있다면 너무 걱정하지 않아도 돼. 한 끼에서 두 끼 정도 밥을 먹이지 않고, 물을 먹인 후 사료를 조금씩 주는 게 좋아.",
            "turn_id": "BK22012777-1",
            "utterance_id": "BK22012777.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그런데 왜 강아지가 토를 하는 걸까?",
            "turn_id": "BK22012777-2",
            "utterance_id": "BK22012777.3"
        },
        {
            "reference_date": "43872.0",
            "reference_text": [
                {
                    "value": "개의 구토 원인엔 여러가지가 있을 수 있다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                },
                {
                    "value": "그 중 가장 흔한 원인으로는 새로운 음식이나 몸에 맞지 않는 음식을 섭취한 경우가 있다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.mt.co.kr/mtview.php?no=2020021015222623763",
            "search_query": "강아지 구토 원인",
            "terminate": false,
            "text": "다양한 이유로 인해서 강아지가 토를 할 수 있는데, 그중에서도 처음 먹는 음식이나 몸에 안 맞는 음식을 먹으면 강아지가 구토를 할 수 있어.",
            "turn_id": "BK22012777-2",
            "utterance_id": "BK22012777.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇다면 어떤 음식이 강아지의 구토를 유발해?",
            "turn_id": "BK22012777-3",
            "utterance_id": "BK22012777.5"
        },
        {
            "reference_date": "44775.0",
            "reference_text": [
                {
                    "value": "개가 자일리톨을 먹으면 가벼운 배탈과 구토 발작을 일으킬 수 있으며, 간 기능 부전과 사망으로 이어질 수 있다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1411848/",
            "search_query": "개 자일리톨 구토",
            "terminate": false,
            "text": "강아지가 자일리톨을 먹게 되면 구토나 발작, 간 기능 부전 또는 가벼운 배탈이 생길 수 있고 심하면 목숨까지 잃을 수 있어.",
            "turn_id": "BK22012777-3",
            "utterance_id": "BK22012777.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 포도를 먹어도 구토를 할 수 있어?",
            "turn_id": "BK22012777-4",
            "utterance_id": "BK22012777.7"
        },
        {
            "reference_date": "44653.0",
            "reference_text": [
                {
                    "value": "포도는 반려견에게 치명적인 과일이다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                },
                {
                    "value": "증상이 가벼울 땐 구토와 설사로 끝날 수 있지만, 중독 증상이 심할 경우 신부전증과 사망으로 이어진다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1389649/",
            "search_query": "강아지 포도 구토",
            "terminate": false,
            "text": "강아지한테 포도는 생명을 위험할 수 있는 과일이야. 증상이 심하지 않으면 구토와 설사만 할 수 있지만, 포도 중독이 심하면 신부전증이 생기거나 목숨을 잃을 수 있어.",
            "turn_id": "BK22012777-4",
            "utterance_id": "BK22012777.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "초콜릿도 구토를 유발하지 않아?",
            "turn_id": "BK22012777-5",
            "utterance_id": "BK22012777.9"
        },
        {
            "reference_date": "44775.0",
            "reference_text": [
                {
                    "value": "메틸잔틴은 구토와 설사, 헐떡임, 과도한 갈증과 배뇨, 과잉 행동, 비정상적 심장박동, 경련, 발작, 사망을 초래할 수 있다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                },
                {
                    "value": "베이킹에 들어간 초콜릿은 가장 높은 수준의 메틸잔틴을 함유하고 있다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                },
                {
                    "value": "커피와 차도 이러한 물질을 가지고 있어 개에게 주면 절대 안 된다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1411848/",
            "search_query": "강아지 초콜릿 구토",
            "terminate": false,
            "text": "빵을 만들 때 들어가는 초콜릿과 커피나 차에는 메틸잔틴을 제일 높은 수준으로 포함하고 있어서 강아지가 목숨을 잃을 수 있어. 그로 인해 구토와 경련, 발작, 헐떡임, 설사, 과잉행동이 생길 수 있어. 또한 심장박동이 비정상적으로 바뀌거나 배뇨 또는 갈증을 심하게 느낄 수 있기 때문에 절대로 주면 안 돼.",
            "turn_id": "BK22012777-5",
            "utterance_id": "BK22012777.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 아보카도도 먹게 되면 구토를 할까?",
            "turn_id": "BK22012777-6",
            "utterance_id": "BK22012777.11"
        },
        {
            "reference_date": "44653.0",
            "reference_text": [
                {
                    "value": "아보카도는 과육과 씨앗, 잎에 모두 식물성 화합물질인 퍼신(Persin)을 함유한다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                },
                {
                    "value": "이는 사람에겐 무해하지만, ‘반려견에게 유해’하다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                },
                {
                    "value": "구토 등의 위장 장애가 일으키고, 폐와 심장에 퍼신이 축적돼 호흡곤란도 발생시킨다.",
                    "value_time": "44817.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1389649/",
            "search_query": "강아지 아보카도 구토",
            "terminate": false,
            "text": "식물성 화합 물질인 퍼신이 아보카도 잎과 씨앗 그리고 과육이 모두 들어있는데, 사람한테는 해를 끼치지 않지만, 강아지에게는 해로워. 만약 강아지가 아보카도를 먹었다면 구토와 같은 위장 장애가 발생하고, 심장과 폐에 퍼신이 쌓여 호흡곤란이 생기게 돼.",
            "turn_id": "BK22012777-6",
            "utterance_id": "BK22012777.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지에게 구토를 유발하는 음식이 굉장히 많구나?",
            "turn_id": "BK22012777-7",
            "utterance_id": "BK22012777.13"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래서 강아지에게 위험한 음식을 먹지 못하도록 항상 주의를 가져야 해.",
            "turn_id": "BK22012777-7",
            "utterance_id": "BK22012777.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "음식 말고도 강아지가 구토를 하게 되는 이유에 또 어떤 것이 있어?",
            "turn_id": "BK22012777-8",
            "utterance_id": "BK22012777.15"
        },
        {
            "reference_date": "44814.0",
            "reference_text": [
                {
                    "value": "보통 이물을 먹었을 때는 구토, 설사, 복통, 식욕부진, 호흡곤란 등의 증상이 나타난다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                },
                {
                    "value": "또 이물을 먹는 장면을 발견했다면 억지로 이물을 빼내려고 하지 말고 반드시 동물병원에 방문해 전문가의 도움을 받을 것을 당부한다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.k-health.com/news/articleView.html?idxno=61083",
            "search_query": "이물질 구토 동물병원",
            "terminate": false,
            "text": "강아지 이물질을 먹게 되면 구토나 복통, 설사, 호흡곤란 또는 식욕이 저하되는 등의 증상이 생기게 돼. 만약 이물질을 먹는 걸 봤다면 무리하게 이물질을 빼내려고 하는 것보다는, 무조건 동물 병원에 데려가서 수의사에게 진료를 받아야 해.",
            "turn_id": "BK22012777-8",
            "utterance_id": "BK22012777.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "이물질을 먹게 되면 구토 외에 다른 질환이 생길 수 있어?",
            "turn_id": "BK22012777-9",
            "utterance_id": "BK22012777.17"
        },
        {
            "reference_date": "43872.0",
            "reference_text": [
                {
                    "value": "그 외에는 음식이 아닌 이물을 섭취해 위나 장이 막히는 경우가 있다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                },
                {
                    "value": "만약 자연적으로 분해되기 힘든 물질을 반려견이 삼켰다면 큰 수술이 필요할 수 있으므로 동물병원에 가야 한다.",
                    "value_time": "44817.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.mt.co.kr/mtview.php?no=2020021015222623763",
            "search_query": "강아지 이물질 장",
            "terminate": false,
            "text": "강아지가 이물질을 먹게 되면 장이나 위가 막힐 수 있기 때문에, 삼킨 물질이 자연스럽게 나눠져 사라지는 게 아니라면 큰 수술을 해야 할 수도 있기 때문에 동물 병원에 데려가야 해.",
            "turn_id": "BK22012777-9",
            "utterance_id": "BK22012777.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지를 키우면 정말 신경 쓸게 많은 것 같아.",
            "turn_id": "BK22012777-10",
            "utterance_id": "BK22012777.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "신경 쓸게 많긴 하지만 그보다 더 큰 행복을 주는 소중한 존재니까 더 신경 써줘.",
            "turn_id": "BK22012777-10",
            "utterance_id": "BK22012777.20"
        }
    ]
}