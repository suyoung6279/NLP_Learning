    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "요즘 데이팅 앱이 그렇게 인기라면서요?",
            "turn_id": "BK22015086-1",
            "utterance_id": "BK22015086.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "네, 주변에서 많이들 하더라고요.",
            "turn_id": "BK22015086-1",
            "utterance_id": "BK22015086.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "왜 갑자기 데이팅 앱 이용이 활발해진 걸까요?",
            "turn_id": "BK22015086-2",
            "utterance_id": "BK22015086.3"
        },
        {
            "reference_date": "2022-04-28",
            "reference_text": [
                {
                    "value": "2년 넘게 지속된 신종 코로나바이러스 감염증(코로나19) 팬데믹(세계적 대유행)으로 인해 데이팅 애플리케이션(앱) 이용자 수가 증가한 것으로 나타났다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/it/view/2022/04/378325/",
            "search_query": "데이팅 앱 이용자 증가",
            "terminate": false,
            "text": "2년 넘게 지속된 코로나바이러스 감염증의 대유행으로 인해 이용자 수가 증가하게 되었어요.",
            "turn_id": "BK22015086-2",
            "utterance_id": "BK22015086.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "데이팅 앱이라, 이용자 수가 얼마나 늘어났는데요?",
            "turn_id": "BK22015086-3",
            "utterance_id": "BK22015086.5"
        },
        {
            "reference_date": "2022-04-28",
            "reference_text": [
                {
                    "value": "SK그룹의 디지털 광고 전문기업 인크로스가 집계한 통계 리포트에 따르면 지난달 기준 상위 10개 데이팅 앱의 월간 순이용자(MAU) 수는 78만7184명으로 코로나19 확산 이전인 2019년 4월(58만4000명)과 비교하면 34.8% 늘어났다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/it/view/2022/04/378325/",
            "search_query": "데이팅 앱 이용자 증가",
            "terminate": false,
            "text": "인크로스가 집계한 통계 리포트에 따르면 지난달 기준 상위 10개 데이팅 앱의 월간 순 이용자 수는 78만7184명으로 코로나19 확산 이전인 2019년 4월 58만 4000명과 비교하면 34.8퍼센트 늘어난 수준이에요.",
            "turn_id": "BK22015086-3",
            "utterance_id": "BK22015086.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "처음 데이팅 앱이 생겼을 때는 쓰는 사람이 적을 거라고 생각했는데, 이제는 꽤 많은 사람이 사용하네요. 혹시 데이팅 앱이 어떻게 처음 생겨난 건지 아시나요?",
            "turn_id": "BK22015086-4",
            "utterance_id": "BK22015086.7"
        },
        {
            "reference_date": "2022-09-07",
            "reference_text": [
                {
                    "value": "초기 데이팅 광고의 역사는 1727년으로 거슬러 올라간다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                },
                {
                    "value": "만남을 기다리던 영국 여성 헬렌 모리슨은 '맨체스터 위클리 저널'에 광고를 올려 \"삶을 공유할\" 수 있는 상대를 찾았다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                },
                {
                    "value": "인문학 잡지 '라팜의 계간지(Lapham's Quarterly)'에 따르면, 당시 맨체스터 시장은 해당 광고를 올렸다는 이유로 헬렌을 4주 동안 정신병원에 입원시켰다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.bbc.com/korean/international-62817038?xtor=AL-73-%5Bpartner%5D-%5Bnaver%5D-%5Bheadline%5D-%5Bkorean%5D-%5Bbizdev%5D-%5Bisapi%5D",
            "search_query": "최초의 데이팅 광고",
            "terminate": false,
            "text": "물론이죠, 1727년으로 거슬러 올라가는데요. 영국 여성 헬렌 모리슨이 맨체스터 위클리 저널에 광고를 올려 삶을 공유할 수 있는 상대를 찾은 것이 그 시작이었죠. 물론, 당시 인문학 잡지 라팜의 계간지에 따르면, 맨체스터 시장은 해당 광고를 올린 헬렌을 4주간 정신병원에 입원시켰어요.",
            "turn_id": "BK22015086-4",
            "utterance_id": "BK22015086.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "헉, 그런 일이 있었군요. 어쩌면 그렇게 느껴졌을 수도 있겠어요. 데이팅 앱에서 범죄를 당하는 경우도 종종 있지 않나요?",
            "turn_id": "BK22015086-5",
            "utterance_id": "BK22015086.9"
        },
        {
            "reference_date": "2022-09-26",
            "reference_text": [
                {
                    "value": "데이팅 앱 중 월간 순이용자(MAU) 수 21.5만명으로 1위로 알려진 '틴더'를 키워드로 최근 3년치 판결문을 모두 분석해봤다(22년 8월 기준).",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                },
                {
                    "value": "범죄 유형은 예상했던 대로 성범죄가 가장 많았다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                },
                {
                    "value": "성관계 장면을 불법촬영한 경우가 18건 중 7건(약 39%)으로 절반 가까이를 차지했다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                },
                {
                    "value": "성폭행 사건은 2건 (약 11%) 발생했다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://lawtalknews.co.kr/article/8BLLDCMNHQZ3",
            "search_query": "데이트앱 범죄",
            "terminate": false,
            "text": "안타깝게도 있죠, 데이팅 앱 중 월간 순 이용자 수 21.5만명으로 1위로 알려진 틴더를 키워드로 최근 3년 치 판결문을 모두 분석해본 결과, 가장 많은 범죄 유형은 성범죄였어요. 성관계 장면을 불법 촬영한 경우가 18건 중 7건인 39퍼센트의 비율로 발생했고, 성폭행 사건의 경우 2건 발생했죠.",
            "turn_id": "BK22015086-5",
            "utterance_id": "BK22015086.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "성범죄라니 정말 끔찍한 일이네요. 혹시 다른 범죄는 없었나요?",
            "turn_id": "BK22015086-6",
            "utterance_id": "BK22015086.11"
        },
        {
            "reference_date": "2022-08-25",
            "reference_text": [
                {
                    "value": "모바일 데이팅 앱을 이용해 여성인 척 행세하며 남성들을 속여 돈을 뜯어낸 신종 사기 조직 일당이 무더기로 징역형을 선고받았다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220825520817?OutUrl=naver",
            "search_query": "데이팅앱 사기",
            "terminate": false,
            "text": "마음 아프지만 있어요, 모바일 데이팅 앱을 이용해서 여자인 척 행세한 신종 사기 조직 일당들이 남성들을 속여서 돈을 뜯어냈다가 징역형을 선고받은 사건이 있었거든요.",
            "turn_id": "BK22015086-6",
            "utterance_id": "BK22015086.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "도대체 어떻게 사기를 친 거예요?",
            "turn_id": "BK22015086-7",
            "utterance_id": "BK22015086.13"
        },
        {
            "reference_date": "2022-08-25",
            "reference_text": [
                {
                    "value": "A씨 등은 2020년 9월부터 올해 초까지 데이팅 앱에서 여성인 것처럼 행세하거나 허위 인적 사항으로 교제 의사가 있는 것처럼 남성들에게 접근해 약 4만1천700여명의 피해자들이 대화에 필요한 포인트 3만4천여개(11억여원 상당)를 구매하도록 한 혐의로 재판에 넘겨졌다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hankyung.com/society/article/2022082572277",
            "search_query": "데이팅앱 사기 혐의",
            "terminate": false,
            "text": "일당 들은 2020년 9월부터 올해 초까지 데이팅 앱에서 여성인 것처럼 행세하거나 허위 인적 사항으로 교제 의사가 있는 것처럼 남성들에게 접근해서 약 4만1천400여명의 피해자가 대화에 필요한 포인트 3만4천여개, 그러니까 11억여원 상당을 구매하도록 했어요.",
            "turn_id": "BK22015086-7",
            "utterance_id": "BK22015086.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "흠, 주로 남자들이 사기의 대상이었네요. 데이팅 앱 남녀 성비의 차이가 큰가요?",
            "turn_id": "BK22015086-8",
            "utterance_id": "BK22015086.15"
        },
        {
            "reference_date": "2022-04-29",
            "reference_text": [
                {
                    "value": "앱 이용자의 성별 비중은 남성이 압도적이었다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                },
                {
                    "value": "상위 10개 앱의 평균 성비는 남성 79.7%, 여성 20.3%로 집계됐다.",
                    "value_time": "2022-10-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.sedaily.com/NewsView/264VPX8Y0P",
            "search_query": "데이팅앱 성비",
            "terminate": false,
            "text": "네, 앱 이용자의 성별 비중은 남성이 압도적이에요. 상위 10개 앱의 평균 성비는 남성이 97.7퍼센트, 여성이 20.3퍼센트로 집계되었거든요.",
            "turn_id": "BK22015086-8",
            "utterance_id": "BK22015086.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "남성 이용자가 압도적으로 많군요. 그럼 이런 데이팅 앱 범죄를 피하기 위해선 어떻게 해야 할까요?",
            "turn_id": "BK22015086-9",
            "utterance_id": "BK22015086.17"
        },
        {
            "reference_date": "2022-07-23",
            "reference_text": [
                {
                    "value": "데이팅앱이 사기와 성범죄 등 범죄 매개체가 되는 사례가 있는 만큼, 투자 권유 등 돈 관련 이야기가 나오면 거의 사기라고 보고 주의해야 한다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                },
                {
                    "value": "피해를 볼 경우 경찰청 사이버범죄신고시스템에 신고하면 된다.",
                    "value_time": "2022-10-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.seoul.co.kr/news/newsView.php?id=20220723500015&wlog_tag3=naver",
            "search_query": "데이팅앱 사기 예방",
            "terminate": false,
            "text": "데이팅 앱이 사기와 성범죄 등과 같은 범죄의 매개체가 되는 사례가 있는 만큼, 투자 권유와 같은 돈 관련 이야기가 나오면 거의 사기라고 보고 주의해야 해요. 피해를 볼 경우 경찰청 사이버 범죄 신고시스템에 신고해야 하고요.",
            "turn_id": "BK22015086-9",
            "utterance_id": "BK22015086.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알려주셔서 감사해요, 데이팅 앱에 대해 더욱 자세히 알 수 있는 좋은 시간이었어요.",
            "turn_id": "BK22015086-10",
            "utterance_id": "BK22015086.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "도움이 되었다니 다행이네요, 그럼 다음에 봬요.",
            "turn_id": "BK22015086-10",
            "utterance_id": "BK22015086.20"
        }
    ]
