    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "반려견은 나이에 따라 사료를 주기적으로 바꿔줘야 해?",
            "turn_id": "BK22016580-1",
            "utterance_id": "BK22016580.1"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "반려견의 삶은 대개 3단계로 나누는데, 이 단계에 따라 급여해야 할 사료가 달라진다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 생애 주기 사료",
            "terminate": false,
            "text": "반려견의 삶을 보통 3단계로 나누는데, 단계에 따라 주기적으로 다른 사료를 줘야 해.",
            "turn_id": "BK22016580-1",
            "utterance_id": "BK22016580.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 태어난 지 얼마 안 되는 어린 강아지에게는 어떤 사료를 먹여야 해?",
            "turn_id": "BK22016580-2",
            "utterance_id": "BK22016580.3"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "태어나서 한 살까지는 면역계와 골격계가 형성되는 시기다.",
                    "value_time": "44841.0",
                    "value_type": "constant"
                },
                {
                    "value": "이때는 필요한 에너지가 많은 만큼 열량이 높은 사료를 급여한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "또 골격을 튼튼하게 만들기 위해 비타민과 무기질 밸런스를 맞추어 주는 것도 중요하다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 태어나서 한 살까지 사료",
            "terminate": false,
            "text": "면역계와 골격계가 형성되는 시기인 태어나서 한 살까지는 필요한 에너지가 많기 때문에 열량이 높은 사료를 주는 게 좋아. 그리고 골격을 튼튼하게 만들려면 비타민과 무기질도 균형 맞춰 줘야 해.",
            "turn_id": "BK22016580-2",
            "utterance_id": "BK22016580.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "반려견이 한 살이 지나면 그 이후에는 사료를 어떻게 바꿔줘야 해?",
            "turn_id": "BK22016580-3",
            "utterance_id": "BK22016580.5"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "체구가 거의 결정된 한 살이 지나면 체중과 피부 관리에 들어간다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "고열량 식단을 중단하고 피부와 털 건강을 위해 단백질과 오메가 지방산도 챙겨야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 한 살 지나면 사료",
            "terminate": false,
            "text": "보통 한 살이 지나면 체구가 결정되기 때문에 체중 관리와 피부 관리를 해야 해. 열량이 높은 사료는 먹이지 말고 피부와 털 건강을 위해 단백질과 오메가 지방산을 챙겨주는 게 좋아.",
            "turn_id": "BK22016580-3",
            "utterance_id": "BK22016580.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "반려견의 노화로 노견이 되면 그렇게 먹이면 안 되지? 노견이 되면 또 어떤 사료를 먹여야 되는 거야?",
            "turn_id": "BK22016580-4",
            "utterance_id": "BK22016580.7"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "노견은 신체 능력과 신진대사가 떨어지고 갖가지 병에 노출된다.",
                    "value_time": "44841.0",
                    "value_type": "constant"
                },
                {
                    "value": "이런 점을 보완하기 위한 시니어 전용 사료가 있다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "노화 관리를 위한 항산화 물질과 소화 흡수율이 높은 고품질의 단백질 등을 함유한 사료로 바꾸어 주어야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 노견 노화 관리 사료",
            "terminate": false,
            "text": "노견은 신체 능력과 신진대사가 떨어져 여러 가지 병에 걸릴 수 있기 때문에 그것을 보완해 주는 시니어 전용 사료가 있어. 노화 관리를 위해 항산화 물질이 있고 소화 흡수율이 높은 고품질 단백질이 들어 있는 사료로 바꿔줘야 해.",
            "turn_id": "BK22016580-4",
            "utterance_id": "BK22016580.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "피부질환이나 알레르기 같은 질병을 앓고 있는 반려견한테는 어떤 사료를 먹여야 좋을까?",
            "turn_id": "BK22016580-5",
            "utterance_id": "BK22016580.9"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "피부 질환이나 알레르기, 심혈관계와 간 질환이 있어도 각각에 알맞은 처방 사료를 급여해야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 질병 처방 사료",
            "terminate": false,
            "text": "피부 질환이나 알레르기, 심혈관계, 간 질환 등 반려견의 질환에 따라 맞는 사료가 있기 때문에 알맞은 처방 사료를 먹여야 해.",
            "turn_id": "BK22016580-5",
            "utterance_id": "BK22016580.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "질병에 걸린 반려견을 위한 처방 사료라면 수의사가 진단해서 처방해주는 거지?",
            "turn_id": "BK22016580-6",
            "utterance_id": "BK22016580.11"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "의사의 정확한 진단이 우선이고, 정해진 기간 동안 꾸준히 먹여야 한다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "증상이 나아졌다고 임의로 중단하면 안 된다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 질병 사료 의사 진단",
            "terminate": false,
            "text": "맞아, 처방 사료는 의사가 정확하게 진단해서 처방한 사료야. 정해진 기간 동안 꾸준하게 줘야 하고 반려견의 증상이 좋아졌다고 해서 임의로 중단하면 안 되는 거 잊지 마.",
            "turn_id": "BK22016580-6",
            "utterance_id": "BK22016580.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 예방 차원에서 미리 처방 사료를 주는 건 어때?",
            "turn_id": "BK22016580-7",
            "utterance_id": "BK22016580.13"
        },
        {
            "reference_date": "44511.0",
            "reference_text": [
                {
                    "value": "예방 차원에서 미리 급여하는 것도 금지다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "영양 불균형 같은 부작용이 생길 수 있어서다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2021/11/1066111/",
            "search_query": "반려견 질병 사료 예방 차원",
            "terminate": false,
            "text": "미리 질병에 관한 처방 사료를 급여하면 영양이 불균형해지는 부작용이 생길 수 있어서 안 돼.",
            "turn_id": "BK22016580-7",
            "utterance_id": "BK22016580.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "신경 써야 할 게 많구나. 우리도 건강을 생각해 유기농 음식을 많이 먹는 데 강아지도 건강을 위해 사료도 유기농으로 주면 좋겠지?",
            "turn_id": "BK22016580-8",
            "utterance_id": "BK22016580.15"
        },
        {
            "reference_date": "44613.0",
            "reference_text": [
                {
                    "value": "강아지 사료는 유기농으로 고르는 것이 좋으나 그 중에서도 유기농 원료 함량을 체크해봐야 한다,",
                    "value_time": "44841.0",
                    "value_type": "variable"
                },
                {
                    "value": "유기농 사료라고 광고하는 제품 중에는 유기농 원료는 극소량만 사용된 경우가 있기 때문이다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://idsn.co.kr/news/view/1065594667844415",
            "search_query": "강아지 사료 유기농 원료 함량",
            "terminate": false,
            "text": "유기농으로 선택하는 게 좋긴 한데 유기농 원료 함량을 잘 확인해야 해. 유기농 사료라고 광고하는 제품 중에 유기농 원료는 아주 조금만 사용된 경우가 있거든.",
            "turn_id": "BK22016580-8",
            "utterance_id": "BK22016580.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "유기농 원료는 몇 퍼센트 이상 사용된 제품이 좋은 거야?",
            "turn_id": "BK22016580-9",
            "utterance_id": "BK22016580.17"
        },
        {
            "reference_date": "44613.0",
            "reference_text": [
                {
                    "value": "현재 시중에는 90% 이상의 유기농 원료가 사용된 제품이 있어 가급적 이러한 제품을 선택하는 것이 좋다.",
                    "value_time": "44841.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://idsn.co.kr/news/view/1065594667844415",
            "search_query": "유기농 원료 90",
            "terminate": false,
            "text": "시중에 유기농 원료가 90퍼센트가 넘게 사용된 제품이 있거든. 가능한 한 그런 제품을 선택하는 게 좋지.",
            "turn_id": "BK22016580-9",
            "utterance_id": "BK22016580.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오늘 사러 가봐야겠다. 자세하게 설명해 준 덕분에 궁금증이 다 해결됐어.",
            "turn_id": "BK22016580-10",
            "utterance_id": "BK22016580.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "다행이다, 더 궁금한 게 있다면 언제든 연락해.",
            "turn_id": "BK22016580-10",
            "utterance_id": "BK22016580.20"
        }
    ]
}