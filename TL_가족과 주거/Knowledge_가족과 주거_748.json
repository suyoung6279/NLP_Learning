    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "반려동물을 키우기가 쉽지 않아. 생활비를 줄여서 먹이와 용품들을 사고 있는데 아플 때 병원은 또 어떻게 가야 할지 막막해.",
            "turn_id": "BK22016515-1",
            "utterance_id": "BK22016515.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "병원이 걱정이라면 우리동네 동물병원에 가봐.",
            "turn_id": "BK22016515-1",
            "utterance_id": "BK22016515.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리동네 동물병원은 어떤 사업이야?",
            "turn_id": "BK22016515-2",
            "utterance_id": "BK22016515.3"
        },
        {
            "reference_date": "44634.0",
            "reference_text": [
                {
                    "value": "서울시 우리동네 동물병원 사업은 취약계층 반려동물을 대상으로 기초 건강검진, 필수 예방접종, 심장사상충 예방약 같은 필수진료를 지원하는 사업이다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/article/all/20220313/112312171/1",
            "search_query": "우리동네 동물병원",
            "terminate": false,
            "text": "서울시에서 진행하는 우리동네 동물병원은 취약계층의 반려동물을 상대로 기초 건강검진, 필수 예방접종, 심장사상충 예방약 같은 필수진료를 돕는 사업이야.",
            "turn_id": "BK22016515-2",
            "utterance_id": "BK22016515.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "신청자 조건은 어떻게 돼?",
            "turn_id": "BK22016515-3",
            "utterance_id": "BK22016515.5"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "우리동네동물병원 진료지원은 기초생활수급자와 차상위계층이 받을 수 있다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 진료지원",
            "terminate": false,
            "text": "기초생활수급자와 차상위계층이 우리동네동물병원 진료 지원을 받을 수 있어.",
            "turn_id": "BK22016515-3",
            "utterance_id": "BK22016515.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "기초생활수급자니까 신청할 수 있겠다. 우리동네 동물병원을 이용하려면 반려견의 조건은 어떻게 돼?",
            "turn_id": "BK22016515-4",
            "utterance_id": "BK22016515.7"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "반려견은 동물등록이 필수다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                },
                {
                    "value": "미등록 개는 동물등록 후 지원을 받을 수 있으며, 서울시 ‘내장형 동물등록칩’사업을 이용하면 1만원에 등록이 가능하다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 동물등록",
            "terminate": false,
            "text": "키우는 개가 반드시 동물등록이 되어 있어야 해. 등록하지 않은 개라면 동물등록 후 지원을 받을 수 있는데, 서울시 내장형 동물등록칩사업을 통해 1만 원에 등록할 수 있어.",
            "turn_id": "BK22016515-4",
            "utterance_id": "BK22016515.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇다면 병원에서 지원받을 수 있는 범위가 어느 정도 인지 알려줄 수 있어?",
            "turn_id": "BK22016515-5",
            "utterance_id": "BK22016515.9"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "진료는 기초 건강검진을 비롯한 필수예방접종, 심장사상충 예방약 등 필수진료와 건강검진에서 발견한 질병치료, 중성화수술 등 선택진료에 대한 지원을 받을 수 있다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 진료",
            "terminate": false,
            "text": "응, 기초 건강검진은 물론 필수예방접종, 심장사상충 예방약 등의 필수진료와 건강검진 시 발견한 질병 치료, 중성화수술 등 선택진료에 대한 지원을 받을 수 있어.",
            "turn_id": "BK22016515-5",
            "utterance_id": "BK22016515.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "비용에 상관없이 받을 수 있는 거야?",
            "turn_id": "BK22016515-6",
            "utterance_id": "BK22016515.11"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "보호자는 필수 진료의 경우 1회당 5000원(최대 1만원), 선택진료는 20만원을 초과하는 부담금만 지불하면 된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 지원금액",
            "terminate": false,
            "text": "필수 진료는 1회당 5,000원 최대 1만 원, 선택진료는 20만 원을 초과하는 금액만 부담하면 돼.",
            "turn_id": "BK22016515-6",
            "utterance_id": "BK22016515.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리 집 반려견은 2마리인데, 반려동물은 몇 마리까지 지원 가능해?",
            "turn_id": "BK22016515-7",
            "utterance_id": "BK22016515.13"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "가구당 동물 1마리에서 2마리로 지원 범위도 확대했다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 가구당 지원동물수",
            "terminate": false,
            "text": "원래는 가구당 동물 1마리로 규정하고 있었지만, 지원 범위를 2마리로 늘렸어.",
            "turn_id": "BK22016515-7",
            "utterance_id": "BK22016515.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리동네동물병원은 어디 있는지 어떻게 알 수 있어?",
            "turn_id": "BK22016515-8",
            "utterance_id": "BK22016515.15"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "동물병원 정보는 동물복지지원센터 홈페이지와 120다산콜센터를 통해 확인할 수 있다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 신청",
            "terminate": false,
            "text": "동물복지지원센터 홈페이지와 120다산콜센터를 통해 동물병원 정보를 알 수 있어.",
            "turn_id": "BK22016515-8",
            "utterance_id": "BK22016515.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리동네 동물병원 이용 시 가져가야 할 서류가 있을까?",
            "turn_id": "BK22016515-9",
            "utterance_id": "BK22016515.17"
        },
        {
            "reference_date": "44635.0",
            "reference_text": [
                {
                    "value": "동물의료 지원을 받기 위해서는 수급자증명서 또는 차상위계층 확인서(3개월 이내 발급)를 가지고 동물병원에 방문해 제시하면 된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220314518289?OutUrl=naver",
            "search_query": "우리동네 동물병원 신청서류",
            "terminate": false,
            "text": "동물병원에 방문할 때는 수급자증명서 또는 3개월 이내로 발급한 차상위계층 확인서를 보여줘야 해.",
            "turn_id": "BK22016515-9",
            "utterance_id": "BK22016515.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "너무 좋은 제도야. 반려동물이 아플 때 죄책감이 있었는데 빨리 병원에 갈 수 있겠다.",
            "turn_id": "BK22016515-10",
            "utterance_id": "BK22016515.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "반려동물과 함께 건강한 삶을 살 수 있도록 하는 이런 정책들은 정말 칭찬할만해.",
            "turn_id": "BK22016515-10",
            "utterance_id": "BK22016515.20"
        }
    ]
}