            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래, 반려조를 입양하면 새에 대한 정보들을 공부하면서 관심을 계속 주는 것이 중요하지.",
            "turn_id": "BK22015278-9",
