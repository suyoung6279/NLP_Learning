    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지도 나이가 들면 심장병이 생길 위험이 있을까?",
            "turn_id": "BK22012722-1",
            "utterance_id": "BK22012722.1"
        },
        {
            "reference_date": "44630.0",
            "reference_text": [
                {
                    "value": "반려견은 대체로 6~7살이 되면서부터 노화가 시작되고, 노화로 인해 발병하는 여러 가지 노령건 질환 중 가장 흔한 질환을 하나 꼽으라면 강아지 심장병이라 불리는 이첨판폐쇄부전증을 꼽을 수 있다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mdtoday.co.kr/news/view/1065607789740469",
            "search_query": "반려견 심장병",
            "terminate": false,
            "text": "응. 보통 강아지의 노화는 6살이나 7살 사이에 시작되는데, 그로 인해 생기는 질병 중 이첨판폐쇄부전증이라는 심장병이 제일 흔하게 발생해.",
            "turn_id": "BK22012722-1",
            "utterance_id": "BK22012722.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "심장병이 생기게 되면 어떤 증상이 나타나게 돼?",
            "turn_id": "BK22012722-2",
            "utterance_id": "BK22012722.3"
        },
        {
            "reference_date": "44710.0",
            "reference_text": [
                {
                    "value": "심장병이 발병한 강아지는 기력 상실이나 운동 기피 식욕 부진 기침과 호흡 곤란 같은 증상이 발견되고 심하면 졸도하는 일이 생길 수 있으므로 발병 초기에 치료와 관리가 필요하다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.kookje.co.kr/news2011/asp/newsbody.asp?code=0700&key=20220530.22018007475",
            "search_query": "강아지 심장병 증상",
            "terminate": false,
            "text": "강아지가 심장병이 생기면 운동을 피하거나 식욕이 떨어지고, 기력 상실, 기침 및 숨쉬기 힘든 증상들이 나타나는데, 증상이 심하면 기절할 수도 있기 때문에 되도록 빨리 치료를 받는 게 중요해.",
            "turn_id": "BK22012722-2",
            "utterance_id": "BK22012722.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "감기에 걸려서 기침할 수도 있지 않아?",
            "turn_id": "BK22012722-3",
            "utterance_id": "BK22012722.5"
        },
        {
            "reference_date": "42935.0",
            "reference_text": [
                {
                    "value": "강아지가 기침할 때 단순한 감기나 기관지염일 수도 있지만, 나이가 든 강아지들이 기침하는 경우에는 심장질환이 가장 흔하다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                },
                {
                    "value": "판막질환이나 심장비대증으로 폐에 물이 차거나 커진 심장이 기관이나 기관지를 압박하여 기침이 나기 때문이다.",
                    "value_time": "44799.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hani.co.kr/arti/society/environment/803083.html",
            "search_query": "강아지 기침 심장질환",
            "terminate": false,
            "text": "단순히 기관지염이나 감기로 인해서 기침을 할 수 있지만, 노령견이 기침할 때는 심장질환이 원인인 경우가 많아. 판막 질병이나 심장이 커져서 폐에 물이 차거나 비대해진 심장이 기관지나 기관을 누르면 기침이 발생하거든.",
            "turn_id": "BK22012722-3",
            "utterance_id": "BK22012722.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "노견이 기침하면 병원에 데려가야겠구나. 혹시 어떤 강아지들이 심장병이 생기기 쉬워?",
            "turn_id": "BK22012722-4",
            "utterance_id": "BK22012722.7"
        },
        {
            "reference_date": "44214.0",
            "reference_text": [
                {
                    "value": "심장병은 시추, 몰티즈, 치와와, 포메라니안 등 소형견과 노령견에서 발생 가능성이 높다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.news1.kr/articles/?4170651",
            "search_query": "심장병 소형견",
            "terminate": false,
            "text": "나이가 많은 강아지나 치와와, 몰티즈, 포메라니안 및 시추 등과 같은 소형견에게서 심장병이 생길 확률이 높아.",
            "turn_id": "BK22012722-4",
            "utterance_id": "BK22012722.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "소형견을 키운다면 심장병에 대해서 더욱 신경을 써야겠구나?",
            "turn_id": "BK22012722-5",
            "utterance_id": "BK22012722.9"
        },
        {
            "reference_date": "44785.0",
            "reference_text": [
                {
                    "value": "특히 소형견의 경우, 심장병을 가진 상태로 태어나거나 후천적인 심장병을 얻을 확률이 더 높기 때문에 호흡이 이상하거나 기침이 잦다면 반드시 동물병원에 내원하자.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.healthinnews.co.kr/news/articleView.html?idxno=31790",
            "search_query": "소형견 심장병 내원",
            "terminate": false,
            "text": "응. 소형견은 선천적으로 심장병을 갖고 태어나거나 후천적으로 심장병이 생길 가능성이 유독 높아. 그렇기 때문에 기침을 자주 하거나 숨을 이상하게 쉰다면 동물 병원에 꼭 데려가야 해.",
            "turn_id": "BK22012722-5",
            "utterance_id": "BK22012722.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 이미 심장병이 있는 강아지들은 건강이 위험한 거야?",
            "turn_id": "BK22012722-6",
            "utterance_id": "BK22012722.11"
        },
        {
            "reference_date": "43767.0",
            "reference_text": [
                {
                    "value": "반려동물의 심장병 유병률은 높은 편이지만 모두 위험한 상태에 놓이는 건 아니다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                },
                {
                    "value": "초기로 진단받더라도 더 이상 진행되지 않는 경우가 30∼40%에 이른다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/Culture/article/all/20191028/98107700/1",
            "search_query": "반려동물 심장병 초기",
            "terminate": false,
            "text": "심장병이 생기는 반려동물 수는 많지만 그렇다고 해서 다 건강이 위험해지는 건 아니야. 심장병 초기여도 30퍼센트에서 40퍼센트 정도는 병세가 더 나빠지지 않거든.",
            "turn_id": "BK22012722-6",
            "utterance_id": "BK22012722.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 이미 심장이 커진 애들을 위해서 어떻게 관리해 주면 좋을까?",
            "turn_id": "BK22012722-7",
            "utterance_id": "BK22012722.13"
        },
        {
            "reference_date": "43767.0",
            "reference_text": [
                {
                    "value": "하지만 심장이 비대해지고 증상이 나타나는 경우에는 반려동물이 민감해지는 경우가 많으므로 세심한 돌봄이 필요하다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                },
                {
                    "value": "반드시 저염 사료를 급여해야 하며, 지속적인 투약과 내원 스트레스를 줄이기 위해 노력해야 한다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/Culture/article/all/20191028/98107700/1",
            "search_query": "반려동물 심장비대 돌봄",
            "terminate": false,
            "text": "심장이 커지고 이미 증상이 나타났다면 반려동물이 예민해지기 때문에 섬세하게 돌봐줘야 해. 또한 꾸준히 약을 먹이고, 염분이 적은 사료를 먹어야 할뿐더러 병원에 데려갈 때 스트레스를 덜 받도록 노력해 줘야 해.",
            "turn_id": "BK22012722-7",
            "utterance_id": "BK22012722.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지가 나이 들어가는 걸 보는 게 너무 마음이 아파.",
            "turn_id": "BK22012722-8",
            "utterance_id": "BK22012722.15"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래도 강아지와 함께하는 매 순간을 행복하게 보내면 강아지도 좋아할 거야.",
            "turn_id": "BK22012722-8",
            "utterance_id": "BK22012722.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇겠지? 그런데 사람이 먹는 건강한 음식을 강아지에게 줘도 될까?",
            "turn_id": "BK22012722-9",
            "utterance_id": "BK22012722.17"
        },
        {
            "reference_date": "44685.0",
            "reference_text": [
                {
                    "value": "사람이 먹는 건강식이라도 강아지에겐 악영향을 미칠 수 있다.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                },
                {
                    "value": "반드시 급여 전 위해성을 확인하자.",
                    "value_time": "44799.0",
                    "value_type": "variable"
                },
                {
                    "value": "간식 급여량이 너무 많을 경우 사료 섭취가 줄고, 이는 영양 불균형을 초래한다.",
                    "value_time": "44799.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1395081/",
            "search_query": "강아지 사람 건강식",
            "terminate": false,
            "text": "아무리 사람한테 건강한 음식이라도 강아지에게 나쁜 영향을 초래할 수 있으니까 무조건 강아지에게 음식을 주기 전에 위험한 성질이 없는지 확인해야 해. 또한 간식을 너무 많이 주게 되면 강아지가 사료를 덜 먹게 돼서 영양의 균형이 깨지게 돼.",
            "turn_id": "BK22012722-9",
            "utterance_id": "BK22012722.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "하긴. 아무래도 강아지는 강아지 음식 먹는 게 가장 좋겠지?",
            "turn_id": "BK22012722-10",
            "utterance_id": "BK22012722.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "괜히 사람 음식 먹여서 탈 날 수 있으니까 강아지 전용 간식을 주도록 해.",
            "turn_id": "BK22012722-10",
            "utterance_id": "BK22012722.20"
        }
    ]
}