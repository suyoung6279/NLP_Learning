    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 주변에 다문화 가정인 친구 있어?",
            "turn_id": "BK22001374-1",
            "utterance_id": "BK22001374.1"
        },
        {
            "reference_date": "2022-06-01",
            "reference_text": [
                {
                    "value": "현재 우리나라의 국제결혼 비율은 전체 혼인 건수 중 약 10% 정도를 차지한다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                },
                {
                    "value": "그만큼 다문화가정이 많아졌다는 것이다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.dailypop.kr/news/articleView.html?idxno=60353",
            "search_query": "다문화가정 비율",
            "terminate": false,
            "text": "응, 주변에 꽤 있어. 우리나라 전체 혼인 건수 중에 국제 결혼이 약 10퍼센트정도 차지할 만큼 다문화 가정은 꽤 쉽게 볼 수 있어.",
            "turn_id": "BK22001374-1",
            "utterance_id": "BK22001374.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "내 주변에도 다문화 가정 친구가 있는데, 자녀 교육에 관해 걱정이 많더라고.",
            "turn_id": "BK22001374-2",
            "utterance_id": "BK22001374.3"
        },
        {
            "reference_date": "2022-06-27",
            "reference_text": [
                {
                    "value": "그 결과, 다문화 청소년들은 교육격차 등의 이유로 제대로 된 학습에 어려움을 겪는 것을 확인했다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://edu.chosun.com/site/data/html_dir/2022/06/27/2022062701353.html",
            "search_query": "다문화 교육격차",
            "terminate": false,
            "text": "그렇구나, 교육격차 등의 이유로 다문화 청소년들이 제대로 된 학습에 어려움을 겪기도 해.",
            "turn_id": "BK22001374-2",
            "utterance_id": "BK22001374.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "심지어 다문화 가정이라는 게 취업에도 불리하게 작용하기도 한다며.",
            "turn_id": "BK22001374-3",
            "utterance_id": "BK22001374.5"
        },
        {
            "reference_date": "2021-07-20",
            "reference_text": [
                {
                    "value": "이는 노동시장 취업에 불리하게 작용하여 다문화가족 청소년은 취업률도 낮고 일용근로자 등 저임금노동에 종사하는 비율이 높다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.newdaily.co.kr/site/data/html/2021/07/19/2021071900197.html",
            "search_query": "다문화 취업",
            "terminate": false,
            "text": "응, 다문화 가족 청소년들은 취업률도 낮고 저임금노동 분야에 종사하는 비율이 높아.",
            "turn_id": "BK22001374-3",
            "utterance_id": "BK22001374.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다문화 가정이라면 정말 고민이 많겠다.",
            "turn_id": "BK22001374-4",
            "utterance_id": "BK22001374.7"
        },
        {
            "reference_date": "2022-06-27",
            "reference_text": [
                {
                    "value": "만 6세 이상 자녀를 둔 결혼이주여성 등 귀화자 중 “자녀 양육이 어렵다”고 응답한 비율은 88.1%에 달했다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                },
                {
                    "value": "자녀 양육에 있어서 가장 어려움을 느끼는 부분은 ‘학습지도·학업관리 어려움(50.4%)’였다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/article/all/20220627/114165201/1",
            "search_query": "다문화가정 학습",
            "terminate": false,
            "text": "실제로 만 6세 이상 자녀가 있는 다문화 가정 중 약 88퍼센트 이상이 자녀 양육에 어려움을 겪고 있고, 그 중에서도 학습지도와 학업 관리의 어려움이 있다고 한 사람이 절반이 넘어.",
            "turn_id": "BK22001374-4",
            "utterance_id": "BK22001374.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다들 비슷한 고민을 하고 있구나. 학교 내에 다문화 가정 차별 문제는 괜찮아?",
            "turn_id": "BK22001374-5",
            "utterance_id": "BK22001374.9"
        },
        {
            "reference_date": "2022-06-30",
            "reference_text": [
                {
                    "value": "다행인지 다문화가족 자녀가 학교폭력과 차별을 당한 경험은 점차 감소하는 추세로 나타났다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.idomin.com/news/articleView.html?idxno=797913",
            "search_query": "다문화가정 차별",
            "terminate": false,
            "text": "다행히도 다문화 가족 자녀가 학교 폭력이나 차별을 당하는 일은 줄어들고 있어.",
            "turn_id": "BK22001374-5",
            "utterance_id": "BK22001374.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그건 다행이다. 다문화 가정을 위한 복지도 많이 생기고, 인식도 더 개선되었으면 좋겠어.",
            "turn_id": "BK22001374-6",
            "utterance_id": "BK22001374.11"
        },
        {
            "reference_date": "2022-06-29",
            "reference_text": [
                {
                    "value": "다양한 방식으로 정책을 추진해 나가고 있는데, 다문화 학생의 특성을 고려한 '선제적 맞춤 교육', 다문화 수용성 제고를 위한 '다문화 이해 교육' 확대, 현장 밀착 지원을 위한 '지역 유관 기관' 연계 강화 등이 해당한다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20220629010006658",
            "search_query": "다문화 가정 정책",
            "terminate": false,
            "text": "현재 다문화 가정을 위한 다양한 정책이 추진되고 있어. 다문화 학생의 특성을 고려한 선제적 맞춤 교육, 다문화 수용성 제고를 위한 다문화 이해 교육 확대, 현장 밀착 지원을 위한 지역 유관 기관 연계 강화 등이 실시되기도 해.",
            "turn_id": "BK22001374-6",
            "utterance_id": "BK22001374.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "문제를 해결하기 위한 정책이 많이 실시되고 있구나.",
            "turn_id": "BK22001374-7",
            "utterance_id": "BK22001374.13"
        },
        {
            "reference_date": "2018-07-07",
            "reference_text": [
                {
                    "value": "다문화가족지원센터에서는 다문화 가정 자녀들을 위한 심리상담과 진로교육, 봉사활동 및 체험활동 프로그램을 진행하고 있다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/201806290928081660",
            "search_query": "다문화가족지원센터",
            "terminate": false,
            "text": "응 다문화가족지원센터라는 곳에서는 다문화 가정 자녀들을 위해서 심리상담, 진로교육, 봉사활동 및 체험활동 등 다양한 프로그램을 실시하고 있어.",
            "turn_id": "BK22001374-7",
            "utterance_id": "BK22001374.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오, 혹시 그런 정보를 확인할 수 있는 사이트가 있을까?",
            "turn_id": "BK22001374-8",
            "utterance_id": "BK22001374.15"
        },
        {
            "reference_date": "2015-11-10",
            "reference_text": [
                {
                    "value": "‘다누리’는 한국생활에 필요한 생활정보, 결혼이민자 주요 출신국 문화소개, 온라인 상담, 다문화가족정보매거진 및 다문화가족지원센터 소식 등을10개 언어로 제공하는 웹서비스다.",
                    "value_time": "2022-07-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.kyeonggi.com/1072506",
            "search_query": "다누리",
            "terminate": false,
            "text": "다누리라고 다문화 가정을 위한 웹서비스가 있어. 한국생활에 필요한 정보나, 온라인 상담, 다문화가족지원센터 소식을 10개의 언어로 제공하는 곳이니까 들어가 보면 좋을 거야.",
            "turn_id": "BK22001374-8",
            "utterance_id": "BK22001374.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다문화 가정을 위한 사이트가 있구나. 친구한테도 소개해 줘야겠다.",
            "turn_id": "BK22001374-9",
            "utterance_id": "BK22001374.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "응, 사이트에 들어가서 좋은 정보 많이 얻어가시라고 해.",
            "turn_id": "BK22001374-9",
            "utterance_id": "BK22001374.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고마워, 덕분에 좋은 정보 많이 알아간다.",
            "turn_id": "BK22001374-10",
            "utterance_id": "BK22001374.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "별 거 아닌데 뭘. 또 도움이 필요하면 언제든지 연락해.",
            "turn_id": "BK22001374-10",
            "utterance_id": "BK22001374.20"
        }
    ]
}