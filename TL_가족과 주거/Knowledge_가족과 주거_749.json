    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지 산책하러 갔다가 맹견으로 보이는 개가 우리 강아지를 물려고 해서 놀랐어. 다행히 피해서 다치지 않았지만 말이야.",
            "turn_id": "BK22016516-1",
            "utterance_id": "BK22016516.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "무서웠겠다 맹견 허가제가 빨리 시행되어야 할 텐데.",
            "turn_id": "BK22016516-1",
            "utterance_id": "BK22016516.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맹견 허가제는 언제부터 시행되는데?",
            "turn_id": "BK22016516-2",
            "utterance_id": "BK22016516.3"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "2024년 4월 27일부터는 맹견을 수입하거나 키우려면 시·도지사의 허가를 받아야 한다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "맹견 허가제",
            "terminate": false,
            "text": "맹견을 수입하거나 키우고 싶으면 2024년 4월 27일부터 시도지사의 허가를 받아야 해.",
            "turn_id": "BK22016516-2",
            "utterance_id": "BK22016516.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맹견허가제의 시행 배경은 역시 개 물림 사고 때문일까?",
            "turn_id": "BK22016516-3",
            "utterance_id": "BK22016516.5"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "맹견 허가제는 견주들의 관리 소홀로 치명적인 개물림 사고가 발생하는 것을 막기 위해서다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                },
                {
                    "value": "지난해 개물림 사고는 2197건이었다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "맹견 개물림 사고",
            "terminate": false,
            "text": "맞아. 작년에 개물림 사고가 2,197건이었어. 맹견을 키우는 사람들의 소홀한 관리로 치명적인 개물림 사고가 발생하는 것을 막기 위해서 맹견 허가제가 생겼지.",
            "turn_id": "BK22016516-3",
            "utterance_id": "BK22016516.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "생각보다 개물림 사고가 잦았구나. 맹견으로 분류되는 종들은 어떤 게 있어?",
            "turn_id": "BK22016516-4",
            "utterance_id": "BK22016516.7"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "현행법상 맹견은 도사견, 아메리칸 핏불테리어, 아메리칸 스태퍼드셔 테리어, 스태퍼드셔 불테리어, 로트바일러 등 5종이다.",
                    "value_time": "44839.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "현행법상 맹견",
            "terminate": false,
            "text": "현행법상 맹견은 도사견, 아메리칸 핏불테리어, 아메리칸 스태퍼드셔 테리어, 스태퍼드셔 불테리어, 로트바일러 등 5종류야.",
            "turn_id": "BK22016516-4",
            "utterance_id": "BK22016516.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맹견이 아니어도 사나운 개가 있을 수도 있잖아. 그런 개들은 어떻게 관리 돼?",
            "turn_id": "BK22016516-5",
            "utterance_id": "BK22016516.9"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "맹견에 해당하지 않더라도 사람이나 동물을 공격한 개는 시 ·도지사가 맹견으로 지정할 수 있다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                },
                {
                    "value": "맹견으로 지정되면 사육 허가를 받아야 한다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "맹견 사육허가",
            "terminate": false,
            "text": "맹견에 포함되지 않는 경우엔 시도지사가 맹견으로 지정할 수 있어. 사람 또는 동물을 공격한 개가 이에 해당하는데 개가 맹견으로 결정되면 사육 허가를 받아야 해.",
            "turn_id": "BK22016516-5",
            "utterance_id": "BK22016516.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맹견을 키우는 걸 허가받은 견주들이 필수로 해야 하는 건 뭐야?",
            "turn_id": "BK22016516-6",
            "utterance_id": "BK22016516.11"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "개물림 사고에 대비해 배상을 지원하는 책임보험에도 가입해야 한다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "개물림 사고 책임보험",
            "terminate": false,
            "text": "책임보험에 꼭 가입해야 해. 개 물림 사고에 대비해 배상을 지원해줘.",
            "turn_id": "BK22016516-6",
            "utterance_id": "BK22016516.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "책임보험이 있었구나. 맹견을 키우는 사람이 가입하지 않으면 어떻게 돼?",
            "turn_id": "BK22016516-7",
            "utterance_id": "BK22016516.13"
        },
        {
            "reference_date": "43845.0",
            "reference_text": [
                {
                    "value": "맹견 소유자가 내년부터 책임보험 가입 의무를 어기면 300만원 이하의 과태료가 부과된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://go.seoul.co.kr/news/newsView.php?id=20200115012023&wlog_tag3=naver",
            "search_query": "맹견 등록",
            "terminate": false,
            "text": "맹견을 키우는 사람이 책임보험 가입 의무를 지키지 않으면 300만 원 이하의 과태료를 부과해.",
            "turn_id": "BK22016516-7",
            "utterance_id": "BK22016516.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "허가받은 맹견이 집에서 새끼를 낳으면 분양할 수도 있지 않아?",
            "turn_id": "BK22016516-8",
            "utterance_id": "BK22016516.15"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "맹견이 정부 관리를 벗어나 가정에서 번식해 분양하지 못하도록 중성화 수술이 의무화된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "맹견 정부관리",
            "terminate": false,
            "text": "집에서 새끼를 낳아 분양할 수 없어. 맹견은 정부의 관리를 벗어나면 안 되기 때문에 중성화 수술이 의무화돼.",
            "turn_id": "BK22016516-8",
            "utterance_id": "BK22016516.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "번식도 안 되는구나. 이미 키우고 있는 사람들이라면 어떻게 해?",
            "turn_id": "BK22016516-9",
            "utterance_id": "BK22016516.17"
        },
        {
            "reference_date": "44783.0",
            "reference_text": [
                {
                    "value": "현재 맹견을 키우는 견주는 이 제도 시행 후 6개월 이내에 사육 허가를 받아야 한다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                },
                {
                    "value": "위반 시 1년 이하 징역 또는 1000만원 이하의 벌금을 물게 된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.chosun.com/economy/economy_general/2022/08/10/AHVAK6JZENDH7PRTQAHQ7RWTUM/?utm_source=naver&utm_medium=referral&utm_campaign=naver-news",
            "search_query": "맹견 사육허가 위반시 벌금",
            "terminate": false,
            "text": "맹견을 기르는 사람은 맹견 허가제 시행 후 6개월 이내에 사육 허가를 받아야 해. 이를 어기면 1년 이하 징역 또는 1,000만 원 이하의 벌금을 내야 해.",
            "turn_id": "BK22016516-9",
            "utterance_id": "BK22016516.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맹견제도를 통해서 강아지나 사람 모두 개물림 사고 없이 안심하고 다닐 수 있었으면 좋겠다.",
            "turn_id": "BK22016516-10",
            "utterance_id": "BK22016516.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "그러게 잘 관리되어서 효과가 있었으면 해.",
            "turn_id": "BK22016516-10",
            "utterance_id": "BK22016516.20"
        }
    ]
