    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아이를 출산하고 나니 산후우울증이 생긴 것 같아요. 산후우울증은 모든 산모가 겪는 건가요?",
            "turn_id": "BK22009162-1",
            "utterance_id": "BK22009162.1"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "산후우울증은 산모의 약 10~20%에서 발생한다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증",
            "terminate": false,
            "text": "출산 한 산모 중 약 10%에서 20%가 산후우울증을 겪고 있어요.",
            "turn_id": "BK22009162-1",
            "utterance_id": "BK22009162.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다들 겪는 건 아닌 거네요. 산후우울증이 우울한 것 이외에 다른 증상도 있나요?",
            "turn_id": "BK22009162-2",
            "utterance_id": "BK22009162.3"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "우울한 기분과 불안감, 과도한 체중변화나 의욕 저하 등을 경험하며 심할 경우 극단적 선택까지 고민할 정도로 악화된다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증 증상",
            "terminate": false,
            "text": "우울감 이외에 불안감이나 과도한 체중 변화, 의욕 저하와 같은 기분을 느끼게 되고 심하면 극단적인 선택까지 고민할 정도로 악화될 수 있어요.",
            "turn_id": "BK22009162-2",
            "utterance_id": "BK22009162.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "꽤 심각한 증상들도 있네요. 이 산후 우울증은 보통 언제쯤 없어지게 되나요?",
            "turn_id": "BK22009162-3",
            "utterance_id": "BK22009162.5"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "출산 후 첫 10일 이후부터 증상이 나타나며 길면 1년까지 지속될 수 있어 주의가 요구된다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증 증상",
            "terminate": false,
            "text": "일반적으로 출산을 한 후 10일 이후부터 산후우울증 증상이 나타나는데 1년까지도 길어질 수 있으니 주의해야 해요.",
            "turn_id": "BK22009162-3",
            "utterance_id": "BK22009162.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "1년이나 갈 수 있다니 절망적이에요. 아이를 낳아서 너무 행복한데 산후 우울증이 왜 온 걸까요?",
            "turn_id": "BK22009162-4",
            "utterance_id": "BK22009162.7"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "임신을 하면 여성 호르몬인 에스트로겐과 프로게스테론 분비량이 크게 늘어난다.",
                    "value_time": "2022-09-21",
                    "value_type": "constant"
                },
                {
                    "value": "출산 이후 48시간 내에 에스트로겐과 프로게스테론이 90% 이상 감소하면서 임신 전과 비슷한 수치로 돌아간다.",
                    "value_time": "2022-09-21",
                    "value_type": "constant"
                },
                {
                    "value": "이런 호르몬의 급격한 변화는 뇌에 있는 기분과 감정을 조절하는 세로토닌 신경 전달 체계에 영향을 미쳐 산후우울증을 유발하는 원인이 된다는 게 의료계의 설명이다.",
                    "value_time": "2022-09-21",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증 호르몬 변화",
            "terminate": false,
            "text": "임신 시에는 에스트로겐과 프로게스테론과 같은 여성 호르몬 분비량이 늘어나게 돼요. 출산하고 이틀 이내에 이 두 가지 호르몬이 90% 이상 줄어들면서 임신 전 수치와 비슷하게 돌아가게 되는데요. 이처럼 호르몬이 급격하게 변화하면 뇌의 감정조절을 맡고 있는 세로토닌 신경 전달 체계에 영향을 끼치게 되고 그래서 산후우울증이 발생한답니다.",
            "turn_id": "BK22009162-4",
            "utterance_id": "BK22009162.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "호르몬 때문에 기분도 오락가락 했던 거네요. 그럼 호르몬 이외에 다른 원인도 있을까요?",
            "turn_id": "BK22009162-5",
            "utterance_id": "BK22009162.9"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "심리·사회적인 요인도 산후우울증을 유발하기도 한다.",
                    "value_time": "2022-09-21",
                    "value_type": "constant"
                },
                {
                    "value": "임신과 출산 후 신체 변화와 출산에 대한 걱정, 양육에 대한 부담감 등 심리적인 요인이 그 원인이다.",
                    "value_time": "2022-09-21",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증 심리요인",
            "terminate": false,
            "text": "심리적, 사회적 요인 때문에 산후우울증이 나타나기도 해요. 임신과 출산하며 겪는 신체 변화나 출산과 관련된 걱정, 양육 부담과 같은 심리적 요인이 산후우울증의 요인으로 손꼽힌답니다.",
            "turn_id": "BK22009162-5",
            "utterance_id": "BK22009162.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아 그럴수도 있겠네요. 그런데 남편도 저처럼 우울한 증상이 있다는데 남편도 산후우울증이 생길 수 있나요?",
            "turn_id": "BK22009162-6",
            "utterance_id": "BK22009162.11"
        },
        {
            "reference_date": "2022-07-11",
            "reference_text": [
                {
                    "value": "부부의 최대 3% 이상은 산전·산후 우울증을 함께 겪는다는 중요한 연구 결과가 나왔다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                },
                {
                    "value": "출산 전후의 부부를 돌보는 보건의료 요원들은 부부가 모두 동시에 산전, 산후 우울증을 겪을 수 있다는 사실을 알아 두어야 한다고 연구팀은 권고했다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kizmom.hankyung.com/news/view.html?aid=202207119994o",
            "search_query": "산후우울증 남편",
            "terminate": false,
            "text": "엄마뿐 아니라 아빠도 산전, 산후우울증을 겪을 수 있어요. 연구 결과에 따르면 부부의 최대 3퍼센트 이상의 부부가 산전, 산후 우울증을 같이 겪는 것으로 나타났어요.",
            "turn_id": "BK22009162-6",
            "utterance_id": "BK22009162.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "남편도 같은 기분을 느낄 수 있다니 신기해요. 그런데 산후우울증을 치료하려면 어떻게 해야 할까요?",
            "turn_id": "BK22009162-7",
            "utterance_id": "BK22009162.13"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "호전되지 않을 경우 약물 치료와 상담 정신 치료가 필요하다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                },
                {
                    "value": "수유 기간에는 약물 사용이 자제되며 증상이 심할 경우에만 약물이나 정신 치료를 받아아 한다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증 병원",
            "terminate": false,
            "text": "산후우울증이 좋아지지 않는다면 약물 치료 및 상담 정신 치료를 받는 게 좋아요. 수유기간에는 되도록 약물 사용은 하지 않고, 심한 경우에만 약물 및 정신 치료를 받으면 돼요.",
            "turn_id": "BK22009162-7",
            "utterance_id": "BK22009162.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇군요. 그런데 상담 치료를 받는다는 것이 좀 꺼려지기도 하는데 다른 방법은 없을까요?",
            "turn_id": "BK22009162-8",
            "utterance_id": "BK22009162.15"
        },
        {
            "reference_date": "2022-08-07",
            "reference_text": [
                {
                    "value": "여성만의 문제가 아닌 남편과 온 가족이 함께 겪고 해결해야 한다는 이유에서다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                },
                {
                    "value": "특히 아내에 대한 남편의 공감과 연대는 필수적이다.",
                    "value_time": "2022-09-21",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://moneys.mt.co.kr/news/mwView.php?no=2022080515481067235",
            "search_query": "산후우울증 공감 치료",
            "terminate": false,
            "text": "산후우울증은 남편과 모든 가족이 함께 해결해야 해요. 특히 남편이 아내를 공감해주고 서로 연대 되어 있다는 느낌을 주는 것이 필수랍니다.",
            "turn_id": "BK22009162-8",
            "utterance_id": "BK22009162.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "가족에게서 위로받고 공감 받으면 좋아진다는 거네요. 아이 낳고 우울감이 생겨 너무 힘들었는데 이렇게 대화를 하니 조금이나마 마음이 가벼워진 것 같아요.",
            "turn_id": "BK22009162-9",
            "utterance_id": "BK22009162.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "마음속 얘기를 하는 것만으로도 기분이 좋아지기도 하니까 많은 대화를 통해 마음을 가볍게 하는 것이 중요해요.",
            "turn_id": "BK22009162-9",
            "utterance_id": "BK22009162.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알겠어요. 알려주신 대로 가족과 많이 대화하고 그래도 좋아지지 않으면 상담도 받으러 가볼게요. 정보 감사드려요.",
            "turn_id": "BK22009162-10",
            "utterance_id": "BK22009162.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "산후우울증을 적극적으로 해결하려는 의지가 있으시니 금방 좋아지실 거예요. 그럼 행복하게 육아하시고 다음에 또 봬요.",
            "turn_id": "BK22009162-10",
            "utterance_id": "BK22009162.20"
        }
    ]
}