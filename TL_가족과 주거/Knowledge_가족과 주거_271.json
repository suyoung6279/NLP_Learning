    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "조카가 가와사키병에 걸렸다고 입원해야 한다는 전화를 받았어요. 가와사키병은 저에겐 조금 생소한데, 가와사키가 어떠한 뜻이 있는 일본어 단어인가요?",
            "turn_id": "BK22014984-1",
            "utterance_id": "BK22014984.1"
        },
        {
            "reference_date": "2021-06-24",
            "reference_text": [
                {
                    "value": "가와사키병은 1967년 일본 소아과의사 가와사키 도미사쿠가 처음 발견하면서 이름이 붙었다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=54279",
            "search_query": "소아 가와사키병 이름",
            "terminate": false,
            "text": "가와사키라는 일본어 단어가 어떠한 뜻이 있는 것은 아니에요. 이 병은 1967년 일본의 소아과의사인 가와사키 도미사쿠가 최초로 발견하게 되면서 이름을 붙인 거예요.",
            "turn_id": "BK22014984-1",
            "utterance_id": "BK22014984.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "이따이이따이병처럼 뜻이 있는 게 아니라 병을 발견한 박사의 이름을 딴 거군요. 저도 아이를 키웠지만 가와사키병은 처음 들어보는데, 어떤 질병인가요?",
            "turn_id": "BK22014984-2",
            "utterance_id": "BK22014984.3"
        },
        {
            "reference_date": "2022-02-22",
            "reference_text": [
                {
                    "value": "가와사키병은 소아에서 발생하는 원인 불명의 급성 열성 혈관염으로 피부와 점막, 임파절 등 전신에 침범하는 질병이다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.monews.co.kr/news/articleView.html?idxno=310513",
            "search_query": "소아 가와사키병",
            "terminate": false,
            "text": "가와사키병은 아이들에게서 발생하는 원인 불명 급성 열성 혈관염이에요. 혈관뿐 아니라 피부나 점막, 임파절 등 온몸에 침범하는 질병이랍니다.",
            "turn_id": "BK22014984-2",
            "utterance_id": "BK22014984.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "급성 혈관염이라면 꽤 심각한 병 아닌가요? 아이들이 자주 걸리는 병인지 아님 희귀병인지 궁금해요.",
            "turn_id": "BK22014984-3",
            "utterance_id": "BK22014984.5"
        },
        {
            "reference_date": "2022-05-11",
            "reference_text": [
                {
                    "value": "국내에서 매년 4000~5000명의 환자가 발생하는 비교적 흔한 질환으로, 사망률은 0.01%에 불과해 치료가 잘되는 편이다.",
                    "value_time": "2022-10-05",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.healthinnews.co.kr/news/articleView.html?idxno=29901",
            "search_query": "소아 가와사키병 흔한 질환",
            "terminate": false,
            "text": "소아 가와사키병은 우리나라에서 매해 4000~5000명이 걸리는 비교적 흔한 질환이랍니다. 가와사키병의 사망률은 0.01%에 불과하여 치료가 잘 되는 질환 중 하나에요.",
            "turn_id": "BK22014984-3",
            "utterance_id": "BK22014984.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "흔한 질환이라면 그나마 다행이네요. 처음에 코로나 증상인 줄 알고 계속 코로나 검사만 받았다는데, 코로나와 가와사키병 증상이 비슷한가요?",
            "turn_id": "BK22014984-4",
            "utterance_id": "BK22014984.7"
        },
        {
            "reference_date": "2022-05-11",
            "reference_text": [
                {
                    "value": "가와사키병의 증상은 기침과 고열 등으로 독감 최근에는 코로나19 감염과도 비슷한 모습을 보인다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                },
                {
                    "value": "하지만 기온이 내려가는 겨울 봄 등에 감염이 늘어나는 이들 질환과 달리 가와사키병은 기온이 올라가는 여름과 초가을에 환자가 늘어나는 차이가 있다.",
                    "value_time": "2022-10-05",
                    "value_type": "variable"
                },
                {
                    "value": "초기에는 경우에 따라 설사, 복통, 두통 등을 호소하기도 한다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.healthinnews.co.kr/news/articleView.html?idxno=29901",
            "search_query": "소아 가와사키병 코로나",
            "terminate": false,
            "text": "그럴 만도 한 게, 가와사키병은 기침과 고열 증상이 있기 때문에 코로나와 헷갈릴 수 있어요. 하지만 코로나나 독감은 겨울이나 봄에 감염이 많이 되지만 가와사키는 기온이 높은 여름이나 초가을에 많이 걸린다는 차이점이 있어요. 가와사키병 초기에는 설사나 두통, 복통 증상을 호소하는 경우도 있답니다.",
            "turn_id": "BK22014984-4",
            "utterance_id": "BK22014984.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "정말 증상만 봐서는 코로나인지 독감인지 가와사키병인지 구분하기 어렵겠네요. 그럼 가와사키병에서만 나타나는 전형적인 증상이 있나요?",
            "turn_id": "BK22014984-5",
            "utterance_id": "BK22014984.9"
        },
        {
            "reference_date": "2022-05-11",
            "reference_text": [
                {
                    "value": "가와사키병의 전형적인 증상으로는 ▲38.5도 이상의 고열 지속 ▲눈꼽 없는 결막충혈 ▲입술 혹은 혓바닥이 붉어지고 붓는 딸기혀 증상, ▲몸이나 BCG(결핵예방백신)접종을 한 자리에 발진 ▲목 림프절이 붓는 증상 ▲손발이 붉고 붓고 붉어짐 등이다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.healthinnews.co.kr/news/articleView.html?idxno=29901",
            "search_query": "소아 가와사키병 증상",
            "terminate": false,
            "text": "가와사키병의 전형적인 증상은 38.5도 이상의 고열이 지속되거나 눈곱 없이 결막이 충혈되는 경우, 입술이나 혓바닥이 빨개지면서 붓는 딸기 혀 증상이 있어요. 또한 몸이나 BCG 접종을 한 부위에 발진이 생기고 손발이 붓고 붉어지는 증상이 나타난답니다. 목 림프절도 붓는다면 가와사키병을 의심해 보아야 해요.",
            "turn_id": "BK22014984-5",
            "utterance_id": "BK22014984.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "딸기 혀나 결막충혈, 발진 등이 생기면 코로나나 독감보다 가와사키병을 의심해 볼 수 있는 거네요. 그런데 가와사키병은 왜 걸리는 거예요?",
            "turn_id": "BK22014984-6",
            "utterance_id": "BK22014984.11"
        },
        {
            "reference_date": "2022-05-11",
            "reference_text": [
                {
                    "value": "원인은 아직 밝혀지지 않았다.",
                    "value_time": "2022-10-05",
                    "value_type": "variable"
                },
                {
                    "value": "바이러스나 용혈사슬알균 등의 감염성 질환이 원인으로 지목되며, 유전적인 요소도 영향을 미치는 것으로 추측되고 있다.",
                    "value_time": "2022-10-05",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.healthinnews.co.kr/news/articleView.html?idxno=29901",
            "search_query": "소아 가와사키병 원인",
            "terminate": false,
            "text": "가와사키병이 왜 걸리는지 그 원인은 아직 정확히 밝혀진 바가 없어요. 바이러스나 용혈사슬알균 등으로 인한 감염성 질환, 유전적인 요소 때문에 발생한다고 추측할 뿐이에요.",
            "turn_id": "BK22014984-6",
            "utterance_id": "BK22014984.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "원인이 명확하지 않으면 예방하는 것도 힘들겠네요. 그럼 의심 증상이 있어 병원에 가면 어떤 검사를 통해 가와사키병을 진단받게 되나요?",
            "turn_id": "BK22014984-7",
            "utterance_id": "BK22014984.13"
        },
        {
            "reference_date": "2021-06-24",
            "reference_text": [
                {
                    "value": "피검사, 소변검사 등을 통해 5가지 증상 중 2~3가지만 나타날 경우 불완전가와사키병, 4가지 이상이면 전형적인 가와사키병으로 진단한다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=54279",
            "search_query": "소아 가와사키병 검사",
            "terminate": false,
            "text": "피검사와 소변 검사 등을 통하여 5가지 증상 가운데 2~3가지만 나타나면 불완전가와사키병, 4가지 이상의 증상이 발현된다면 가와사키병으로 진단하게 돼요.",
            "turn_id": "BK22014984-7",
            "utterance_id": "BK22014984.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇군요. 조카가 몸도 아픈데 여러 검사까지 받느라 힘들었겠어요. 그럼 가와사키병은 어떤 치료를 하게 되나요?",
            "turn_id": "BK22014984-8",
            "utterance_id": "BK22014984.15"
        },
        {
            "reference_date": "2022-05-11",
            "reference_text": [
                {
                    "value": "초기에는 면역글로블린과 고용량의 아스피린을 투여해 치료한다.",
                    "value_time": "2022-10-05",
                    "value_type": "variable"
                },
                {
                    "value": "발병한 지 1~2주가 지나면 반드시 심장초음파 검사로 관상동맥의 상태를 파악하는데, 관상동맥합병증(관상동맥류)이 없을 경우 아스피린의 용량을 주로 투여하며 6~8주간 경과를 지켜본다.",
                    "value_time": "2022-10-05",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.healthinnews.co.kr/news/articleView.html?idxno=29901",
            "search_query": "소아 가와사키병 치료",
            "terminate": false,
            "text": "가와사키병의 초기에는 면역글로블린과 고용량 아스피린을 투여하게 돼요. 발병한 지 1~2주가 지나면 꼭 심장초음파 검사를 하여 관상동맥의 상태를 파악해야 하는데요. 관상동맥합병증이 없다면 아스피린의 용량을 주로 투여하고 6~8주간의 경과를 지켜보게 된답니다.",
            "turn_id": "BK22014984-8",
            "utterance_id": "BK22014984.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇군요. 며칠 동안 열이 난다고 해서 단순 감기인 줄 알았는데, 가와사키라니 얼마나 걱정했는지 몰라요.",
            "turn_id": "BK22014984-9",
            "utterance_id": "BK22014984.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러셨군요. 병원에서 치료받으면 나을 수 있는 병이니 너무 걱정하지 마세요.",
            "turn_id": "BK22014984-9",
            "utterance_id": "BK22014984.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇게 생각해야겠죠? 조카가 퇴원하면 몸에 좋은 음식도 잔뜩 해줘야겠어요. 오늘 도움 주셔서 감사해요.",
            "turn_id": "BK22014984-10",
            "utterance_id": "BK22014984.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "별말씀을요. 아이가 하루빨리 건강해지길 저도 염원할게요. 그럼 다음에 또 이야기 나눠요.",
            "turn_id": "BK22014984-10",
            "utterance_id": "BK22014984.20"
        }
    ]
}