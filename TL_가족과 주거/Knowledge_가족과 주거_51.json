    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지가 1살이 되어서 예방접종을 맞추려고 해. 어떤 것들을 접종시키면 될까?",
            "turn_id": "BK22012650-1",
            "utterance_id": "BK22012650.1"
        },
        {
            "reference_date": "44553.0",
            "reference_text": [
                {
                    "value": "첫 번째로 접종해야 하는 것은 바로 종합 백신이다.",
                    "value_time": "44775.0",
                    "value_type": "variable"
                },
                {
                    "value": "DHPPi와 DHPPL로 나뉜다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                },
                {
                    "value": "반려견이 가장 많이 맞는 백신은 DHPPi이며, 렙토스피라의 경우 부작용 우려가 있어 실외 생활을 하는 반려견에게 권해진다.",
                    "value_time": "44775.0",
                    "value_type": "variable"
                },
                {
                    "value": "DHPPL은 위의 4가지와 들쥐 등 야생동물을 통해 전염되는 렙토스피라(Leptospira) 질병을 예방하는 효과가 추가된 것이다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.busan.com/view/busan/view.php?code=2021122218295403115",
            "search_query": "반려견 종합백신",
            "terminate": false,
            "text": "종합백신을 첫 번째로 접종시키면 돼. 종합백신은 DHPPi와 DHPPL로 나뉘는데 DHPPi는 강아지들이 가장 많이 맞는 백신이야. DHPPL은 야생동물들로부터 전염되는 렙토스피라 질병을 막아주지만 부작용의 우려 때문에 실외에서 생활하는 강아지한테 권해져.",
            "turn_id": "BK22012650-1",
            "utterance_id": "BK22012650.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지들이 가장 많이 접종하는 DHPPi는 어떤 질병을 예방해 줘?",
            "turn_id": "BK22012650-2",
            "utterance_id": "BK22012650.3"
        },
        {
            "reference_date": "44553.0",
            "reference_text": [
                {
                    "value": "DHPPi는 홍역(Distemper), 간염(Hepatitis), 파보 장염(Parvo virus), 파라 인플루엔자(Parainfluenza) 4가지 병을 예방하기 위한 백신이다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.busan.com/view/busan/view.php?code=2021122218295403115",
            "search_query": "DHPPi",
            "terminate": false,
            "text": "DHPPi라는 백신은 홍역과 간염, 파보 장염 ,파라 인플루엔자 이렇게 4가지의 병을 예방할 수 있는 백신이야.",
            "turn_id": "BK22012650-2",
            "utterance_id": "BK22012650.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "종합백신을 먼저 접종 시켜야겠구나. 그리고 또 어떤 백신을 맞춰야 해?",
            "turn_id": "BK22012650-3",
            "utterance_id": "BK22012650.5"
        },
        {
            "reference_date": "44672.0",
            "reference_text": [
                {
                    "value": "코로나 장염 백신은 말 그대로 장염을 일으키는 α- coronavirus를 예방해줍니다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                },
                {
                    "value": "발열, 식욕부진, 구토와 설사, 우울증, 백혈구 감소증을 나타내어 파보바이러스와 증상이 비슷합니다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.salgoonews.com/news/articleView.html?idxno=18478",
            "search_query": "코로나 장염",
            "terminate": false,
            "text": "코로나 장염 백신을 맞춰야 해. 알파 coronavirus가 장염을 일으키는데 백신을 맞으면 예방해 주거든. 코로나 장염에 걸리게 되면 파보바이러스와 비슷하게 발열과 구토와 설사, 우울증, 식욕부진 및 백혈구가 감소되는 증상이 나타나.",
            "turn_id": "BK22012650-3",
            "utterance_id": "BK22012650.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "사람이 걸리는 코로나를 말하는 거야?",
            "turn_id": "BK22012650-4",
            "utterance_id": "BK22012650.7"
        },
        {
            "reference_date": "44619.0",
            "reference_text": [
                {
                    "value": "우선 반려견이 걸리는 바이러스는 ‘개 코로나바이러스(canine coronavirus)’다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                },
                {
                    "value": "무엇보다 이 바이러스는 사람에게 감염되지 않는 것으로 확인됐다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.pharmnews.com/news/articleView.html?idxno=100062",
            "search_query": "개 코로나 바이러스",
            "terminate": false,
            "text": "아니. canine coronavirus라고 개 코로나 바이러스를 말해. 이 바이러스는 사람에게 전염되지 않아.",
            "turn_id": "BK22012650-4",
            "utterance_id": "BK22012650.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아 그래? 그렇다면 강아지가 코로나19에 걸리진 않는 건가?",
            "turn_id": "BK22012650-5",
            "utterance_id": "BK22012650.9"
        },
        {
            "reference_date": "44505.0",
            "reference_text": [
                {
                    "value": "드문 확률이긴 하지만 동물들도 코로나19에 감염될 수 있습니다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                },
                {
                    "value": "고양이와 개를 포함해 전세계적으로 소수의 반려동물이 코로나19에 감염됐습니다.",
                    "value_time": "44775.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/Society/article/all/20211105/110094567/1",
            "search_query": "동물 코로나19",
            "terminate": false,
            "text": "드물긴 하지만 동물도 코로나19에 걸릴 수 있어. 실제로 강아지와 고양이를 비롯해 소수의 반려동물이 전 세계적으로 코로나19에 감염되었거든.",
            "turn_id": "BK22012650-5",
            "utterance_id": "BK22012650.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "사람한테 코로나19가 옮은 거야?",
            "turn_id": "BK22012650-6",
            "utterance_id": "BK22012650.11"
        },
        {
            "reference_date": "44505.0",
            "reference_text": [
                {
                    "value": "코로나19에 감염된 동물들은 대부분 코로나19에 확진된 주인이나 가족과 밀접하게 접촉한 후에 확진됐습니다.",
                    "value_time": "44775.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/Society/article/all/20211105/110094567/1",
            "search_query": "코로나19 감염 동물",
            "terminate": false,
            "text": "맞아. 코로나19에 걸린 대부분의 동물들은 코로나19에 확진된 가족이나 주인과 긴밀하게 접촉하고 나서 확진이 되었어.",
            "turn_id": "BK22012650-6",
            "utterance_id": "BK22012650.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "사람한테서 코로나19를 옮을 수 있구나. 그건 그렇고 또 어떤 접종을 맞춰야 해?",
            "turn_id": "BK22012650-7",
            "utterance_id": "BK22012650.13"
        },
        {
            "reference_date": "44651.0",
            "reference_text": [
                {
                    "value": "켄넬코프로 일컫는 보데텔라(Bordetella bronchiseptica) 감염증은 반려견에서 흔한 전염성 질환이다",
                    "value_time": "44775.0",
                    "value_type": "constant"
                },
                {
                    "value": "미국에서도 논코어(Non-core) 백신으로 분류되지만 실질적으로는 접종이 권고되고 있다.",
                    "value_time": "44775.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.dailyvet.co.kr/news/practice/companion-animal/163431",
            "search_query": "켄넬코프",
            "terminate": false,
            "text": "켄넬코프 접종을 맞춰야 해. 보데텔라 감염증이 켄넬코프로 부르는데 강아지한테 흔하게 나타나는 전염성 질환이야. 미국에서는 논코어 백신으로 분류되긴 하지만 실제로는 접종을 권장하고 있어.",
            "turn_id": "BK22012650-7",
            "utterance_id": "BK22012650.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "켄넬코프라는 건 처음 들어봤어. 그리고 또 맞춰야 할 예방접종이 있을까?",
            "turn_id": "BK22012650-8",
            "utterance_id": "BK22012650.15"
        },
        {
            "reference_date": "43750.0",
            "reference_text": [
                {
                    "value": "광견병은 법정 전염병으로 현재 우리나라에서는 모든 반려동물 소유자가 접종에 대한 의무를 가지고 있다.",
                    "value_time": "44775.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.sideview.co.kr/news/articleView.html?idxno=3150",
            "search_query": "광견병 접종",
            "terminate": false,
            "text": "우리나라에서는 반려동물을 소유하고 있는 사람은 모두 광견병 접종을 의무적으로 맞춰야 해. 광견병은 법률로 규정된 전염병이거든.",
            "turn_id": "BK22012650-8",
            "utterance_id": "BK22012650.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맞아. 광견병 주사는 꼭 맞춰야 한다는 말은 들었어.",
            "turn_id": "BK22012650-9",
            "utterance_id": "BK22012650.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "응. 키우는 강아지에게 광견병 주사도 맞히고 알려준 예방접종들도 챙겨서 맞춰.",
            "turn_id": "BK22012650-9",
            "utterance_id": "BK22012650.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래야겠어. 종합백신이랑 코로나 장염, 켄넬코프, 광견병 접종 수첩에 적어놔야겠다.",
            "turn_id": "BK22012650-10",
            "utterance_id": "BK22012650.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "응. 강아지 컨디션 좋을 때 접종 잘 챙겨서 맞추길 바라! 맞추길 바라!",
            "turn_id": "BK22012650-10",
            "utterance_id": "BK22012650.20"
        }
    ]
}