    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "남편이랑 상의해봤는데 우리 아기를 가져보기로 했어.",
            "turn_id": "BK22002118-1",
            "utterance_id": "BK22002118.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어머, 너무 축하해. 넌 항상 아이가 있었으면 했잖아.",
            "turn_id": "BK22002118-1",
            "utterance_id": "BK22002118.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맞아. 그런데 임신을 준비하려고 하니 막상 뭐부터 해야할 지 모르겠는거야.",
            "turn_id": "BK22002118-2",
            "utterance_id": "BK22002118.3"
        },
        {
            "reference_date": "2021-01-05",
            "reference_text": [
                {
                    "value": "임신전 검사는 부부의 건강 상태를 확인해 임신에 필요한 치료를 받고 준비하는 과정이다.",
                    "value_time": "2022-07-19",
                    "value_type": "constant"
                },
                {
                    "value": "여성은 혈액검사로 빈혈, 혈소판 수치, 풍진, 성병, 간염 항원 및 항체, 혈액형 등을 확인한다.",
                    "value_time": "2022-07-19",
                    "value_type": "constant"
                },
                {
                    "value": "남성 역시 여성과 마찬가지로 혈액검사, 소변검사, 간염 검사 등을 필수적으로 받아야 한다.",
                    "value_time": "2022-07-19",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.yna.co.kr/view/AKR20210105057200017",
            "search_query": "임신 계획 가임력",
            "terminate": false,
            "text": "임신전 검사부터 해봐. 부부의 건강 상태를 확인하고 임신에 필요한 치료를 받는 준비 과정이야. 여자는 혈액검사를 해서 빈혈, 혈소판 수치, 풍진, 성병, 간염 항원과 항체, 혈액형을 확인하게 될거고, 남자도 혈액검사를 해. 그리고 소변검사, 간염 검사를 필수적으로 받아야 해.",
            "turn_id": "BK22002118-2",
            "utterance_id": "BK22002118.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래? 그냥 임신을 하면 되는 게 아니라 검사도 받아야 하는거였어?",
            "turn_id": "BK22002118-3",
            "utterance_id": "BK22002118.5"
        },
        {
            "reference_date": "2012-12-26",
            "reference_text": [
                {
                    "value": "시군구별로 조금씩 차이가 있지만 대부분의 경우 신혼부부에게는 임신전 혈액검사가 무료이다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://n.news.naver.com/mnews/article/086/0002139130?sid=102",
            "search_query": "임신전 산전검사 보건소",
            "terminate": false,
            "text": "물론이지. 사는 곳마다 다르긴 한데 대부분 신혼부부한테는 임신 전 혈액검사가 무료니까 잘 찾아봐.",
            "turn_id": "BK22002118-3",
            "utterance_id": "BK22002118.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "또 주의해야할 점이 있을까?",
            "turn_id": "BK22002118-4",
            "utterance_id": "BK22002118.7"
        },
        {
            "reference_date": "2022-03-10",
            "reference_text": [
                {
                    "value": "술이나 담배로 체내에 쌓인 독소들은 장기간 건강에 영향을 주는 것들이며 임신을 계획한다면 최소 6개월 전에는 끊는 것이 좋습니다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.ibabynews.com/news/articleView.html?idxno=99452",
            "search_query": "임신 계획 준비",
            "terminate": false,
            "text": "술이나 담배 끊는 거 잊지마. 임신을 계획하고 있다면 최소 6개월 전에는 끊어야 해. 술이나 담배로 체내에 쌓인 독소들은 장기간동안 건강에 영향을 주거든.",
            "turn_id": "BK22002118-4",
            "utterance_id": "BK22002118.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그건 이미 얘기해뒀지. 남편이 담배를 끊는다고 큰 결심을 했더라고. 먹으면 안되는 것 말고 챙겨먹으면 좋은 것 있을까?",
            "turn_id": "BK22002118-5",
            "utterance_id": "BK22002118.9"
        },
        {
            "reference_date": "2022-05-09",
            "reference_text": [
                {
                    "value": "엽산은 임신 극 초기부터 12주차까지 필수 섭취 영양소이므로 임신을 준비하는 시기부터 꾸준히 섭취해주면 좋다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                },
                {
                    "value": "산부인과에서 임신 확인서를 발급받고 보건소에 찾아가면 임신 12주까지 섭취할 수 있을 만큼의 엽산을 무료로 지급 받을 수 있다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kizmom.hankyung.com/news/view.html?aid=202205092092o",
            "search_query": "임신준비 영양제",
            "terminate": false,
            "text": "임신을 준비하는 시기부터 먹으면 좋은건 엽산이야. 게다가 엽산은 임신 극 초기부터 12주차까지 필수 영양소라서 산부인과에서 임신 확인서를 발급받은 후에 보건소를 가면 12주치 엽산을 무료로 받을 수 있어. 지금은 엽산을 개인적으로 사서 챙겨먹고, 임신 후에는 보건소에서 지급받는거 잊지마.",
            "turn_id": "BK22002118-5",
            "utterance_id": "BK22002118.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그거 정말 좋은 정보네. 그런데 엽산이 왜 필수영양소인거야?",
            "turn_id": "BK22002118-6",
            "utterance_id": "BK22002118.11"
        },
        {
            "reference_date": "2022-05-14",
            "reference_text": [
                {
                    "value": "비타민 B의 일종인 엽산은 태아의 뇌 발달을 돕고 신경관 결손을 막는 ‘임신부 필수 영양소’로 꼽힌다.",
                    "value_time": "2022-07-19",
                    "value_type": "constant"
                },
                {
                    "value": "임신 중 엽산을 충분히 섭취할 경우, 습관성 유산, 다운증후군, 저체중아, 거대적아구성빈혈 등을 예방할 수 있다.",
                    "value_time": "2022-07-19",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://health.chosun.com/site/data/html_dir/2022/05/11/2022051102141.html",
            "search_query": "임신 엽산",
            "terminate": false,
            "text": "엽산은 비타민B의 일종인데 태아의 뇌 발달을 돕고 신경관 결손을 막거든. 임신 중에 엽산을 충분히 섭취하면 습관성 유산, 다운증후군, 저체중아, 거대적아구성빈혈도 예방할 수 있어.",
            "turn_id": "BK22002118-6",
            "utterance_id": "BK22002118.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "엽산은 여자만 먹으면 되는거야?",
            "turn_id": "BK22002118-7",
            "utterance_id": "BK22002118.13"
        },
        {
            "reference_date": "2021-12-13",
            "reference_text": [
                {
                    "value": "이러한 이유로 임신을 준비하는 기간에는 여성은 물론 배우자까지 정량의 엽산을 꾸준하게 챙겨서 복용하는 것이 좋다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000655889",
            "search_query": "임신 준비",
            "terminate": false,
            "text": "아니. 부부가 함께 정량의 엽산을 꾸준히 챙겨 먹는게 좋아.",
            "turn_id": "BK22002118-7",
            "utterance_id": "BK22002118.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 똑같이 잘 챙겨먹는 것 처럼 남편도 생활 습관을 고치고 건강 관리하는 게 필수인거지?",
            "turn_id": "BK22002118-8",
            "utterance_id": "BK22002118.15"
        },
        {
            "reference_date": "2021-08-18",
            "reference_text": [
                {
                    "value": "건강한 임신을 위해서는 준비와 노력이 필요한데 생활습관 개선 등을 통해 정자의 질적, 양적 개선을 기대하려면 적어도 3개월 이상의 준비기간이 필요하다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.healthinnews.co.kr/news/articleView.html?idxno=24772",
            "search_query": "남자 임신준비 기간",
            "terminate": false,
            "text": "맞아. 정자가 질적, 양적으로 개선되려면 최소 3개월의 준비기간이 필요하거든.",
            "turn_id": "BK22002118-8",
            "utterance_id": "BK22002118.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알겠어. 임신 준비하려면 이것저것 챙기고 알아야 할 것들이 참 많다.",
            "turn_id": "BK22002118-9",
            "utterance_id": "BK22002118.17"
        },
        {
            "reference_date": "2021-03-16",
            "reference_text": [
                {
                    "value": "임신 3개월 전부터는 부부가 함께 금연, 금주, 스트레스 관리, 숙면 등 건강한 생활습관을 유지하는 것이 좋다.",
                    "value_time": "2022-07-19",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://health.chosun.com/site/data/html_dir/2021/03/16/2021031600841.html",
            "search_query": "부부 임신준비",
            "terminate": false,
            "text": "3개월 전부터 남편이랑 같이 담배 끊기, 술 끊기, 스트레스 관리하기, 잘 자기 이런 건강한 생활습관 유지하는 게 좋지.",
            "turn_id": "BK22002118-9",
            "utterance_id": "BK22002118.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아마 임신 준비할 때가 내 인생에서 제일 건강한 때가 되겠네.",
            "turn_id": "BK22002118-10",
            "utterance_id": "BK22002118.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래도 너무 설레겠다. 말 나온김에 내가 엽산 선물해줄게. 집 주소 좀 불러줄래?",
            "turn_id": "BK22002118-10",
            "utterance_id": "BK22002118.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "내가 이따가 집에 가서 문자로 보내줄게. 선물 고마워!",
            "turn_id": "BK22002118-11",
            "utterance_id": "BK22002118.21"
        }
    ]
}