            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "잘 생각했어. 간단한 것부터 하나씩 도전해 봐. 직접 강아지 주식과 간식을 만드는 재미와 보람도 쏠쏠해서 꼭 한 번쯤은 도전해 보길 추천해.",
            "turn_id": "BK22008134-10",
            "utterance_id": "BK22008134.20"
