    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리집 개가 활동성이 좋아서 산책을 자주 하고 있어. 산책을 하면서 할 수 있는 일이 있나 찾아보고 있어. 어떤 게 좋을까?",
            "turn_id": "BK22016514-1",
            "utterance_id": "BK22016514.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇다면 반려견 순찰대에 지원해 보는 것도 고려해 봐.",
            "turn_id": "BK22016514-1",
            "utterance_id": "BK22016514.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "반려견 순찰대 이름 좋은데 어떤 역할이야?",
            "turn_id": "BK22016514-2",
            "utterance_id": "BK22016514.3"
        },
        {
            "reference_date": "44662.0",
            "reference_text": [
                {
                    "value": "서울 반려견 순찰대'는 주민이 반려견과 함께 일상적인 산책 활동을 자유롭게 하면서 거주지 곳곳의 위험 요소를 살피고 지역 방범 활동을 하는 역할을 한다.",
                    "value_time": "44831.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/202204111809135329",
            "search_query": "서울 반려견 순찰대",
            "terminate": false,
            "text": "서울 반려견 순찰대는 거주민이 개와 같이 자유롭게 일상적인 산책을 하면서, 사는 곳 주변에 위험한 것들이 있나 둘러보고 지역의 방범 활동을 하는 역할을 해.",
            "turn_id": "BK22016514-2",
            "utterance_id": "BK22016514.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "지역의 방범활동을 하는 거였구나. 순찰대 활동은 시간이 정해져 있어?",
            "turn_id": "BK22016514-3",
            "utterance_id": "BK22016514.5"
        },
        {
            "reference_date": "44741.0",
            "reference_text": [
                {
                    "value": "순찰대 활동은 시간 제약 없이 자율적으로 이뤄진다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.segye.com/newsView/20220628526254?OutUrl=naver",
            "search_query": "반려견 순찰대 활동",
            "terminate": false,
            "text": "순찰대 활동은 시간 제한없이 자주적으로 할 수 있어.",
            "turn_id": "BK22016514-3",
            "utterance_id": "BK22016514.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "원하는 시간에 하니 좋다. 활동하기 전에 어떤 교육을 받고 투입돼?",
            "turn_id": "BK22016514-4",
            "utterance_id": "BK22016514.7"
        },
        {
            "reference_date": "44743.0",
            "reference_text": [
                {
                    "value": "반려견 순찰대에 참가하려면 범죄 예방, 생활 안전 등의 교육을 받아야 한다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                },
                {
                    "value": "반려견도 안전사고 예방을 위한 기본적 행동 교육을 받은 뒤 순찰에 투입된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/article/all/20220630/114234120/1",
            "search_query": "반려견 순찰대",
            "terminate": false,
            "text": "범죄 예방, 생활 안전 등의 교육을 받아야 반려견 순찰대에 참가할 수 있어. 반려견도 순찰하려면 안전사고 예방을 위한 기본적 행동 교육을 받은 뒤 투입돼.",
            "turn_id": "BK22016514-4",
            "utterance_id": "BK22016514.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "반려견 순찰대가 활동하면서 치안에 기여한 게 있을까?",
            "turn_id": "BK22016514-5",
            "utterance_id": "BK22016514.9"
        },
        {
            "reference_date": "44740.0",
            "reference_text": [
                {
                    "value": "반려견 순찰대는 주취자 신고, 가로등 고장, 도로 파손 등 87건의 신고를 접수하는 등 공동체 치안문화 형성에 기여했다.",
                    "value_time": "44831.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://news.heraldcorp.com/view.php?ud=20220628000423",
            "search_query": "반려견 순찰대 활동효과",
            "terminate": false,
            "text": "반려견 순찰대는 공동체 치안 문화 형성에 공헌했어. 술에 취한 사람 신고, 가로등 고장, 도로 파손 등 87건의 신고를 접수했지.",
            "turn_id": "BK22016514-5",
            "utterance_id": "BK22016514.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나! 반려견 순찰대의 활동이 범죄 예방 효과도 있을까?",
            "turn_id": "BK22016514-6",
            "utterance_id": "BK22016514.11"
        },
        {
            "reference_date": "44743.0",
            "reference_text": [
                {
                    "value": "서울시 자치경찰위원회 강민준 경위는 “일반 방범대는 정해진 시간에만 순찰을 도는데, 반려견 순찰대는 이른 새벽부터 늦은 밤까지 산책을 다니며 범죄 예방에 긍정적 효과를 주고 있다”고 설명했다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/article/all/20220630/114234120/1",
            "search_query": "반려견 순찰대 활동",
            "terminate": false,
            "text": "서울시 자치경찰 위원회에 따르면 일반적인 방범대는 정해진 시간에 순찰하는 반면, 반려견 순찰대는 이른 새벽에서부터 늦은 저녁까지 산책하기 때문에 범죄 예방에 긍정적 효과를 주고 있다고 보고 있어.",
            "turn_id": "BK22016514-6",
            "utterance_id": "BK22016514.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "산책을 하면서 동네 치안에도 긍정적인 효과를 줄 수있다니 좋다. 신청은 어디서 할 수 있어?",
            "turn_id": "BK22016514-7",
            "utterance_id": "BK22016514.13"
        },
        {
            "reference_date": "44755.0",
            "reference_text": [
                {
                    "value": "순찰대 신청은 ‘서울 반려견 순찰대’ 홈페이지에서 가능하며 순찰 팀명, 동물등록번호, 순찰대 지원동기 등을 기재하면 된다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mediahub.seoul.go.kr/archives/2005063",
            "search_query": "반려견 순찰대 지원방법",
            "terminate": false,
            "text": "서울 반려견 순찰대 홈페이지에서 신청이 가능해. 순찰 팀명, 동물등록번호, 순찰대 지원동기 등을 작성 하면 돼.",
            "turn_id": "BK22016514-7",
            "utterance_id": "BK22016514.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "인원에 제한이 있을것 같은데 자치구당 몇 명이 선발되고 있어?",
            "turn_id": "BK22016514-8",
            "utterance_id": "BK22016514.15"
        },
        {
            "reference_date": "44743.0",
            "reference_text": [
                {
                    "value": "서류심사와 실습평가를 거쳐 자치구당 50명 내외의 순찰대원을 선발한다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.donga.com/news/article/all/20220630/114234120/1",
            "search_query": "반려견 순찰대 인원",
            "terminate": false,
            "text": "서류심사와 실습평가 후 자치구당 50명 내외로 순찰대원을 선정해.",
            "turn_id": "BK22016514-8",
            "utterance_id": "BK22016514.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "노견이나 신체가 불편한 반려견은 지원을 못 할까?",
            "turn_id": "BK22016514-9",
            "utterance_id": "BK22016514.17"
        },
        {
            "reference_date": "44755.0",
            "reference_text": [
                {
                    "value": "특히 반려견의 질병과 노령 등 이유로 순찰대 활동을 망설이는 반려견 가족들도 순찰대 활동에 참여할 수 있도록 강아지 유모차를 이용하여 정기적인 산책을 하고 있다면 신청과 심사를 통해 선발할 계획이다.",
                    "value_time": "44831.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mediahub.seoul.go.kr/archives/2005063",
            "search_query": "반려견 순찰대 지원조건",
            "terminate": false,
            "text": "반려견이 질병이 있거나 노령견인 경우에도 반려견 유모차를 타고 꾸준히 산책하고 있다면 순찰대에 신청이 가능하고 심사를 통해 뽑힐 수 있어.",
            "turn_id": "BK22016514-9",
            "utterance_id": "BK22016514.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "좋아 신청 기간이 되면 한번 해봐야겠다.",
            "turn_id": "BK22016514-10",
            "utterance_id": "BK22016514.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "명예직이긴 하지만 산책하면서 보람도 있고 좋을 것 같아.",
            "turn_id": "BK22016514-10",
            "utterance_id": "BK22016514.20"
        }
    ]
