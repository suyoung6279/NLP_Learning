            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다행이네요. 알레르기 때문에 반려동물을 못 키운다고 하면 너무 슬플 것 같았거든요. 오늘부터 차근히 공부하고 준비해서 조만간 강아지를 데려와야겠어요.",
            "turn_id": "BK22008722-10",
            "utterance_id": "BK22008722.19"
        },
        {
            "reference_date": "2020-01-13",
