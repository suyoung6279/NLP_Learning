    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고양이를 키울 때 월에 얼마나 들지 알고 있어야, 입양할 수 있을 거 같아. 고양이와 생활하는데 월에 얼마나 들까?",
            "turn_id": "BK22013457-1",
            "utterance_id": "BK22013457.1"
        },
        {
            "reference_date": "44523.0",
            "reference_text": [
                {
                    "value": "2021년 KB금융지주의 경영연구소가 발표한 통계에 따르면, 반려묘 양육비는 월 평균 10만 원 정도라고 합니다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "양육비용의 약 1/3은 사료 구입에 사용되었다고 해요.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "이처럼, 고양이를 키울 때는 사료, 고양이 화장실 모래처럼 주기적으로 사야 하는 생활 필수품이 있어 많은 비용이 듭니다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/109271/",
            "search_query": "고양이 비용",
            "terminate": false,
            "text": "2021년 KB금융지주의 경영연구소가 발표한 통계에서는 월평균 반려묘의 양육비는 10만 원 정도야. 사료 구입에 양육비의 약 삼분의 일이 사용되고 있는데, 이처럼 반려묘를 양육할 때는 주기적 생활필수품으로 사료, 화장실 모래 같은 것들을 사야 해서 큰 비용이 들어.",
            "turn_id": "BK22013457-1",
            "utterance_id": "BK22013457.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고양이는 독립적이라고 들었어. 고양이도 주인에게 애정 표현이 있을까?",
            "turn_id": "BK22013457-2",
            "utterance_id": "BK22013457.3"
        },
        {
            "reference_date": "43683.0",
            "reference_text": [
                {
                    "value": "반면 고양이 애정표현은 조용하고 소극적이다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "다리 근처로 와 몸을 비비거나, 꼬리를 바싹 세워 애정을 표현한다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "눈인사를 건네거나 얼굴로 다가와 코 뽀뽀를 해주기도 한다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/42124/",
            "search_query": "고양이 애정표현",
            "terminate": false,
            "text": "고양이는 다리 근처에서 몸 비비기, 또 꼬리를 바짝 세워 애정을 표현하고, 눈인사하거나 얼굴에 다가와서 코 뽀뽀를 하는 등 조용하고 소극적인 애정 표현을 해.",
            "turn_id": "BK22013457-2",
            "utterance_id": "BK22013457.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오히려 소극적이고 조용한 애정 표현이 고양이 매력이 올라가는 거 같아.",
            "turn_id": "BK22013457-3",
            "utterance_id": "BK22013457.5"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지와 또 다른 고양이의 애정 표현은 매력적이긴 해.",
            "turn_id": "BK22013457-3",
            "utterance_id": "BK22013457.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 외로움을 많이 타는 고양이도 있을까?",
            "turn_id": "BK22013457-4",
            "utterance_id": "BK22013457.7"
        },
        {
            "reference_date": "43888.0",
            "reference_text": [
                {
                    "value": "집사에게 많이 의지하는 고양이일수록 외로움을 잘 타는 특징이 있다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "유독 집사가 고양이를 과잉 보호하거나 맹목적으로 사랑하는 경향이 있으면 고양이도 외로움을 잘 탄다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/78830/",
            "search_query": "고양이 외로움",
            "terminate": false,
            "text": "집사에게 많이 의지한다던가, 집사가 고양이에게 과잉보호를 하거나, 맹목적 사랑을 해주는 경향이 있으면 고양이가 외로움을 타.",
            "turn_id": "BK22013457-4",
            "utterance_id": "BK22013457.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혼자 있다고 외롭지 않을 거 같아서 고양이를 반려동물로 생각하고 있었는데 이런 성격도 있을 수 있다는 걸 고려해야겠구나. 고양이 성격에 대해서 더 알려줄래?",
            "turn_id": "BK22013457-5",
            "utterance_id": "BK22013457.9"
        },
        {
            "reference_date": "43590.0",
            "reference_text": [
                {
                    "value": "호기심이 남다른 성격의 고양이들도 있다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "사냥 습성이 아주 강하게 발현되는 성격도 있다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "고양이는 기본적으로 예민한 동물이다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "그 정도가 유난히 심한 “예민 보스 고양이”도 있다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "이 경우, 누군가 자신을 제어하려고 하는 것을 매우 싫어한다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/28472/",
            "search_query": "고양이 성격",
            "terminate": false,
            "text": "기본적으로 예민한 성격의 고양이지만, 유난히 더 심한 예민 보스 고양이도 있어. 이런 고양이는 다른 사람이 자기를 제어하는 걸 아주 싫어해. 또 호기심이 많은 성격의 고양이도 있을 수 있고, 사냥 습성이 아주 강하게 나오는 성격도 있어.",
            "turn_id": "BK22013457-5",
            "utterance_id": "BK22013457.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고양이도 여러 성격이 있구나. 고양이 입양 전 준비해야 할 사항도 알려줘.",
            "turn_id": "BK22013457-6",
            "utterance_id": "BK22013457.11"
        },
        {
            "reference_date": "43993.0",
            "reference_text": [
                {
                    "value": "입양 전 고양이들의 기본적 생활을 하기 위한 의식주 마련은 필수 준비사항이다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "고양이에게 맞는 사료인지 확인을 할 수 없기에 건식사료와 습식사료를 모두 준비해두는 걸 추천한다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "고양이의 쾌적한 배변 활동을 위해 고양이 모래와 화장실을 준비한다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.busan.com/view/busan/view.php?code=2020061018130944175",
            "search_query": "고양이 입양시기 준비사항",
            "terminate": false,
            "text": "고양이를 입양하기 전에는 기본적인 생활을 위해 의식주 준비하는 게 필수 준비사항이야. 건식과 습식 사료를 모두 준비해서 고양이에게 맞는 사료인지 확인해 보는 게 좋아. 또 고양이 모래와 화장실 준비로 고양이가 쾌적한 배변 활동을 할 수 있어.",
            "turn_id": "BK22013457-6",
            "utterance_id": "BK22013457.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고양이 사료를 준비하려 봤는데, 종류가 너무 많아서 고르기 어려워. 사료 고르는 법 좀 알려줄래?",
            "turn_id": "BK22013457-7",
            "utterance_id": "BK22013457.13"
        },
        {
            "reference_date": "44756.0",
            "reference_text": [
                {
                    "value": "탄수화물은 고양이의 혈당을 빠르게 올릴 뿐만 아니라 알레르기를 유발할 수 있다고 합니다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "그래서 사료에 곡물 성분이 들어있지 않은 제품을 사야 합니다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "고양이는 고단백, 저탄수 식단으로 먹어야 합니다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "그래서 고양이 사료는 단백질이 30~40%정도가 좋다고 합니다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/125183/",
            "search_query": "고양이 사료 고르기",
            "terminate": false,
            "text": "고양이는 고단백질, 저탄수화물로 먹여야 해. 고양이에게 탄수화물은 혈당을 올리고 알레르기를 일으킬 수 있기 때문에 사료에 곡물 성분이 안 들어가 있는 제품을 고르는 게 좋아. 그리고 단백질은 30퍼센트에서 40퍼센트 정도 들어간 게 좋아.",
            "turn_id": "BK22013457-7",
            "utterance_id": "BK22013457.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "네가 알려준 대로 고려해서 사료를 고를게. 고양이 모래도 종류가 많던데, 모래 종류에 대해서도 알려줄래?",
            "turn_id": "BK22013457-8",
            "utterance_id": "BK22013457.15"
        },
        {
            "reference_date": "44348.0",
            "reference_text": [
                {
                    "value": "고양이 모래 종류는 아주 다양해요.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "이 중에서 가장 일반적으로 사용하는 두부모래와 벤토나이트, 카사바의 특징에 대해 알아봐요.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "두부 모래는 두부 찌꺼기로 만들어진 펠렛 모양의 모래로 얇은 입자부터 큰 입자까지 다양해요.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "벤토나이트는 야생의 모래와 가장 비슷한 형태로 고양이가 사용하기 쉬워요.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "카사바(옥수수) 모래는 카사바 나무에서 채취한 뿌리 작물과 옥수수로 만든 것으로 100% 천연 모래에요.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/103159/",
            "search_query": "고양이 모래고르기",
            "terminate": false,
            "text": "아주 다양한 고양이 모래가 있어. 일반적으로 사용하는 건 두부모래, 벤토나이트, 카바사가 있어. 특징을 알려주자면, 두부 찌꺼기로 만든 두부모래는 펠렛 모양으로 얇은 입자에서 큰 입자까지 다양하게 있고, 벤토나이트는 고양이가 사용하기 쉬운 야생 모래와 가장 비슷한 모양이야. 카사바 나무에서 채취한 뿌리 작물과 옥수수로 만든 카사바 모래는 백 퍼센트 천연 모래야.",
            "turn_id": "BK22013457-8",
            "utterance_id": "BK22013457.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고양이와 함께 놀아줄 장난감도 구입해야겠어. 고양이 장난감은 뭐가 있어?",
            "turn_id": "BK22013457-9",
            "utterance_id": "BK22013457.17"
        },
        {
            "reference_date": "43724.0",
            "reference_text": [
                {
                    "value": "물장구를 좋아하는 고양이라면 분명 급수대를 좋아할 것이다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                },
                {
                    "value": "캣휠은 고양이 러닝머신이다.",
                    "value_time": "44818.0",
                    "value_type": "constant"
                },
                {
                    "value": "끝에 깃털이나 인형이 달린 낚싯대는 고양이와 사냥놀이를 하는 데 사용하기에 제격이다.",
                    "value_time": "44818.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://mypetlife.co.kr/47737/",
            "search_query": "고양이 장난감",
            "terminate": false,
            "text": "급수대는 물장구치는 걸 좋아하는 고양이가 좋아하고, 고양이 러닝머신으로 캣휠도 있어. 고양이와 사냥놀이하는데 알맞은 끝에 깃털 혹은 인형이 달린 낚싯대도 있지.",
            "turn_id": "BK22013457-9",
            "utterance_id": "BK22013457.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고양이를 입양해서 가족이 될 생각 하니 마음이 설레. 알려줘서 고마워.",
            "turn_id": "BK22013457-10",
            "utterance_id": "BK22013457.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "다른 궁금한 점이 있으면 언제든지 물어봐.",
            "turn_id": "BK22013457-10",
            "utterance_id": "BK22013457.20"
        }
    ]
}