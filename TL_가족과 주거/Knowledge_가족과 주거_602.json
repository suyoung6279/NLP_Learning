    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저 있잖아요, 아기 가졌어요.",
            "turn_id": "BK22001696-1",
            "utterance_id": "BK22001696.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어머나, 정말 축하해요. 남편이 아기 많이 기다린다고 하더니 정말 기뻐하고 있겠어요. 그럼 예정일은 언제예요?",
            "turn_id": "BK22001696-1",
            "utterance_id": "BK22001696.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "임신 테스트기 확인하고 남편 펑펑 울었다니까요. 어제 병원 다녀왔는데 아직 아기집은 안 보인다고 다음주에 다시 오라고 하더라고요.",
            "turn_id": "BK22001696-2",
            "utterance_id": "BK22001696.3"
        },
        {
            "reference_date": "2017-11-08",
            "reference_text": [
                {
                    "value": "임신 5주차가 되면 생리중단으로 임신사실을 눈치챌 수 있으며, 소변 임신테스트기로도 확인할 수 있고, 초음파 검사로도 임신낭(아기집)과 태아의 모습을 확인할 수 있다.",
                    "value_time": "2022-07-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000308614",
            "search_query": "아기집 확인 시기",
            "terminate": false,
            "text": "산부인과에서 초음파 검사로 아기집을 확인할 수 있는 시기는 보통 임신 5주차 이후예요. 다음 번에는 초음파를 통해 태아의 모습도 확인할 수 있을 거예요.",
            "turn_id": "BK22001696-2",
            "utterance_id": "BK22001696.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "정말 기대돼요. 그럼 그때는 아기가 얼마나 자라 있을까요?",
            "turn_id": "BK22001696-3",
            "utterance_id": "BK22001696.5"
        },
        {
            "reference_date": "2018-09-06",
            "reference_text": [
                {
                    "value": "심장과 간도 생기고 임신 5주에 태아기로 진행되면서 키가 1cm에 다다릅니다.",
                    "value_time": "2022-07-10",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://uberin.mk.co.kr/view.php?year=2018&no=562497",
            "search_query": "임신 5주 아기 발달",
            "terminate": false,
            "text": "보통 임신 5주차쯤 되면 태아는 1cm 정도로 성장해요. 그리고 심장과 간도 생기게 된답니다.",
            "turn_id": "BK22001696-3",
            "utterance_id": "BK22001696.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아직 정말 작은 생명이네요. 빨리 제 눈으로 아기의 모습을 확인하고 싶어요.",
            "turn_id": "BK22001696-4",
            "utterance_id": "BK22001696.7"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "곧 감동적인 첫 심장 소리를 들을 수 있을 거예요. 그럼 임신 초기에 필요한 영양제는 잘 챙겨 먹고 있어요?",
            "turn_id": "BK22001696-4",
            "utterance_id": "BK22001696.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아니요. 첫 임신이라 정말 아무것도 몰라요. 임신 초기에 필요한 영양제가 따로 있나요?",
            "turn_id": "BK22001696-5",
            "utterance_id": "BK22001696.9"
        },
        {
            "reference_date": "2017-11-08",
            "reference_text": [
                {
                    "value": "엽산, 아연, 철분 등의 영양보충이 필수적이다.",
                    "value_time": "2022-07-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000308614",
            "search_query": "임신 초기 영양제",
            "terminate": false,
            "text": "필수적으로 섭취가 필요한 영양제는 엽산, 아연, 철분 정도예요.",
            "turn_id": "BK22001696-5",
            "utterance_id": "BK22001696.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오늘 당장 검색해 보고 주문해야겠어요.",
            "turn_id": "BK22001696-6",
            "utterance_id": "BK22001696.11"
        },
        {
            "reference_date": "2015-07-21",
            "reference_text": [
                {
                    "value": "임산부 영양제는 임신 12주까지 엽산제 최대 3개월분, 임신 16~20주부터 출산 전까지 철분제 최대 6개월분을 각각 제공한다.",
                    "value_time": "2022-07-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.kyeonggi.com/1001120",
            "search_query": "보건소 임산부 영양제 지원",
            "terminate": false,
            "text": "주문하시기 전에 거주 지역 보건소의 임산부 지원 사업 내용을 우선 살펴 보세요. 임신 초기에는 엽산제를 16주 이후부터는 철분제를 무료로 지원해 주거든요.",
            "turn_id": "BK22001696-6",
            "utterance_id": "BK22001696.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그런 사업도 있어요? 정말 너무 아는 게 없는 초보 엄마네요.",
            "turn_id": "BK22001696-7",
            "utterance_id": "BK22001696.13"
        },
        {
            "reference_date": "2022-07-03",
            "reference_text": [
                {
                    "value": "7월 1일부터 서울에 거주하는 모든 임산부에게 '1인당 70만 원'의 교통비 지원이 시작된다.",
                    "value_time": "2022-07-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.gukjenews.com/news/articleView.html?idxno=2500359",
            "search_query": "보건소 임산부 지원 사업",
            "terminate": false,
            "text": "지금 서울에 살고 계시죠? 그럼 교통비 지원도 함께 신청하세요. 7월 1일부터 서울에 살고 있는 모든 임산부에게 교통비로 사용할 수 있도록 70만 원을 지원하거든요.",
            "turn_id": "BK22001696-7",
            "utterance_id": "BK22001696.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "70만 원이라니 정말 큰 도움이 되겠어요. 몰라서 혜택을 놓칠 뻔했는데 이렇게 알려 주셔서 정말 감사해요.",
            "turn_id": "BK22001696-8",
            "utterance_id": "BK22001696.15"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "제가 달리 임신 선물도 못 드리는데 이런 거라도 확실하게 챙겨 드려야죠.",
            "turn_id": "BK22001696-8",
            "utterance_id": "BK22001696.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "정말 저에게 무엇보다 꼭 필요한 선물이에요. 저 감동받았어요.",
            "turn_id": "BK22001696-9",
            "utterance_id": "BK22001696.17"
        },
        {
            "reference_date": "2020-03-12",
            "reference_text": [
                {
                    "value": "임산부에게 좋은 음식으로는 토마토가 있다.",
                    "value_time": "2022-07-06",
                    "value_type": "variable"
                },
                {
                    "value": "토마토는 비타민, 미네랄, 라이코펜 등 몸에 좋은 영양소가 풍부하게 들어 있어 하루에 2~3개 정도 섭취하는 것이 좋으며 물을 잘 챙겨 먹지 않는 편이라면 토마토를 통해 수분 보충을 할 수 있고, 임신 초기에는 입덧 증상을 완화시키는데도 도움이 된다.",
                    "value_time": "2022-07-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nbntv.co.kr/news/articleView.html?idxno=216504",
            "search_query": "임신초기 좋은 음식",
            "terminate": false,
            "text": "이렇게 기뻐하시니 저도 기분 좋네요. 그런데 혹시 토마토 좋아하세요? 토마토가 임산부에게 정말 좋거든요. 입덧 증상을 줄여줄 뿐만 아니라 비타민, 미네랄, 라이코펜 등의 영양 섭취가 가능하고 동시에 수분도 보충되니 하루에 2, 3개 정도 챙겨 드세요.",
            "turn_id": "BK22001696-9",
            "utterance_id": "BK22001696.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "토마토가 그렇게 좋군요. 앞으로 꼭꼭 잘 챙겨서 먹을게요. 임신 초기는 특히 모든 것을 조심해야 한다고 하던데 언제쯤까지가 임신 초기인가요?",
            "turn_id": "BK22001696-10",
            "utterance_id": "BK22001696.19"
        },
        {
            "reference_date": "2022-04-20",
            "reference_text": [
                {
                    "value": "▲초기는 마지막 월경 시작일로부터 13주까지 ▲중기는 14주부터 28주까지 ▲말기는 29주부터 출산 전까지다.",
                    "value_time": "2022-07-06",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://health.chosun.com/site/data/html_dir/2022/04/20/2022042000971.html",
            "search_query": "임신초기 기간",
            "terminate": false,
            "text": "마지막 월경 시작일부터 계산해서 13주까지를 임신 초기라고 해요.",
            "turn_id": "BK22001696-10",
            "utterance_id": "BK22001696.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "3개월 정도는 많이 조심해야겠어요.",
            "turn_id": "BK22001696-11",
            "utterance_id": "BK22001696.21"
        },
        {
            "reference_date": "2019-11-25",
            "reference_text": [
                {
                    "value": "임신 초기 조심해야 할 것은 복부 자극에 주의하고, 유해 약물과 뜨거운 목욕, 방사선 촬영을 피해야 한다.",
                    "value_time": "2022-07-06",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nbntv.co.kr/news/articleView.html?idxno=752512",
            "search_query": "임신초기 주의사항",
            "terminate": false,
            "text": "네, 맞아요. 특히 복부에 자극이 가지 않도록 조심하고 태아에게 나쁜 영향을 끼칠 수 있는 약물 복용에도 주의해야 해요. 그리고 지나치게 뜨겁게 목욕하는 것, 방사선 촬영도 피해야 하고요.",
            "turn_id": "BK22001696-11",
            "utterance_id": "BK22001696.22"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알려주신 내용들 잘 기억해서 건강한 아기 만날 수 있도록 꼭 지킬게요. 소중한 정보 정말 감사해요.",
            "turn_id": "BK22001696-12",
            "utterance_id": "BK22001696.23"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "도움이 되어서 정말 기뻐요. 다시 한 번 임신 축하해요.",
            "turn_id": "BK22001696-12",
            "utterance_id": "BK22001696.24"
        }
    ]
}