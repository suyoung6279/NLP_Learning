    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "집에 새끼 강아지를 데려왔는데, 강아지 예방접종은 언제 해야 해?",
            "turn_id": "BK22012459-1",
            "utterance_id": "BK22012459.1"
        },
        {
            "reference_date": "43088.0",
            "reference_text": [
                {
                    "value": "강아지들은 어미 개 초유에서 면역항체를 공급받는다.",
                    "value_time": "44803.0",
                    "value_type": "constant"
                },
                {
                    "value": "그러나 생후 45일부터 어미 젖의 면역항체가 약해진다.",
                    "value_time": "44803.0",
                    "value_type": "constant"
                },
                {
                    "value": "이때부터 예방접종을 해야 한다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.news1.kr/articles/?3180971",
            "search_query": "강아지 예방접종 언제",
            "terminate": false,
            "text": "생후 45일부터 해야 해. 강아지들은 어미 개 초유에서 면역항체를 공급받는데, 생후 45일부터 어미젖의 면역항체가 약해지거든.",
            "turn_id": "BK22012459-1",
            "utterance_id": "BK22012459.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지가 맞아야 하는 예방접종의 종류는 어떤 게 있어?",
            "turn_id": "BK22012459-2",
            "utterance_id": "BK22012459.3"
        },
        {
            "reference_date": "44734.0",
            "reference_text": [
                {
                    "value": "강아지 예방 접종 중 ‘종합 5종’으로 불리는 종합백신(DHPPL)은 강아지에게 치명적일 수 있는 홍역, 전염성 간염, 파보 바이러스(장염), 파라 인플루엔자(Parainfluenza), 렙토스피라증(Leptospirasis)과 같은 다섯 가지 질병으로부터 강아지를 보호해 줄 수 있습니다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                },
                {
                    "value": "이외에도 사람과 동물이 함께 감염될 수 있는 광견병, 장염을 일으키는 코로나 바이러스, 기관지염, 감기와 같은 호흡기 바이러스 질환 등도 예방 접종을 통해 예방할 수 있습니다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/202206221550122844",
            "search_query": "강아지 예방 접종 종류",
            "terminate": false,
            "text": "홍역, 전염성 간염, 파보 바이러스, 파라 인플루엔자, 렙토스피라증 같은 다섯 가지 질병에 걸리지 않게 예방해서 종합 5종이라고 불리는 종합 백신이 있어. 그리고 광견병, 코로나바이러스, 기관지염, 호흡기 바이러스 질환인 감기같이 사람과 동물이 함께 감염될 수 있는 병도 접종을 통해 예방할 수 있어.",
            "turn_id": "BK22012459-2",
            "utterance_id": "BK22012459.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지도 예방접종을 꽤 많이 해야 하는구나. 어떤 주기로 몇 번 맞아야 해?",
            "turn_id": "BK22012459-3",
            "utterance_id": "BK22012459.5"
        },
        {
            "reference_date": "44734.0",
            "reference_text": [
                {
                    "value": "강아지 종합백신 5종(DHPPL)은 최초 1회 접종 후 2주 간격으로 총 5차례에 나누어 실시합니다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                },
                {
                    "value": "이 밖에 접종이 필요한 항목들은 수의사와 상의해 치밀하게 일정을 짜야 합니다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/202206221550122844",
            "search_query": "강아지 예방 접종 주기 횟수",
            "terminate": false,
            "text": "우선 종합백신 5종은 처음에 접종하고 나서 2주 간격으로 5번 나눠서 맞아야 하고 다른 접종이 필요한 주사는 수의사와 상의해서 일정을 짜면 돼.",
            "turn_id": "BK22012459-3",
            "utterance_id": "BK22012459.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 혹시 강아지도 예방접종 후에 부작용이 있어?",
            "turn_id": "BK22012459-4",
            "utterance_id": "BK22012459.7"
        },
        {
            "reference_date": "44145.0",
            "reference_text": [
                {
                    "value": "예방접종 후 대부분의 아이들은 괜찮지만, 간혹 접종 부위에 뭉침이나 붓기, 통증, 탈모 등의 증상이 있을 수 있다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                },
                {
                    "value": "또 식욕저하나 발열, 관절염 등이 나타날 수 있다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                },
                {
                    "value": "하루정도는 괜찮지만 3일째 지속된다면 접종한 병원에 내원하여 상담을 받는 것이 좋다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.sisunnews.co.kr/news/articleView.html?idxno=132846",
            "search_query": "강아지 예방접종 부작용",
            "terminate": false,
            "text": "많지는 않지만, 예방 접종 후에 간혹 접종 부위가 뭉치거나 붓고, 통증이 있거나 털이 빠지는 등의 증상이 있을 수 있어. 또 식욕이 없어지거나 열이 나거나 관절염 같은 증상도 있을 수 있는데 하루 정도는 괜찮지만 3일째 증상이 계속된다면 접종한 병원에 가서 상담받는 게 좋아.",
            "turn_id": "BK22012459-4",
            "utterance_id": "BK22012459.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "예방 접종 후에도 신경을 써줘야겠다. 예방 접종할 때 주의점이 있을까?",
            "turn_id": "BK22012459-5",
            "utterance_id": "BK22012459.9"
        },
        {
            "reference_date": "44145.0",
            "reference_text": [
                {
                    "value": "또, 접종 하루에서 이틀 전에는 과한 운동은 자제하는 것이 좋고 구토 증상이 나타날 수 있기 때문에 접종 3시간 전부터 과식은 금지해야 한다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                },
                {
                    "value": "접종을 한 후에는 목욕과 외출, 운동은 이틀에서 삼일정도 하지 말아야 한다다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.sisunnews.co.kr/news/articleView.html?idxno=132846",
            "search_query": "강아지 예방접종 주의점",
            "terminate": false,
            "text": "접종하기 하루, 이틀 전에는 과한 운동은 하지 않는 게 좋고 구토 증상이 있을 수 있어서 접종 세 시간 전부터는 과식하지 않게 해야 해. 그리고 접종하고 나서는 목욕이나 외출, 운동은 이틀에서 삼일은 하지 않는 게 좋아.",
            "turn_id": "BK22012459-5",
            "utterance_id": "BK22012459.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "접종 전후로 신경을 써줘야겠다. 예방 접종 후에 추가로 접종할 게 있어?",
            "turn_id": "BK22012459-6",
            "utterance_id": "BK22012459.11"
        },
        {
            "reference_date": "44734.0",
            "reference_text": [
                {
                    "value": "개와 고양이는 사람과 달리 1회 접종으로 평생 면역이 생기지 않습니다.",
                    "value_time": "44803.0",
                    "value_type": "constant"
                },
                {
                    "value": "매년 또는 항체 검사를 실시한 뒤 추가접종을 해주어야 합니다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/202206221550122844",
            "search_query": "강아지 예방접종 추가접종",
            "terminate": false,
            "text": "응, 사람은 1회 예방 접종으로 평생 면역이 생기지만, 개나 고양이는 한 번 접종한다고 평생 면역이 생기지 않거든. 그래서 면역이 생겼는지 매년 항체 검사를 하고 나서 추가 접종을 해줘야 해.",
            "turn_id": "BK22012459-6",
            "utterance_id": "BK22012459.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 강아지 예방접종을 주인이 직접 하는 사람도 있다고 들었는데 그래도 돼?",
            "turn_id": "BK22012459-7",
            "utterance_id": "BK22012459.13"
        },
        {
            "reference_date": "44670.0",
            "reference_text": [
                {
                    "value": "자가접종은 불법이기도 하지만 그것보다도 자가접종을 하다가 갑작스러운 이상이 생긴다면 이에 대처할 수가 없다는 점이 정말 안타깝다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=59017",
            "search_query": "강아지 예방접종 자가접종",
            "terminate": false,
            "text": "아니, 직접 예방접종을 하다가 강아지에게 갑자기 이상이 생긴다면 직접 대처할 수가 없어서 위험해. 그리고 무엇보다 자가 접종은 불법이야.",
            "turn_id": "BK22012459-7",
            "utterance_id": "BK22012459.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지 안전을 위해서 병원에 꼭 가야겠네. 마지막으로 물어볼 건 예방접종 비용이 얼마야?",
            "turn_id": "BK22012459-8",
            "utterance_id": "BK22012459.15"
        },
        {
            "reference_date": "44145.0",
            "reference_text": [
                {
                    "value": "강아지 예방접종은 1차부터 5차까지 20만 원 내외로 형성 되어 있는데 신종플루에 대비해 6차 접종까지 맞게 되면 대략 24만 원 내외가 된다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                },
                {
                    "value": "병원에 따라 조금씩 가격이 상이하지만 종합백신은 대략 2만 5천원정도 한다.",
                    "value_time": "44803.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.sisunnews.co.kr/news/articleView.html?idxno=132846",
            "search_query": "강아지 예방접종 비용",
            "terminate": false,
            "text": "병원마다 조금씩 가격이 다르긴 하지만 1차부터 5차까지는 20만원 내외이고, 종합백신은 대략 2만 5천원 정도야. 신종플루에 대비해서 6차 접종까지 하는 경우가 있는데 그럴 경우 대략 총 24만원 내외야.",
            "turn_id": "BK22012459-8",
            "utterance_id": "BK22012459.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아주 부담이 되는 가격은 아니네. 생후 45일이 지나면 접종하러 가야겠다.",
            "turn_id": "BK22012459-9",
            "utterance_id": "BK22012459.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래, 강아지를 위해서도, 강아지를 키우는 사람을 위해서도 예방접종은 정말 중요해.",
            "turn_id": "BK22012459-9",
            "utterance_id": "BK22012459.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "처음 키우는 거라 모르는 게 많았는데 알려줘서 고마워.",
            "turn_id": "BK22012459-10",
            "utterance_id": "BK22012459.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "더 물어볼 게 있다면 언제든지 물어보고 강아지 예쁘고 건강하게 잘 키웠으면 좋겠어.",
            "turn_id": "BK22012459-10",
            "utterance_id": "BK22012459.20"
        }
    ]
}