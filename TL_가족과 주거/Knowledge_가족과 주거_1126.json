    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저, 요즘 이사 때문에 고민이에요. 예산이 생각보다 넉넉지 않거든요.",
            "turn_id": "BK22007182-1",
            "utterance_id": "BK22007182.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇다면 행복주택을 알아보는 건 어떠세요?",
            "turn_id": "BK22007182-1",
            "utterance_id": "BK22007182.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "처음 들어보는데 행복주택이 어떤 건지 설명해주실 수 있으실까요?",
            "turn_id": "BK22007182-2",
            "utterance_id": "BK22007182.3"
        },
        {
            "reference_date": "2021-06-23",
            "reference_text": [
                {
                    "value": "청년(19세∼39세·신혼부부·대학생 등 젊은계층의 주거불안 해소를 위해 국가 재정과 주택도시기금을 지원받아 대중교통이 편리하고 직주근접이 가능한 부지에 주변시세보다 저렴하게 공급하는 공공임대주택",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.lh.or.kr/contents/cont.do?sCode=user&mPid=231&mId=232&menuYear",
            "search_query": "행복주택",
            "terminate": false,
            "text": "행복주택은 젊은 계층들의 주거 불안을 해결해주기 위해서 국가 재정과 주택도시기금을 지원받아 대중교통이 편하고 직주근접이 가능한 곳에 주변시세보다 저렴하게 공급하는 공공임대주택이에요.",
            "turn_id": "BK22007182-2",
            "utterance_id": "BK22007182.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어머, 그런 게 있는 줄 몰랐어요. 입주할 수 있는 대상이 어떻게 되나요?",
            "turn_id": "BK22007182-3",
            "utterance_id": "BK22007182.5"
        },
        {
            "reference_date": "2022-06-11",
            "reference_text": [
                {
                    "value": "행복주택은 대학생, 신혼부부, 사회초년생 등 젊은층과 고령층의 주거안정을 위해 도입된 공공임대주택이다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.kukinews.com/newsView/kuk202206080212",
            "search_query": "행복주택 입주대상",
            "terminate": false,
            "text": "아, 행복주택은 대학생, 신혼부부, 사회초년생 등 젊 은층과 고령층이 입주 대상이에요.",
            "turn_id": "BK22007182-3",
            "utterance_id": "BK22007182.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오, 입주 대상이 다양하네요? 그러면 신청할 수 있는 소득 기준이 따로 있나요?",
            "turn_id": "BK22007182-4",
            "utterance_id": "BK22007182.7"
        },
        {
            "reference_date": "2022-08-28",
            "reference_text": [
                {
                    "value": "행복주택은 월평균 소득이 전체 도시근로자 월평균 소득의 100% 이하인 대학생, 청년, 신혼부부, 65세 이상 고령자만 입주할 수 있다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/realestate/view/2022/08/759901/",
            "search_query": "행복주택 소득기준",
            "terminate": false,
            "text": "맞아요. 소득 기준이 있는데 행복주택은 월평균 소득이 전체 도시근로자 월평균 소득의 100% 이하라면 신청이 가능해요.",
            "turn_id": "BK22007182-4",
            "utterance_id": "BK22007182.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아까 주변 시세보다 저렴하다고 하셨는데 그렇다면 대략 어느 정도나 저렴한가요?",
            "turn_id": "BK22007182-5",
            "utterance_id": "BK22007182.9"
        },
        {
            "reference_date": "2022-08-30",
            "reference_text": [
                {
                    "value": "국민임대주택과 행복주택은 시세의 60~80% 수준의 임대료로 공급된다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.straightnews.co.kr/news/articleView.html?idxno=216298",
            "search_query": "행복주택 주변시세",
            "terminate": false,
            "text": "행복주택은 시세의 60%에서 80% 정도의 임대료로 제공되고 있어요.",
            "turn_id": "BK22007182-5",
            "utterance_id": "BK22007182.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우와, 정말 괜찮은 조건인데요? 그렇다면 거주할 수 있는 기간은 최대 얼마까지인가요?",
            "turn_id": "BK22007182-6",
            "utterance_id": "BK22007182.11"
        },
        {
            "reference_date": "2020-05-02",
            "reference_text": [
                {
                    "value": "대학생·청년은 최대 6년, 신혼부부는 최대 10년, 고령자·주거급여수급자는 최대 20년까지 거주가 가능하다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.m-economynews.com/news/article.html?no=28543",
            "search_query": "행복주택 최장 기간",
            "terminate": false,
            "text": "우선, 거주 기간은 계층별로 다른데 대학생과 청년은 최대 6년, 신혼부부는 최대 10년까지 가능하고 고령자와 주거 급여수급자는 최대 20년까지 거주가 가능하답니다.",
            "turn_id": "BK22007182-6",
            "utterance_id": "BK22007182.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "국민 임대주택이랑 비슷한 거 아니에요? 어떤 차이가 있을까요?",
            "turn_id": "BK22007182-7",
            "utterance_id": "BK22007182.13"
        },
        {
            "reference_date": "2021-07-05",
            "reference_text": [
                {
                    "value": "기본적으로 행복주택은 국민임대주택의 하위 분류로, 일반적인 사항은 국민임대주택과 크게 다르지 않습니다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                },
                {
                    "value": "그러나 국민임대주택이 일반 국민들과 사회적 약자층을 대상으로 하는 것과 달리 행복주택은 대학생, 사회초년생, 그리고 신혼부부, 고령자, 주거급여수급자, 산업단지근로자로 입주대상을 한정하고 있기 때문에 세부적인 부분에서 다소 차이가 있습니다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.ggilbo.com/news/articleView.html?idxno=856557",
            "search_query": "행복주택과 국민임대주택",
            "terminate": false,
            "text": "국민임대주택의 하위분류이기 때문에 크게 다르지는 않아요. 다만, 국민임대주택은 일반 국민들과 사회적 약자층을 대상으로 하지만 행복주택은 대학생, 사회초년생, 신혼부부와 고령자, 주거 급여수급자 등 입주 대상을 한정하고 있어 세부적인 면에서 차이가 있어요.",
            "turn_id": "BK22007182-7",
            "utterance_id": "BK22007182.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오, 차이를 잘 알겠어요. 그런데 이런 행복주택에도 단점이 있나요?",
            "turn_id": "BK22007182-8",
            "utterance_id": "BK22007182.15"
        },
        {
            "reference_date": "2021-07-05",
            "reference_text": [
                {
                    "value": "한편 행복주택의 단점으로 협소한 주차공간, 비싼 관리비, 짧은 거주기간을 꼽을 수 있습니다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.ggilbo.com/news/articleView.html?idxno=856557",
            "search_query": "행복주택 장점 단점",
            "terminate": false,
            "text": "아, 단점이라면 좁은 주차 공간과 비싼 관리비, 그리고 짧은 거주 기간을 예로 들 수 있어요.",
            "turn_id": "BK22007182-8",
            "utterance_id": "BK22007182.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "장단점이 확실하네요! 모집공고를 알아보고 싶은데 어디서 확인할 수 있을까요?",
            "turn_id": "BK22007182-9",
            "utterance_id": "BK22007182.17"
        },
        {
            "reference_date": "2019-02-18",
            "reference_text": [
                {
                    "value": "행복주택 입주자 모집공고는 사업주체(한국토지주택공사, 지방공사 등)의 홈페이지 등을 통해서 확인이 가능하다.",
                    "value_time": "2022-09-02",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.gokorea.kr/news/articleView.html?idxno=100999",
            "search_query": "행복주택 신청방법 공고",
            "terminate": false,
            "text": "행복주택 입주자 모집공고는 한국토지주택공사, 지방공사 등 사업 주체의 홈페이지를 통해서 확인할 수 있어요.",
            "turn_id": "BK22007182-9",
            "utterance_id": "BK22007182.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "감사해요. 오늘 너무 친절하게 알려주셔서 덕분에 잘 신청할 수 있을 것 같은걸요? 다음에 또 여쭤볼 일이 있으면 부탁드려도 될까요?",
            "turn_id": "BK22007182-10",
            "utterance_id": "BK22007182.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼요. 어려운 것도 아니니 편하실 때 언제든지 연락해주세요. 신청하시다가 모르는 부분 있으면 연락해주세요!",
            "turn_id": "BK22007182-10",
            "utterance_id": "BK22007182.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "그럼 마음 편히 또 연락드릴게요. 오늘 이야기 나눠서 정말 즐거웠어요.",
            "turn_id": "BK22007182-11",
            "utterance_id": "BK22007182.21"
        }
    ]
}