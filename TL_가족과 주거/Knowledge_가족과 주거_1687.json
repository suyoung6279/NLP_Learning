    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "미국 드라마 같은 걸 보면 친척들에 대한 호칭이 간단해 보이던데, 한국은 너무 많은 것 같아. 대체 어디서 유래된 거야?",
            "turn_id": "BK22012273-1",
            "utterance_id": "BK22012273.1"
        },
        {
            "reference_date": "44633.0",
            "reference_text": [
                {
                    "value": "근친 간 호칭법(近親間呼稱法)은 한국에서 전통적으로 근친을 부르는 호칭어(부름말)를 다르게 함을 가리킨다.",
                    "value_time": "44780.0",
                    "value_type": "constant"
                },
                {
                    "value": "이 호칭법은 중국에서 유학과 함께 전래되었으며, 한자어 호칭은 대부분 중국의 것과 비슷하다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://ko.wikipedia.org/wiki/%ED%95%9C%EA%B5%AD%EC%9D%98_%EA%B7%BC%EC%B9%9C%EA%B0%84_%ED%98%B8%EC%B9%AD%EB%B2%95",
            "search_query": "한국 근친 호칭",
            "terminate": false,
            "text": "한국에서 전통적으로 근친을 칭하는 표현인 근친 간 호칭법을 말하는구나. 이 호칭법은 유학과 함께 중국에서 왔고, 한자어 호칭은 중국에서 사용하는 것과 거의 같아.",
            "turn_id": "BK22012273-1",
            "utterance_id": "BK22012273.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "너무 어려운데 차근차근히 알려줄 수 있을까? 아내의 오빠랑 동생부터 알려줘.",
            "turn_id": "BK22012273-2",
            "utterance_id": "BK22012273.3"
        },
        {
            "reference_date": "42762.0",
            "reference_text": [
                {
                    "value": "전통적으로 아내의 남자 형제들에 대해서는 아내의 오빠인지, 동생인지 따지지 않고 '처남'으로 불러왔다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.kbs.co.kr/news/view.do?ncd=3419042&ref=A",
            "search_query": "아내의 남자 형제",
            "terminate": false,
            "text": "전통적으로 보면 아내의 남자 형제들을 부를 때는 아내의 오빠나 동생임을 가리지 않고 처남으로 불러.",
            "turn_id": "BK22012273-2",
            "utterance_id": "BK22012273.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 아내의 여자 형제들은 어떻게 불러?",
            "turn_id": "BK22012273-3",
            "utterance_id": "BK22012273.5"
        },
        {
            "reference_date": "42762.0",
            "reference_text": [
                {
                    "value": "아내의 여자 형제들은 손위 여부에 따라 처형과 처제로 구별해 부른다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "아내 언니의 남편은 형님(연장자) 또는 동서(연하)로 부르면 된다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.kbs.co.kr/news/view.do?ncd=3419042&ref=A",
            "search_query": "아내의 여자 형제",
            "terminate": false,
            "text": "아내의 손위이거나 손아래냐에 따라 처형과 처제로 구별해서 부르면 돼. 아내 언니의 남편은 형님이라 부르면 되고, 아내 동생의 남편은 동서라고 하면 돼.",
            "turn_id": "BK22012273-3",
            "utterance_id": "BK22012273.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 남편의 형이나 배우자는?",
            "turn_id": "BK22012273-4",
            "utterance_id": "BK22012273.7"
        },
        {
            "reference_date": "42762.0",
            "reference_text": [
                {
                    "value": "남편의 형은 아주버님, 배우자는 형님으로 부른다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "남편의 남동생은 혼인 여부에 따라 도련님(미혼) 혹은 서방님(기혼)으로 호칭한다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "남편 남동생의 아내는 동서다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.kbs.co.kr/news/view.do?ncd=3419042&ref=A",
            "search_query": "남편 형 동생 호칭",
            "terminate": false,
            "text": "남편의 형은 아주버님, 부인은 형님이라 부르고, 남편의 남동생은 결혼을 유무에 따라 결혼을 안 했으면 도련님, 결혼을 했으면 서방님으로 불러. 그리고 남편 남동생의 부인은 동서라고 하면 돼.",
            "turn_id": "BK22012273-4",
            "utterance_id": "BK22012273.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 남편의 여자 형제는 어떻게 불러?",
            "turn_id": "BK22012273-5",
            "utterance_id": "BK22012273.9"
        },
        {
            "reference_date": "42762.0",
            "reference_text": [
                {
                    "value": "남편의 누나는 형님으로 부르고 동생이면 아가씨라 부르면 된다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.kbs.co.kr/news/view.do?ncd=3419042&ref=A",
            "search_query": "남편 누나 동생 호칭",
            "terminate": false,
            "text": "남편의 여동생은 아가씨라고 하고, 누나는 형님이라고 하면 돼",
            "turn_id": "BK22012273-5",
            "utterance_id": "BK22012273.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 남편의 큰 아버지나 작은 아버지는 어떻게 부르면 돼?",
            "turn_id": "BK22012273-6",
            "utterance_id": "BK22012273.11"
        },
        {
            "reference_date": "42762.0",
            "reference_text": [
                {
                    "value": "양가의 큰 아버지나 외할아버지, 외할머니 등의 기타 친인척에 대한 호칭으로 상식적으로 판단해 부르면 된다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "큰아버지는 큰아버님, 작은 아버지는 작은 아버님으로 호칭한다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "외조부모의 경우 그냥 할아버님, 또는 할머님이라고 부르면 자연스럽다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.kbs.co.kr/news/view.do?ncd=3419042&ref=A",
            "search_query": "남편 큰 아버지 호칭",
            "terminate": false,
            "text": "양가의 큰 아버지나 외할아버지, 외할머니 같은 기타 친인척을 부르는 호칭은 그냥 상식적인 선에서 판단해서 부르면 돼. 예를 들면 큰 아버지는 큰아버님, 작은아버지는 작은아버님 이런 식으로 말이야. 외조부모님은 할아버님, 할머님 등으로 부르면 돼.",
            "turn_id": "BK22012273-6",
            "utterance_id": "BK22012273.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아버지의 형제자매를 부르는 말들도 알려줄래?",
            "turn_id": "BK22012273-7",
            "utterance_id": "BK22012273.13"
        },
        {
            "reference_date": "41889.0",
            "reference_text": [
                {
                    "value": "아버지의 형은 큰아버지(백부), 큰아버지의 부인은 큰어머니(백모), 아버지의 남동생은 작은아버지(숙부), 작은아버지의 부인은 작은어머니(숙모)라고 부른다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.headlinejeju.co.kr/news/articleView.html?idxno=220024",
            "search_query": "아버지 형 동생 호칭",
            "terminate": false,
            "text": "아버지의 형은 큰아버지 즉 백부가 되고, 큰아버지의 부인은 큰 어머니 즉 백모가 돼. 그리고 아버지의 남동생과 그 부인은 작은아버지, 작은어머니 또는 숙부, 숙모로 호칭하면 돼",
            "turn_id": "BK22012273-7",
            "utterance_id": "BK22012273.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "당연하지만 어머니의 형제자매를 부르는 말은 따로겠지?",
            "turn_id": "BK22012273-8",
            "utterance_id": "BK22012273.15"
        },
        {
            "reference_date": "41889.0",
            "reference_text": [
                {
                    "value": "어머니의 남자 형제는 외삼촌(외숙), 외삼촌의 부인은 외숙모고 어머니의 여자 자매는 이모, 이모의 남편은 이모부라 부른다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.headlinejeju.co.kr/news/articleView.html?idxno=220024",
            "search_query": "어머니 남자 형제 자매 호칭",
            "terminate": false,
            "text": "맞아. 어머니의 남자 형제는 외삼촌이나 외숙, 외삼촌의 부인은 외숙모라고 하면 돼. 어머니의 여자 자매는 이모가 되는 거고, 그 남편은 이모부라 호칭하면 돼.",
            "turn_id": "BK22012273-8",
            "utterance_id": "BK22012273.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "내 형제자매가 낳은 자식은 어떻게 부르지?",
            "turn_id": "BK22012273-9",
            "utterance_id": "BK22012273.17"
        },
        {
            "reference_date": "42761.0",
            "reference_text": [
                {
                    "value": "조카를 호칭할 때는 질(姪)을 사용한다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "나의 친형제의 자녀일 경우 평소처럼 조카(姪)라 부르면 된다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                },
                {
                    "value": "4촌형제의 자녀는 종질(從姪), 6촌형제의 자녀는 재종질(再從姪)이 된다.",
                    "value_time": "44780.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.jemin.com/news/articleView.html?idxno=428801",
            "search_query": "친형제 자녀 호칭",
            "terminate": false,
            "text": "친형제의 자녀는 조카라고 부르면 돼. 다만 4촌 형제의 자녀는 종질, 6촌 형제의 자녀는 재종질이라 호칭하는 게 맞아. 조카를 호칭할 때는 질을 사용하거든.",
            "turn_id": "BK22012273-9",
            "utterance_id": "BK22012273.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "여가부에서 저런 호칭들을 바꾸자고 새로운 가족 호칭을 제안했다던데?",
            "turn_id": "BK22012273-10",
            "utterance_id": "BK22012273.19"
        },
        {
            "reference_date": "43716.0",
            "reference_text": [
                {
                    "value": "여가부는 추가로 사용할 수 있는 가족 호칭의 예로 배우자의 부모의 경우 '아버님·아버지' 또는 '어머님·어머니'로, 배우자의 손아래 동기는 '이름(+씨)'으로, 자녀의 조부모는 '할아버지·할머니' 등을 제시했다",
                    "value_time": "44780.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.ajunews.com/view/20190906095214074",
            "search_query": "여가부 가족 호칭",
            "terminate": false,
            "text": "맞아. 새로이 사용할 수 있는 가족 호칭으로 심플하게 아버님, 아버지 및 어머니, 어머님 그리고 배우자 손 아래 동기 이름에 씨를 붙여서 부르는 방법, 조부모님은 단순히 할아버지, 할머니로 부르자고 제안했어.",
            "turn_id": "BK22012273-10",
            "utterance_id": "BK22012273.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어려운 표현이 많으니 점점 호칭을 편하게 쓰려는 거 같아.",
            "turn_id": "BK22012273-11",
            "utterance_id": "BK22012273.21"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "그래 어떻게 될지는 지켜봐야겠지만 말이야.",
            "turn_id": "BK22012273-11",
            "utterance_id": "BK22012273.22"
        }
    ]
}