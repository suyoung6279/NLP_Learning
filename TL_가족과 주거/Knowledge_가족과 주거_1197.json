    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나도 이제 내 집 마련의 꿈을 한 단계씩 이뤄보려고 해!",
            "turn_id": "BK22007857-1",
            "utterance_id": "BK22007857.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알찬 계획이네, 하나씩 준비해 나가다 보면 금세 꿈을 이룰 수 있을 거야!",
            "turn_id": "BK22007857-1",
            "utterance_id": "BK22007857.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "일단 지금은 신혼부부 특별공급부터 알아보려고. 신혼부부 특별공급의 자격 요건이 어떻게 돼?",
            "turn_id": "BK22007857-2",
            "utterance_id": "BK22007857.3"
        },
        {
            "reference_date": "2019-07-01",
            "reference_text": [
                {
                    "value": "신혼부부 특별공급 자격은 7년 이내의 신혼부부로 부부 모두 무주택자여야 한다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "아울러, 소득 및 자산 기준을 충족해야 한다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.gokorea.kr/news/articleView.html?idxno=257746",
            "search_query": "신혼부부 특별공급 자격",
            "terminate": false,
            "text": "신혼부부 특별공급 제도는 7년 이내의 신혼부부에게 자격이 주어져. 또한, 부부 두 사람 모두 무주택자여야 하고 소득과 자산 기준을 충족해야 하지.",
            "turn_id": "BK22007857-2",
            "utterance_id": "BK22007857.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "신혼의 기간을 7년으로 정한 거구나. 혹시 신혼부부 특별공급 때문에 혼인신고를 미루는 부부들도 있어?",
            "turn_id": "BK22007857-3",
            "utterance_id": "BK22007857.5"
        },
        {
            "reference_date": "2021-03-14",
            "reference_text": [
                {
                    "value": "혼인기간의 결혼 기간이 짧을수록 점수가 높다는 점 역시 젊은 부부들이 혼인신고를 연기하는 이유 중 하나다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "혼인신고 가점 부여 역시 혼인신고일을 기준으로 하고 있다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "현재 모집공고일에서 혼인신고일까지의 기간이 3년 이하인 경우는 3점, 3~5년 미만이면 2점, 5~7년 미만인 경우는 1점이 주어진다.",
                    "value_time": "2022-09-08",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.econovill.com/news/articleView.html?idxno=523109",
            "search_query": "신혼부부 특별공급 혼인신고 연기",
            "terminate": false,
            "text": "응, 결혼 기간이 짧을수록 높은 점수를 받을 수 있거든. 이는 젊은 부부들이 혼인신고를 미루는 이유 중 하나이기도 하지. 혼인신고 가점 부여 또한 혼인신고일을 기준으로 정해지는데, 기간에 따라 점수가 달라져. 모집공고일에서 혼인신고일까지의 기간이 3년 이하인 경우에는 3점, 3년에서 5년 미만일 시 2점, 5년에서 7년 미만일 시에는 1점이 주어지지.",
            "turn_id": "BK22007857-3",
            "utterance_id": "BK22007857.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "기간에 따라 점수가 달라지다니, 신기하네. 혼인 기간 외에 받을 수 있는 신혼부부 특별공급 가점 항목도 있어?",
            "turn_id": "BK22007857-4",
            "utterance_id": "BK22007857.7"
        },
        {
            "reference_date": "2019-07-01",
            "reference_text": [
                {
                    "value": "신혼부부 특별공급 가점에 해당하는 항목으로는 미성년 자녀 수, 해당 지역 거주 기간 등이 있다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.gokorea.kr/news/articleView.html?idxno=257746",
            "search_query": "신혼부부 특별공급 가점 항목",
            "terminate": false,
            "text": "응, 미성년 자녀 수나 해당 지역 거주 기간 등을 통해 신혼부부 특별공급 가점을 받을 수 있어.",
            "turn_id": "BK22007857-4",
            "utterance_id": "BK22007857.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 만약 다른 신혼부부 특별공급 조건에는 다 해당되는 데 소득 기준에 초과하면 어떻게 돼?",
            "turn_id": "BK22007857-5",
            "utterance_id": "BK22007857.9"
        },
        {
            "reference_date": "2022-08-08",
            "reference_text": [
                {
                    "value": "소득이 초과하는 경우 부동산가액 기준을 충족하는 경우 추첨의 방법으로 공급하기 때문에 기본적으로 소득이 낮을수록 유리하고 소득요건이 맞으면 자녀가 많을수록 유리하다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "신혼부부 특별공급은 혼인 기간이 7년 이내인 신혼부부가 대상이며 소득 기준에 따라 먼저 우선공급 대상자와 일반공급 대상자를 나눈다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.asiatoday.co.kr/view.php?key=20220808010004704",
            "search_query": "신혼부부 특별공급 소득 초과",
            "terminate": false,
            "text": "결혼 기간이 7년 안쪽인 신혼부부 중에서도, 소득 기준에 따라서 우선 공급 대상자와 일반공급 대상자로 나뉘어져. 만약 소득 기준을 초과한다면, 부동산 가액 기준에 충족될 시 추첨 방법으로 공급하지. 그래서 기본적으로 소득이 낮을수록 유리해. 소득요건이 맞는다면 자녀가 많을수록 더 유리해지고.",
            "turn_id": "BK22007857-5",
            "utterance_id": "BK22007857.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "여러 가지 요건에 따라 결과가 달라지겠구나. 혹시 올해는 청년이나 신혼부부 특별공급 물량은 어떻게 돼?",
            "turn_id": "BK22007857-6",
            "utterance_id": "BK22007857.11"
        },
        {
            "reference_date": "2022-01-03",
            "reference_text": [
                {
                    "value": "국토교통부의 올해 업무 추진계획에 따르면, 청년과 신혼부부 특별공급 물량(예측치)은 작년의 2배가량인 13만 5천 호에 달한다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nocutnews.co.kr/news/5682700",
            "search_query": "신혼부부 특별공급 물량",
            "terminate": false,
            "text": "이번해 국토교통부의 업무 추진계획에 따르면, 청년과 신혼부부 특별공급 물량은 13만 5천 호에 달해. 이는 지난해 물량의 2배가량이지.",
            "turn_id": "BK22007857-6",
            "utterance_id": "BK22007857.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "좋은 소식이네, 그나저나 신혼부부 말고 다른 특별공급 유형에는 어떤 것들이 있어?",
            "turn_id": "BK22007857-7",
            "utterance_id": "BK22007857.13"
        },
        {
            "reference_date": "2022-06-12",
            "reference_text": [
                {
                    "value": "특별공급 유형은 다양하다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "△생애최초 △신혼부부 △다자녀 △노부모 △기관추천 등이 있다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "우선 기관추천은 국가유공자, 장애인, 중소기업근로자, 군인, 북한이탈주민을 대상으로 신청할 수 있다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.edaily.co.kr/news/read?newsId=01987686632361064&mediaCodeNo=257&OutLnkChk=Y",
            "search_query": "특별공급 유형",
            "terminate": false,
            "text": "신혼부부 특별공급 외에도 특별공급 유형은 다양해. 생애 최초, 노부모, 다자녀, 그리고 기관추천 등이 있지. 특히 기관추천의 경우에는 국가유공자, 중소기업근로자, 장애인, 북한이탈주민, 군인을 대상으로 신청할 수 있는 특별공급 제도야.",
            "turn_id": "BK22007857-7",
            "utterance_id": "BK22007857.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "내가 몰랐던 특별공급 유형들이 많았구나. 그중에서 생애 최초 특별공급은 한 번쯤 들어본 것 같은데, 신청 자격이 어떻게 돼?",
            "turn_id": "BK22007857-8",
            "utterance_id": "BK22007857.15"
        },
        {
            "reference_date": "2022-08-08",
            "reference_text": [
                {
                    "value": "생애최초 특별공급은 청약자 본인을 포함해 세대 구성원 모두 과거 주택을 소유한 사실이 없어야 한다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "다만 직계존속 60세 이상이 소유한 주택은 대상에서 제외된다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.asiatoday.co.kr/view.php?key=20220808010004704",
            "search_query": "생애최초 특별공급",
            "terminate": false,
            "text": "생애 최초 특별공급은 청약자 본인을 포함하여 세대 구성원 모두 과거에 주택을 소유했던 사실이 없어야 신청할 수 있어. 다만, 직계존속 가족 중 60세 이상이 과거에 주택을 소유했던 사실은 포함되지 않지.",
            "turn_id": "BK22007857-8",
            "utterance_id": "BK22007857.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 그리고 신혼부부들에게 특화된 신혼희망타운이라는 것도 있던데. 그건 어떤 특징을 갖고 있어?",
            "turn_id": "BK22007857-9",
            "utterance_id": "BK22007857.17"
        },
        {
            "reference_date": "2022-02-21",
            "reference_text": [
                {
                    "value": "신혼희망타운은 문재인정부에서 2018년부터 공급된 신혼부부 특화형 공공주택이다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                },
                {
                    "value": "연 1.3% 고정금리로 집값의 70%까지 대출해주는 전용 모기지 상품을 제공해주는 대신 입주자는 향후 주택을 매도할 때 대출금 상환과 더불어 시세차익의 최대 50%를 주택도시기금에 납부해야 하는 점이 특징이다.",
                    "value_time": "2022-09-08",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/realestate/view/2022/02/165816/",
            "search_query": "신혼희망타운",
            "terminate": false,
            "text": "신혼희망타운은 2018년도부터 공급되기 시작했어. 문재인 정부 때 탄생한 신혼부부 특화형 공공주택이지. 입주자는 연 1.3퍼센트의 고정금리로 집값의 70퍼센트까지 대출받을 수 있는 전용 모기지 상품을 받는 대신에 향후 주택 매도 시 대출금 상환과 함께 시세차익의 최대 50퍼센트를 주택도시기금에 납부해야 한다는 것이 주요 특징이야.",
            "turn_id": "BK22007857-9",
            "utterance_id": "BK22007857.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "이해에 큰 도움이 되었어. 오늘 설명해준 내용들 다 참고해서 알아볼게. 고마워!",
            "turn_id": "BK22007857-10",
            "utterance_id": "BK22007857.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "도움이 되었다니 다행이네, 꼼꼼하게 준비해나가서 좋은 소식 있길 바랄게!",
            "turn_id": "BK22007857-10",
            "utterance_id": "BK22007857.20"
        }
    ]
}