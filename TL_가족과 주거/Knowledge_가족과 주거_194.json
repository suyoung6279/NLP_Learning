    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나폴리로 가족 여행 가기로 해서 계획을 세워야 하는데 좀 도와줘. 먼저, 나폴리가 어떤 곳인지부터 알려 줄래?",
            "turn_id": "BK22014675-1",
            "utterance_id": "BK22014675.1"
        },
        {
            "reference_date": "2014-07-20",
            "reference_text": [
                {
                    "value": "이탈리아 캄파니아주의 주도인 나폴리는 카프리섬과 폼베이 유적으로 가는 관문으로 유명하다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "고대 그리스인들이 삶의 터전을 일궜던 곳으로 지금까지도 그 문화가 고스란히 남아 있어 색다른 분위기를 경험할 수 있는 게 특징이다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2014/07/1010359/",
            "search_query": "나폴리",
            "terminate": false,
            "text": "가족들과 나폴리로 여행 가기로 했구나. 이탈리아 캄파니아 주의 주도인 나폴리는 폼페이 유적을 관광하러 가거나 카프리섬에 가기 위해서도 거쳐야 하는 곳이지. 고대 그리스인들이 살던 곳이어서 지금도 그 문화를 엿볼 수 있는 지역이기도 하고.",
            "turn_id": "BK22014675-1",
            "utterance_id": "BK22014675.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나폴리에 고대 그리스인들이 살았었구나. 그러면, 나폴리에서 관광해야 할 곳들도 설명해 줘.",
            "turn_id": "BK22014675-2",
            "utterance_id": "BK22014675.3"
        },
        {
            "reference_date": "2015-09-25",
            "reference_text": [
                {
                    "value": "그 중 플레비시토 광장은 나폴리의 중요 공식행사가 열리는 도시의 중심광장이다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "중앙에 크게 자리잡고 있는 건축물은 산 프란체스코 디 파올라 성당.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "로마의 판테온을 모델로 하여 1846년 완공한 건축물이다.",
                    "value_time": "2022-10-01",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.koreadaily.com/2015/09/25/society/opinion/3704609.html",
            "search_query": "나폴리 플레비시토 광장",
            "terminate": false,
            "text": "플레비시토 광장은 나폴리의 중요한 공식 행사가 열리는 곳으로, 광장 중앙에는 로마의 판테온을 모델로 해서 1846년에 건축된 산 프란체스코 디 파올라 성당이 있어.",
            "turn_id": "BK22014675-2",
            "utterance_id": "BK22014675.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "판테온을 모델로 한 성당이 어떤 모습일지 궁금하네. 그리고, 관광할 곳을 더 설명해 줘.",
            "turn_id": "BK22014675-3",
            "utterance_id": "BK22014675.5"
        },
        {
            "reference_date": "2014-07-20",
            "reference_text": [
                {
                    "value": "누오보성은 13세기 프랑스 앙주 왕가의 성으로 건설됐다.",
                    "value_time": "2022-10-01",
                    "value_type": "constant"
                },
                {
                    "value": "1266년 왕위에 오른 앙주의 카를로 1세가 나폴리 왕국 수도를 팔레르모에서 나폴리로 옮긴 후 바다가 가까운 곳에 새로운 성을 세우라고 명령했다고 한다.",
                    "value_time": "2022-10-01",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2014/07/1010359/",
            "search_query": "나폴리 누오보 성당",
            "terminate": false,
            "text": "프랑스의 앙주 왕가의 성으로 13세기에 건축한 성인 누오보성이 있어. 이 성은 바닷가 가까이 위치하고 있는데, 그 이유는 1266년 앙주의 왕이 된 카를로 1세가 팔레르모에서 나폴리로 나폴리 왕국의 수도를 옮기면서 바다가 가까이 성을 지으라고 명령했기 때문이야.",
            "turn_id": "BK22014675-3",
            "utterance_id": "BK22014675.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "바다가 가까운 곳에 있는 성이라면 더 운치 있겠다. 그리고, 나폴리는 높은 곳에서 내려다보는 풍경이 좋다는데, 어떻게 하면 높은 지대로 갈 수 있어?",
            "turn_id": "BK22014675-4",
            "utterance_id": "BK22014675.7"
        },
        {
            "reference_date": "2019-06-26",
            "reference_text": [
                {
                    "value": "고지대를 오르기 위한 푸니쿨라는 나폴리의 명물 중 하나다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "총 세 대가 운영되고 있는데 최초는 1880년에 설치된 것이라 하니 운치도 있다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "가장 인기 있는 푸니쿨라는 몬테산토역에 위치한 것으로, 이유는 아래 동네인 스파카 나폴리(Spacca Napoli)를 내려다볼 수 있어서다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.mk.co.kr/news/culture/view/2019/06/458810/",
            "search_query": "나폴리 푸니쿨라",
            "terminate": false,
            "text": "고지대에 가려면 푸니쿨라를 타면 돼. 최초의 푸니쿨라는 1880년에 설치된 것으로, 현재 푸니쿨라는 총 세 대가 운영되고 있어. 그중 사람들에게 스파카 나폴리를 내려다볼 수 있어 인기 있는 푸니쿨라는 몬테산토역에 있는 거야.",
            "turn_id": "BK22014675-4",
            "utterance_id": "BK22014675.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나폴리에 가면 꼭 푸니쿨라는 타봐야겠네. 근데, 스파카 나폴리가 어떤 곳이길래 사람들이 그곳을 보는 푸니쿨라를 많이 탄다는 거야?",
            "turn_id": "BK22014675-5",
            "utterance_id": "BK22014675.9"
        },
        {
            "reference_date": "2019-12-11",
            "reference_text": [
                {
                    "value": "나폴리의 오랜 전통과 서민들의 삶을 엿볼 수 있는 스파카나폴리(spaccanapoli)는 나폴리가 네아폴리스이던 시절부터 서민의 주거지역이었던 곳이다.",
                    "value_time": "2022-10-01",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.tournews21.com/news/articleView.html?idxno=40497",
            "search_query": "나폴리 스파카나폴리",
            "terminate": false,
            "text": "스파카 나폴리는 나폴리의 오랜 전통과 서민들이 사는 모습을 볼 수 있는 곳이야. 이곳은 나폴리가 네아폴리스 시절부터 서민들이 거주하던 곳이거든.",
            "turn_id": "BK22014675-5",
            "utterance_id": "BK22014675.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "스파카 폴리나는 사람 냄새나는 곳이구나. 근데, 나폴리는 오페라로도 유명한 곳인데, 오페라를 볼만한 곳도 있을까?",
            "turn_id": "BK22014675-6",
            "utterance_id": "BK22014675.11"
        },
        {
            "reference_date": "2019-01-28",
            "reference_text": [
                {
                    "value": "산카를로 가극장(Teatro di San Carlo)은 나폴레타나로 숙성된 이탈리아 오페라의 중심이다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "1737년 도메니코 사로의 오페라 <스키로의 아킬레우스> 공연을 시작으로 문을 연 산카를로 가극장은 모든 오페라 작곡자나 성악가가 꿈에 그리는 무대다.",
                    "value_time": "2022-10-01",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://magazine.hankyung.com/money/article/202101204402c",
            "search_query": "산카를로 가극장",
            "terminate": false,
            "text": "이탈리아 오페라의 중심인 산카를로 가극장이 있어. 1737년 도메니코 사로의 오페라인 스키로의 아킬레우스를 공연하며 문을 연 곳으로, 오페라의 작곡자나 성악가들이 오르고 싶어 하는 무대이지.",
            "turn_id": "BK22014675-6",
            "utterance_id": "BK22014675.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "볼 수만 있다면 산카를로 가극장에서 오페라 한 편 보면 좋겠다. 그러면 혹시 나폴리에서 쇼핑하기 좋은 장소는 어디야?",
            "turn_id": "BK22014675-7",
            "utterance_id": "BK22014675.13"
        },
        {
            "reference_date": "2014-09-25",
            "reference_text": [
                {
                    "value": "1890년 도시를 정비하면서 세운 거대한 상가 건물인 움베르토 1세 아케이드는 예나 지금이나 나폴리를 대표하는 쇼핑 타운이다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "철제 구조물이 받치고 있는 천정은 유리로 만든 돔으로 돼 있고, 아케이드의 내부는 늘상 사람들로 가득하다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.dailian.co.kr/news/view/439145/?sc=naver",
            "search_query": "움베르토 1세 아케이드",
            "terminate": false,
            "text": "나폴리를 대표하는 쇼핑타운인 옴베르토 1세 아케이드가 있어. 이곳은 1890년 도시 정비 사업으로 건축한 상가 건물이야. 돔 형태의 유리로 만들어진 천정을 철제 구조물이 받치고 있는 것이 인상적인 곳으로, 항상 사람들로 붐비는 곳이야.",
            "turn_id": "BK22014675-7",
            "utterance_id": "BK22014675.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "1890년에 세운 쇼핑 타운이라니 너무 궁금하네. 마지막으로 나폴리에서 꼭 먹어봐야 할 음식이 있다면 알려 줄래?",
            "turn_id": "BK22014675-8",
            "utterance_id": "BK22014675.15"
        },
        {
            "reference_date": "2019-01-10",
            "reference_text": [
                {
                    "value": "피자가 탄생한 곳에서 ‘전통’ 피자를 맛보는 것은 가장 소박하면서도 특별한 미식여행이 될 것이다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                },
                {
                    "value": "피자이올로(Pizzaiolo)라고 불리는 피자 장인들은 나폴리 음식 문화에서 가장 중요한 사람들이다.",
                    "value_time": "2022-10-01",
                    "value_type": "constant"
                },
                {
                    "value": "이탈리아 전역을 넘어 세계적으로 뻗어 나가 피자를 국제적인 음식으로 알린 장본인들이기 때문이다.",
                    "value_time": "2022-10-01",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.travie.com/news/articleView.html?idxno=20631",
            "search_query": "나폴리 피자",
            "terminate": false,
            "text": "나폴리는 피자가 탄생한 곳으로, 나폴리에서 전통 피자를 먹으면서 소박하면서도 특별한 미식 여행을 즐기면 좋을 거야. 나폴리에는 피자이올로라고 불리는 피자를 국제적으로 알린 피자 장인들이 있어.",
            "turn_id": "BK22014675-8",
            "utterance_id": "BK22014675.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "피자의 원조인 나폴리에서는 당연히 피자를 먹어야겠네. 나폴리를 잘 몰라서 계획 세우는데 힘들었는데 도와줘서 고마워.",
            "turn_id": "BK22014675-9",
            "utterance_id": "BK22014675.17"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "고맙긴, 또 모르는 것 있으면 언제든지 물어봐.",
            "turn_id": "BK22014675-9",
            "utterance_id": "BK22014675.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알겠어, 우리는 다음에 보자.",
            "turn_id": "BK22014675-10",
            "utterance_id": "BK22014675.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "그래, 다음에 보자, 안녕.",
            "turn_id": "BK22014675-10",
            "utterance_id": "BK22014675.20"
        }
    ]
}