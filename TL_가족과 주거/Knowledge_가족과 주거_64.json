    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지도 디스크가 생길 수 있다고 하던데, 정말이야?",
            "turn_id": "BK22012791-1",
            "utterance_id": "BK22012791.1"
        },
        {
            "reference_date": "44369.0",
            "reference_text": [
                {
                    "value": "강아지디스크의 정확한 진단명은 추간판탈출증이다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                },
                {
                    "value": "척추뼈 사이의 추간판이 손상을 입으며 추간판이 터지거나 밀려 나와 척수 신경을 압박하여 통증을 유발한다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.psnews.co.kr/news/articleView.html?idxno=1828672",
            "search_query": "강아지 디스크",
            "terminate": false,
            "text": "강아지 디스크는 척추뼈 사이에 있는 추간판이 다치거나 터져서 밀려나오게 되는데, 그로 인해 척수신경을 눌러 통증이 생겨. 강아지 디스크의 정확한 병명은 추간판 탈출증이야.",
            "turn_id": "BK22012791-1",
            "utterance_id": "BK22012791.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "추간판 탈출증이 발생하면 어떤 증상이 나타나게 돼?",
            "turn_id": "BK22012791-2",
            "utterance_id": "BK22012791.3"
        },
        {
            "reference_date": "44369.0",
            "reference_text": [
                {
                    "value": "강아지 추간판탈출증의 증상은 뒷다리를 끌며 부자연스런 걸음과 몸살 같은 떨림, 대소변을 가리지 못하고 움찔거리며 통증을 호소하고 음식을 거부하는 등 다양한 증상을 나타낸다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.psnews.co.kr/news/articleView.html?idxno=1828672",
            "search_query": "강아지 추간판탈출증 증상",
            "terminate": false,
            "text": "강아지가 추간판 탈출증이 생기게 되면 대소변을 가리지 못하거나 몸살 같은 떨림 또는 움찔거리면서 아파하는 증상이 나타나게 돼. 또한 음식을 먹지 않고, 뒷다리를 끌면서 자연스럽지 못하게 걷는 등 여러 가지 증상이 발생해.",
            "turn_id": "BK22012791-2",
            "utterance_id": "BK22012791.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 디스크가 있으면 변을 보는 것을 힘들어할 수 있어?",
            "turn_id": "BK22012791-3",
            "utterance_id": "BK22012791.5"
        },
        {
            "reference_date": "43441.0",
            "reference_text": [
                {
                    "value": "가령 반려견의 전립선이 비대해지거나 장폐색 등의 질병에 걸리면 장이 막히기 때문에 배설이 힘들어집니다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                },
                {
                    "value": "허리디스크가 있어도 변을 볼 때 허리에 통증이 오기 때문에 힘을 제대로 주지 못합니다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nongmin.com/plan/PLN/SRS/303474/view",
            "search_query": "반려견 허리디스크 배설",
            "terminate": false,
            "text": "강아지가 허리 디스크를 겪고 있다면 허리에 통증이 발생하기 때문에, 배설을 할 때 제대로 힘을 주지 못해. 또한 장폐색이나 전립선 비대 등의 질환이 있으면 장이 막혀서 변을 보기 힘들어.",
            "turn_id": "BK22012791-3",
            "utterance_id": "BK22012791.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나. 그런데 강아지마다 증상이 다르게 나타날 수도 있는 거야?",
            "turn_id": "BK22012791-4",
            "utterance_id": "BK22012791.7"
        },
        {
            "reference_date": "44807.0",
            "reference_text": [
                {
                    "value": "추간판탈출증은 디스크가 손상된 위치나 손상정도에 따라 반려동물마다 증상이 다르게 나타날 수 있다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                },
                {
                    "value": "단순히 다리를 절 때도 있고 제대로 걷지 못하고 심지어 몸을 가누기조차 힘들어할 수 있고 심한 통증을 느끼기도 한다.",
                    "value_time": "44820.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=60988",
            "search_query": "반려동물 추간판탈출증 증상",
            "terminate": false,
            "text": "반려동물마다 디스크가 파손된 정도나 위치에 따라서 증상이 다르게 발생할 수 있어. 추간판 탈출증으로 인해 극심한 통증이 발생하거나 잘 걷지 못하고, 다리를 절 수 있으며 몸을 제대로 가누기 힘들 수도 있어.",
            "turn_id": "BK22012791-4",
            "utterance_id": "BK22012791.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지는 아프다고 말을 못 해서 너무 속상해. 항상 주의 깊게 살펴봐야겠다.",
            "turn_id": "BK22012791-5",
            "utterance_id": "BK22012791.9"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "허리에 문제가 있는 듯한 증상을 보이면 바로 병원으로 데려가.",
            "turn_id": "BK22012791-5",
            "utterance_id": "BK22012791.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지가 추간판 탈출증을 치료할 때 확인하는 것들이 있어?",
            "turn_id": "BK22012791-6",
            "utterance_id": "BK22012791.11"
        },
        {
            "reference_date": "44587.0",
            "reference_text": [
                {
                    "value": "우선 치료를 위해서는 동물이 앓고 있는 추간판탈출증에 대해서 명확하게 분석할 필요가 있다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                },
                {
                    "value": "정확히 어느 척추 사이 레벨인지, 어느 방향인지, 추간판 탈출 양의 정도는 얼마만큼인지, 이로 인한 척수의 손상은 어느 정도 인지를 확인하는 것이 도움이 된다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.jejutwn.com/news/article.html?no=121431",
            "search_query": "동물 추간판탈출증 분석",
            "terminate": false,
            "text": "강아지가 겪고 있는 추간판 탈출증에 대해서 정확히 검토하고 나서 치료를 진행해. 추간판이 탈출한 양은 어느 정도인지, 위치가 어디에서 발생했는지 또는 어디 척추 사이 레벨인지를 정확하게 알아야 척수가 얼마나 손상됐는지 알 수 있거든.",
            "turn_id": "BK22012791-6",
            "utterance_id": "BK22012791.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 침 치료도 강아지 디스크에 도움이 될까?",
            "turn_id": "BK22012791-7",
            "utterance_id": "BK22012791.13"
        },
        {
            "reference_date": "44589.0",
            "reference_text": [
                {
                    "value": "관절염, 근육통은 물론 디스크 발작, 안면신경마비에 효과가 좋고, 초기 디스크 치료에도 효과적이며 식욕저하, 구토, 설사, 복통 등의 위장관 만성 질환에도 쓰이는 치료법이다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                },
                {
                    "value": "꾸준한 침 치료를 통해 노령기 반려동물에게 발생할 수 있는 치매나 행동학적 문제들을 예방하기도 한다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.healthinnews.co.kr/news/articleView.html?idxno=27813",
            "search_query": "반려동물 침치료 디스크",
            "terminate": false,
            "text": "강아지에게 디스크가 생긴지 얼마 안 됐을 때 꾸준하게 침 치료를 받으면 효과를 볼 수 있어. 또한 침 치료는 디스크 발작, 관절염, 근육통, 안면신경 마비에도 효과적인 치료법인데, 노령견의 행동학적 문제나 치매 발생을 막아주고, 복통, 설사, 구토 및 식욕저하 등의 위장 만성 질환이 있는 강아지에게도 좋아.",
            "turn_id": "BK22012791-7",
            "utterance_id": "BK22012791.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "침을 맞는 게 강아지한테도 좋구나. 그런데 디스크에 쉽게 걸리는 견종이 따로 있어?",
            "turn_id": "BK22012791-8",
            "utterance_id": "BK22012791.15"
        },
        {
            "reference_date": "44807.0",
            "reference_text": [
                {
                    "value": "닥스훈트, 시츄, 페키니즈 등의 견종을 기르는 보호자라면 반드시 몸에 이상이 없는지 확인해보고 관리해주길 바란다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                },
                {
                    "value": "강아지 디스크는 특히 다리가 짧고 허리가 긴 품종에서 잘 발견된다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=60988",
            "search_query": "디스크 견종",
            "terminate": false,
            "text": "허리가 길고 다리가 짧은 견종에서 디스크가 쉽게 생기는데, 페키니즈나 닥스훈트 또는 시추 등의 강아지를 키운다면 건강을 체크하며 관리를 해줘야 해.",
            "turn_id": "BK22012791-8",
            "utterance_id": "BK22012791.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "평소에 건강에 이상이 없는지 관심 있게 살펴봐야겠다. 혹시 수영을 시키는 게 디스크 완화에 도움이 될까?",
            "turn_id": "BK22012791-9",
            "utterance_id": "BK22012791.17"
        },
        {
            "reference_date": "44752.0",
            "reference_text": [
                {
                    "value": "수영은 재미와 건강상의 이점을 함께 얻는 놀이 운동이다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                },
                {
                    "value": "소형견의 고질병인 슬개골 탈구나 허리 디스크 예방 치료에도 수영이 제격이다.",
                    "value_time": "44820.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1407723/",
            "search_query": "소형견 수영 디스크 예방",
            "terminate": false,
            "text": "수영은 허리 디스크 예방을 위한 치료로 적격이야. 강아지에게 수영은 건강을 얻고, 재미를 느낄 수 있는 놀이 운동인데, 소형견의 만성질환인 슬개골 탈구에도 좋아.",
            "turn_id": "BK22012791-9",
            "utterance_id": "BK22012791.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "수영을 하면 재미도 있는데 강아지 건강까지 좋아진다니 너무 좋다!",
            "turn_id": "BK22012791-10",
            "utterance_id": "BK22012791.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "기회가 되면 강아지와 함께 수영하는 시간을 가져봐.",
            "turn_id": "BK22012791-10",
            "utterance_id": "BK22012791.20"
        }
    ]
}