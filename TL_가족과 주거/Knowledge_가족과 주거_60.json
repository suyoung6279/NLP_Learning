    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지가 나이가 들면서 안질환에 대해 궁금한 게 많아졌어. 혹시 강아지도 안구건조증이 생길 수 있을까?",
            "turn_id": "BK22012756-1",
            "utterance_id": "BK22012756.1"
        },
        {
            "reference_date": "43838.0",
            "reference_text": [
                {
                    "value": "강아지 안구건조증을 다른 말로 건성각 결막염이라고도 부르는데, 이는 강아지에게 흔한 안과질환으로 눈물 분비량이 줄어들어 눈을 보호하는 눈물층이 부족해 생기는 질환이다.",
                    "value_time": "44812.0",
                    "value_type": "constant"
                },
                {
                    "value": "강아지 안구건조증은 급격히 추워진 날씨와 미세먼지, 건조함으로 인해 발생한다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.kidd.co.kr/news/213386",
            "search_query": "강아지 안구건조증",
            "terminate": false,
            "text": "갑자기 날씨가 추워지거나 건조함, 미세먼지로 인해 강아지도 건성각 결막염이라고도 부르는 안구건조증이 생길 수 있어. 안구건조증은 강아지에게 흔하게 발생하는 안과질환인데, 눈물의 분비량 감소로 인해 눈물층이 모자라게 되면 생기게 돼.",
            "turn_id": "BK22012756-1",
            "utterance_id": "BK22012756.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "안구건조증이 생기게 되면 어떤 증상이 나타나게 돼?",
            "turn_id": "BK22012756-2",
            "utterance_id": "BK22012756.3"
        },
        {
            "reference_date": "44141.0",
            "reference_text": [
                {
                    "value": "반려견이 안구건조증에 걸리면 끈적끈적한 눈곱이 생기고 눈이 충혈된다.",
                    "value_time": "44812.0",
                    "value_type": "constant"
                },
                {
                    "value": "눈을 자주 깜빡이기도 하고 실눈을 뜰 수 있다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fneyefocus.com/news/articleView.html?idxno=15011",
            "search_query": "반려견 안구건조증 눈곱",
            "terminate": false,
            "text": "눈이 충혈되거나 실눈을 뜨며, 끈끈한 눈곱이 생기거나 눈을 깜빡이는 게 잦다면 강아지에게 안구건조증이 생긴 거야.",
            "turn_id": "BK22012756-2",
            "utterance_id": "BK22012756.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 다른 이유로 눈곱이 생길 수도 있어?",
            "turn_id": "BK22012756-3",
            "utterance_id": "BK22012756.5"
        },
        {
            "reference_date": "43649.0",
            "reference_text": [
                {
                    "value": "강아지눈꼽이 끼는 원인으로는 각막에 상처를 입어 눈곱이 많이 낄 수 있다고 합니다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                },
                {
                    "value": "안구 주위가 가려워 긁다가 자신의 발톱에 긁히기도 하고 다른 강아지들과 놀다가 각막에 상처를 입을 수 있으니 유의해주시기 바랍니다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.notepet.co.kr/news/article/article_view/?idx=16152",
            "search_query": "강아지 눈곱 원인",
            "terminate": false,
            "text": "다른 강아지들과 놀다가 다치거나 눈 주변이 간지러워 긁다가 발톱에 긁혀서 각막에 손상을 입어 눈곱이 낄 수 있어. 그래서 각막에 상처가 나지 않도록 조심해 줘야 해.",
            "turn_id": "BK22012756-3",
            "utterance_id": "BK22012756.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "안구건조증이 아니어도 눈곱이 낄 수 있구나. 그런데 안구건조증이 생기면 병원에 데려가야 해?",
            "turn_id": "BK22012756-4",
            "utterance_id": "BK22012756.7"
        },
        {
            "reference_date": "43838.0",
            "reference_text": [
                {
                    "value": "다른 질병과 마찬가지로 안구건조증도 발견 즉시 조기 치료를 시행해 주는 것이 무척이나 중요하다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                },
                {
                    "value": "수의사의 지시에 따라 안약이나 연고를 지속적으로 투여해주고, 세균에 감염됐을 경우 세안 약을 투여해 씻어내 준다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.kidd.co.kr/news/213386",
            "search_query": "안구건조증 치료",
            "terminate": false,
            "text": "안구건조증도 다른 질환들처럼 발견하면 초기에 바로 치료를 해주는 게 중요해. 수의사의 지시대로 연고나 안약을 꾸준히 발라주고, 세균이 침윤했다면 세안 약을 넣어줘서 닦아내줘야 헤.",
            "turn_id": "BK22012756-4",
            "utterance_id": "BK22012756.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "강아지에게서 안구건조증 증상이 나타나면 바로 동물 병원에 데려가야겠다.",
            "turn_id": "BK22012756-5",
            "utterance_id": "BK22012756.9"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어떤 질환이든 증상이 나타나면 바로 병원에 데려가는 게 좋아.",
            "turn_id": "BK22012756-5",
            "utterance_id": "BK22012756.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래야겠어. 그런데 강아지들의 시력을 저하시키는 안질환에 어떤 것들이 있는지 알아?",
            "turn_id": "BK22012756-6",
            "utterance_id": "BK22012756.11"
        },
        {
            "reference_date": "44542.0",
            "reference_text": [
                {
                    "value": "반면 반려동물의 시력을 해치는 주요 3대 안과질환은 ▲각막궤양, ▲포도막염, ▲녹내장이라고 할 수 있다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                },
                {
                    "value": "그중에서도 반려동물의 나이를 불문하고 가장 흔하게 나타나는 것이 바로 '각막궤양'이다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fneyefocus.com/news/articleView.html?idxno=16641",
            "search_query": "반려동물 안과질환",
            "terminate": false,
            "text": "녹내장과 포도막염, 각막궤양이 반려동물의 시력을 망가뜨리는 주 3대 안과질환이야. 그중에서 각막궤양이 나이 상관없이 제일 수두룩하게 발생해.",
            "turn_id": "BK22012756-6",
            "utterance_id": "BK22012756.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "각막궤양이 뭔지 설명해 줄 수 있어?",
            "turn_id": "BK22012756-7",
            "utterance_id": "BK22012756.13"
        },
        {
            "reference_date": "44764.0",
            "reference_text": [
                {
                    "value": "각막은 홍채와 동공을 보호하는 막으로서 눈의 가장 앞에 위치한다.",
                    "value_time": "44812.0",
                    "value_type": "constant"
                },
                {
                    "value": "이러한 각막에 손상이 가고 상처가 생기는 것을 각막궤양이라고 한다.",
                    "value_time": "44812.0",
                    "value_type": "constant"
                },
                {
                    "value": "동물병원에서는 각막궤양이 의심되면 형광염색약을 이용하여 진단한다.",
                    "value_time": "44812.0",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.healthinnews.co.kr/news/articleView.html?idxno=31441",
            "search_query": "각막궤양",
            "terminate": false,
            "text": "각막은 눈 가장 앞쪽에 있는 동공과 홍재를 보호해 주는 막인데, 이 각막에 상처와 손상이 생기게 되는 게 각막궤양이야. 만약 이 질환이 의심되면 동물 병원에서 형광 염색약을 통해 진단을 받을 수 있어.",
            "turn_id": "BK22012756-7",
            "utterance_id": "BK22012756.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "각막궤양은 어쩌다가 생기게 되는 거야?",
            "turn_id": "BK22012756-8",
            "utterance_id": "BK22012756.15"
        },
        {
            "reference_date": "43004.0",
            "reference_text": [
                {
                    "value": "샴푸 원액이 각막을 다치게 하거나 얼굴을 씻는 과정에서 각막을 건드려 각막 궤양을 유발하는 경우다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                },
                {
                    "value": "말을 하지 못하는 반려동물의 시력에 문제가 생겨도 가족이 쉽게 알아채기는 어렵다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hankookilbo.com/News/Read/201709261033688843",
            "search_query": "각막궤양 유발",
            "terminate": false,
            "text": "각막궤양은 얼굴을 씻길 때 각막을 건드리게 돼서 각막 궤양이 생기거나, 샴푸가 각막을 손상시켜서 발생하게 돼. 그런데 반려동물은 말을 못 해서 시력에 문제가 발생해도 가족들이 발견하기가 쉽지 않아.",
            "turn_id": "BK22012756-8",
            "utterance_id": "BK22012756.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나. 궁금한 게 있는데 백내장은 노견에서만 발생하는 질환이야?",
            "turn_id": "BK22012756-9",
            "utterance_id": "BK22012756.17"
        },
        {
            "reference_date": "44223.0",
            "reference_text": [
                {
                    "value": "백내장은 노령성으로 생긴다고 많이 알고 있습니다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                },
                {
                    "value": "그러나 사실 어린 강아지들을 포함해 모든 개들이 백내장으로부터 자유롭지는 않습니다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                },
                {
                    "value": "반려동물에서는 어린 나이에 발생하는 유전성 백내장도 많습니다.",
                    "value_time": "44812.0",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.news1.kr/articles/?4191703",
            "search_query": "백내장 어린 강아지",
            "terminate": false,
            "text": "대부분 나이가 들어가면서 백내장이 발생한다고 알고 있는데, 어린 강아지를 비롯해서 모든 강아지들에게 백내장이 생길 수도 있어. 유전성 백내장은 어린 나이에 생기거든.",
            "turn_id": "BK22012756-9",
            "utterance_id": "BK22012756.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나이가 어린 강아지에게도 백내장이 생길 수 있구나.",
            "turn_id": "BK22012756-10",
            "utterance_id": "BK22012756.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "강아지들의 안질환을 위해서 평소에 관리를 잘해주는 게 좋아.",
            "turn_id": "BK22012756-10",
            "utterance_id": "BK22012756.20"
        }
    ]
}