    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "요즘 아기 키우느라 너무 바빴어.",
            "turn_id": "BK22009303-1",
            "utterance_id": "BK22009303.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러니까, 아기 키우느라 고생 많았어. 우리도 엄청 오랜만에 만났잖아.",
            "turn_id": "BK22009303-1",
            "utterance_id": "BK22009303.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "맞아, 남편이 오늘은 아기 본다고 해서 겨우 나왔지 뭐. 그런데 영아 수당이란 게 있다더라고. 혹시 영아 수당을 지급받을 수 있는 대상은 어떻게 되는지 아니?",
            "turn_id": "BK22009303-2",
            "utterance_id": "BK22009303.3"
        },
        {
            "reference_date": "2022-01-07",
            "reference_text": [
                {
                    "value": "지원 대상은 2022년 1월 1일 이후 출생신고를 한 신생아 가정으로 가족 내 출생 순서와 상관없이 모두 가능하다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                },
                {
                    "value": "단, 대한민국 국적(복수국적자·난민인정자 포함) 소지자여야 한다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nocutnews.co.kr/news/5686224",
            "search_query": "영아수당 지원대상",
            "terminate": false,
            "text": "영아 수당은 대한민국 국민이면 가능하고, 2022년 1월 1일 이후에 출생 신고를 한 신생아가 있다면 출생 순서와 무관하게 지급받을 수 있어.",
            "turn_id": "BK22009303-2",
            "utterance_id": "BK22009303.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그럼 둘째인 우리 아기도 받을 수 있겠네. 영아 수당 지급액은 얼마나 돼?",
            "turn_id": "BK22009303-3",
            "utterance_id": "BK22009303.5"
        },
        {
            "reference_date": "2022-08-30",
            "reference_text": [
                {
                    "value": "현행 제공되는 영아수당의 현금 지급액은 만 0세와 만 1세가 모두 월 30만원이다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                },
                {
                    "value": "어린이집을 다닐 경우에는 영아수당 보육료 바우처를 지급한다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.queen.co.kr/news/articleView.html?idxno=380250",
            "search_query": "영어수당 지급액",
            "terminate": false,
            "text": "현재 기준으로 영아 수당의 지급액은 만 0세와 만 1세가 동일하게 현금으로 월 30만 원인데, 어린이집에 다니고 있다면 영아 수당 보육료 바우처로 지급을 하고 있어.",
            "turn_id": "BK22009303-3",
            "utterance_id": "BK22009303.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아하, 보육료 바우처에 대해 더 자세하게 설명해 줄 수 있을까?",
            "turn_id": "BK22009303-4",
            "utterance_id": "BK22009303.7"
        },
        {
            "reference_date": "2022-08-22",
            "reference_text": [
                {
                    "value": "만 0세를 기준으로 보육료바우처는 월 50만원 정도다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                },
                {
                    "value": "그런데 이건 말 그대로 바우처다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                },
                {
                    "value": "현금으로 지급하지 않는다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                },
                {
                    "value": "어린이집에 그대로 들어가는 돈이다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.mt.co.kr/mtview.php?no=2022082014412491145",
            "search_query": "보육료 바우처",
            "terminate": false,
            "text": "응, 말 그대로 보육료 바우처는 현금으로 지급되지 않고 어린이집 비용으로만 낸다고 생각하면 돼. 보육료 바우처는 만 0세 기준, 월 50만 원 정도로 생각하면 돼.",
            "turn_id": "BK22009303-4",
            "utterance_id": "BK22009303.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나. 아이돌봄 서비스라는 것도 있다던데, 아이돌봄 서비스에 대해 설명해줄래?",
            "turn_id": "BK22009303-5",
            "utterance_id": "BK22009303.9"
        },
        {
            "reference_date": "2022-06-07",
            "reference_text": [
                {
                    "value": "아이돌봄 서비스는 생후 3개월부터 만 12세 이하 아동을 대상으로 부모의 맞벌이 등에 따라 돌봄이 필요한 가정에 아이돌보미가 직접 방문해 1:1 돌봄을 제공한다.",
                    "value_time": "2022-10-12",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.joongdo.co.kr/web/view.php?key=20220605010000792",
            "search_query": "아이돌봄 서비스",
            "terminate": false,
            "text": "아이돌봄 서비스란 부모가 맞벌이를 할 경우, 돌봄이 필요한 집에 아이돌보미가 방문해서 1 대 1 돌봄 서비스를 제공하는 거야. 대상은 출생 후 3개월부터 만 12세 이하의 어린이가 해당돼.",
            "turn_id": "BK22009303-5",
            "utterance_id": "BK22009303.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 현금으로 30만 원을 받아서 자유롭게 쓰거나 어린이집 이용이나 돌봄 서비스로 온전히 내느냐의 차이인 거구나. 그럼 영아 수당 대상 기준이 따로 있을까? 소득 기준이라던가, 나이라던가 말이야.",
            "turn_id": "BK22009303-6",
            "utterance_id": "BK22009303.11"
        },
        {
            "reference_date": "2022-09-12",
            "reference_text": [
                {
                    "value": "영아수당의 경우 소득인정액 기준은 없으며 만 2세가 되어서도 가정양육을 이행하면 가정양육수당을 지원받을 수 있다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.pinpointnews.co.kr/news/articleView.html?idxno=141267",
            "search_query": "영아수당",
            "terminate": false,
            "text": "영아 수당은 소득 기준이 따로 없어. 또 만 2세가 되더라도 계속 가정 양육을 한다면 가정 양육수당으로 지원받을 수도 있고.",
            "turn_id": "BK22009303-6",
            "utterance_id": "BK22009303.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오, 그것참 좋은데? 그럼 영아 수당 신청 방법은 어떻게 돼?",
            "turn_id": "BK22009303-7",
            "utterance_id": "BK22009303.13"
        },
        {
            "reference_date": "2022-01-06",
            "reference_text": [
                {
                    "value": "대상 가정은 전국 읍·면·동 주민센터에 직접 방문해 신청하거나 행복출산 원스톱서비스에 의해 출산 서비스 통합처리 신청서로 신청 가능하다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                },
                {
                    "value": "또한 아동의 보호자가 부모인 경우 복지로 웹사이트 또는 스마트폰 앱(APP)을 통해 온라인 신청도 가능하다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.mt.co.kr/mtview.php?no=2022010611283217956",
            "search_query": "영아수당 신청 방법",
            "terminate": false,
            "text": "신청하는 방법은 다양해. 영아 수당에 해당되는 가정이라면 주민센터에 방문해서 신청할 수도 있고, 행복 출산 원스톱 서비스를 이용해 출산 서비스 통합 처리 신청서로 신청할 수도 있어. 또 영아의 보호자가 부모라면 직접 방문하지 않고 복지로 홈페이지나 스마트폰 앱으로 온라인 신청이 가능해.",
            "turn_id": "BK22009303-7",
            "utterance_id": "BK22009303.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다양해서 좋네. 그런데 행복 출산 원스톱 서비스라는 건 뭐야?",
            "turn_id": "BK22009303-8",
            "utterance_id": "BK22009303.15"
        },
        {
            "reference_date": "2022-04-18",
            "reference_text": [
                {
                    "value": "‘행복 출산’ 원스톱 서비스는 정부24 또는 주민센터에서 출생신고 후, 첫만남이용권, 아동수당, 영아수당, 출산가구 전기료 감면, 해산급여 등을 한 번에 안내받고 신청할 수 있는 서비스다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.khan.co.kr/national/national-general/article/202204181200001",
            "search_query": "행복출산 원스톱서비스",
            "terminate": false,
            "text": "행복 출산 원스톱 서비스란 출생신고 후 한 번에 다양한 서비스를 신청할 수 있는 제도야. 예로 들면 첫 만남 이용권, 아동수당, 영아 수당, 출산가구 전기료 감면, 해산급여 등이 있어.",
            "turn_id": "BK22009303-8",
            "utterance_id": "BK22009303.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "한 번에 신청할 수 있는 서비스가 있다니 좋은데? 아, 그런데 혹시 영아 수당 신청 기간이 따로 있는 거야?",
            "turn_id": "BK22009303-9",
            "utterance_id": "BK22009303.17"
        },
        {
            "reference_date": "2022-02-11",
            "reference_text": [
                {
                    "value": "신청 기간은 출생일을 포함해 60일 이내이며 신청 시 출생한 달부터 소급해 영아수당을 지원한다.",
                    "value_time": "2022-09-22",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.enewstoday.co.kr/news/articleView.html?idxno=1547876",
            "search_query": "영아수당 신청 기간",
            "terminate": false,
            "text": "응, 영아 수당 신청은 태어난 날을 포함해서 60일 이내로 가능해. 출생한 달부터 소급 적용해서 지원되니 참고하도록 해.",
            "turn_id": "BK22009303-9",
            "utterance_id": "BK22009303.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "알려줘서 고마워, 이번 주에 얼른 신청해야겠다. 시간이 이제 늦어서 집에 가봐야겠어.",
            "turn_id": "BK22009303-10",
            "utterance_id": "BK22009303.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "응, 다음에는 아기랑 같이 만나자. 집에 조심히 가.",
            "turn_id": "BK22009303-10",
            "utterance_id": "BK22009303.20"
        }
    ]
}