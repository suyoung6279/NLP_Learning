    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오늘은 같이 저녁 먹기 힘들겠다.",
            "turn_id": "BK22012190-1",
            "utterance_id": "BK22012190.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "저녁을 못 먹는 건 괜찮은데, 혹시 무슨 일 있어?",
            "turn_id": "BK22012190-1",
            "utterance_id": "BK22012190.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리 강아지가 피부염이 생겨서 병원에 다니고 있거든. 오늘 저녁에 진료를 보러 가야 해.",
            "turn_id": "BK22012190-2",
            "utterance_id": "BK22012190.3"
        },
        {
            "reference_date": "2021-05-31",
            "reference_text": [
                {
                    "value": "농촌진흥청이 2018년 동물 병원 진료 기록을 바탕으로 반려견의 나이와 품종에 따른 병원 방문 이유를 분석한 결과, 반려견이 가장 많이 앓는 질병은 피부염과 설사인 것으로 나타났다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.busan.com/view/busan/view.php?code=2021053110544092984",
            "search_query": "강아지 피부염",
            "terminate": false,
            "text": "강아지가 피부염에 자주 걸리는 편이야? 농촌진흥청이 2018년에 동물 병원 진료 기록을 토대로 반려견의 품종과 연령에 따른 병원에 방문한 이유를 조사해봤는데, 피부염과 설사가 가장 흔하게 앓는 질병이었어.",
            "turn_id": "BK22012190-2",
            "utterance_id": "BK22012190.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "응, 실제로 우리 강아지도 피부염에 자주 걸려. 다른 강아지들도 피부염 때문에 병원에 많이 오던데 조사 결과가 있었구나.",
            "turn_id": "BK22012190-3",
            "utterance_id": "BK22012190.5"
        },
        {
            "reference_date": "2021-07-01",
            "reference_text": [
                {
                    "value": "여름철 강아지가 자주 걸리는 질병 중 첫 번째는 피부병이다.",
                    "value_time": "2022-08-14",
                    "value_type": "variable"
                },
                {
                    "value": "대기 습도가 높은 여름이지만 강아지는 땀샘이 없다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                },
                {
                    "value": "때문에 습진이 자주 발생하고 곰팡이성 피부염, 지루성 피부염, 농피증 등이 강아지 온몸에 나타난다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.busan.com/view/busan/view.php?code=2021063017563950655",
            "search_query": "강아지 여름철 피부",
            "terminate": false,
            "text": "피부병은 특히 여름철에 자주 걸리는 질병이야. 여름은 대기 습도가 높은데 강아지는 땀샘이 없잖아. 그래서 습진이 자주 생기고 곰팡이성 피부염이나 지루성 피부염, 그리고 농피증 등이 강아지의 몸 전체에 나타나.",
            "turn_id": "BK22012190-3",
            "utterance_id": "BK22012190.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "앗! 우리 강아지 병명이 바로 곰팡이성 피부염이야. 도대체 어디에서 걸린건지 짐작도 못하겠어.",
            "turn_id": "BK22012190-4",
            "utterance_id": "BK22012190.7"
        },
        {
            "reference_date": "2020-02-25",
            "reference_text": [
                {
                    "value": "곰팡이성 피부염에 걸리는 원인은 다양하다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                },
                {
                    "value": "다른 동물이나 사람에게서 옮기도 하고 침구, 발톱 깎기, 케이지 등에 있는 세균을 통해서 감염되기도 한다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=47402",
            "search_query": "강아지 곰팡이성 피부염",
            "terminate": false,
            "text": "곰팡이성 피부염에 걸리는 원인은 워낙 다양해. 다른 동물이나 사람으로부터 옮을 수도 있고, 침구나 발톱 깎기, 그리고 케이지에 있는 세균을 통해서도 감염돼.",
            "turn_id": "BK22012190-4",
            "utterance_id": "BK22012190.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 원인을 찾기보다는 그냥 앞으로 관리를 잘해주는게 중요하겠구나.",
            "turn_id": "BK22012190-5",
            "utterance_id": "BK22012190.9"
        },
        {
            "reference_date": "2020-09-17",
            "reference_text": [
                {
                    "value": "집먼지 진드기의 영향으로도 피부염이 발생할 수 있기에 침구류와 카펫을 자주 세탁한다.",
                    "value_time": "2022-08-14",
                    "value_type": "variable"
                },
                {
                    "value": "강아지가 생활하는 공간은 일주일에 1회 이상 깨끗하게 청소해줘야 한다.",
                    "value_time": "2022-08-14",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.ikunkang.com/news/articleView.html?idxno=32320",
            "search_query": "강아지 곰팡이성 피부염 관리",
            "terminate": false,
            "text": "바로 그거야! 피부염은 집먼지 진드기의 영향으로도 발병할 수 있으니까 침구류와 카펫을 자주 세탁해 줘. 특히 강아지 생활 공간은 주 1회 이상 깨끗하게 청소해 줘야 해.",
            "turn_id": "BK22012190-5",
            "utterance_id": "BK22012190.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오늘 진료를 받고 나서 바로 청소와 세탁을 해야겠다. 그런데 우리 강아지는 아토피도 있어. 아토피는 사람에게만 생기는 건지 알았는데 말이야.",
            "turn_id": "BK22012190-6",
            "utterance_id": "BK22012190.11"
        },
        {
            "reference_date": "2022-06-19",
            "reference_text": [
                {
                    "value": "강아지 알레르기성피부병은 원인에 따라 음식알레르기와 환경알레르기 등 두 가지로 나뉜다.",
                    "value_time": "2022-08-14",
                    "value_type": "variable"
                },
                {
                    "value": "이때 환경알레르기로 일어나는 피부병을 흔히 ‘아토피’라고 말한다.",
                    "value_time": "2022-08-14",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.k-health.com/news/articleView.html?idxno=59801",
            "search_query": "강아지 아토피",
            "terminate": false,
            "text": "강아지가 앓는 알레르기성 피부병은 원인에 따라 음식 알레르기와 환경 알레르기로 나뉘거든. 그중에 환경 알레르기로 일어나는 피부병을 아토피라고 흔히들 말해.",
            "turn_id": "BK22012190-6",
            "utterance_id": "BK22012190.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 아토피도 결국은 피부염인 거네. 우리 강아지는 유독 간지러워하는 것 같아.",
            "turn_id": "BK22012190-7",
            "utterance_id": "BK22012190.13"
        },
        {
            "reference_date": "2020-04-23",
            "reference_text": [
                {
                    "value": "극심한 가려움증을 동반하는 강아지 아토피 피부염은 주로 눈 주변, 귀, 입, 다리, 서혜부, 배, 항문 등에 증상이 나타난다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.fnnews.com/news/202004231001503368",
            "search_query": "강아지 아토피 증상",
            "terminate": false,
            "text": "강아지 아토피는 극도의 가려움을 유발하는 피부염이라 그래. 대개 눈 주변이나 귀, 입, 다리와 서혜부, 배, 그리고 항문 등에서 증상이 나타나.",
            "turn_id": "BK22012190-7",
            "utterance_id": "BK22012190.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아토피의 증상이 가려움증이구나. 간지러워하는 것을 보고 있기 안쓰러울 지경이야.",
            "turn_id": "BK22012190-8",
            "utterance_id": "BK22012190.15"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 키우는 강아지가 어떤 품종이야?",
            "turn_id": "BK22012190-8",
            "utterance_id": "BK22012190.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "우리 강아지는 갈색 푸들이야.",
            "turn_id": "BK22012190-9",
            "utterance_id": "BK22012190.17"
        },
        {
            "reference_date": "2021-03-25",
            "reference_text": [
                {
                    "value": "무엇보다 바셋 하운드, 푸들 등 길고 아래로 접히는 귀를 가진 품종에게 귀 염증이 자주 발생하는데 특히 알레르기성 피부염을 가진 강아지도 반복적으로 외이염이 발생하기 쉽다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.busan.com/view/busan/view.php?code=2021032418191131974",
            "search_query": "강아지 피부 염증",
            "terminate": false,
            "text": "그러면 귀 염증이 있을 가능성도 있겠다. 푸들, 바셋 하운드 처럼 긴 귀가 접혀 내려오는 품종은 귀 염증이 자주 발생하거든. 특히 알레르기성 피부염이 있는 강아지라면 외이염이 자주 생기기 쉬워.",
            "turn_id": "BK22012190-9",
            "utterance_id": "BK22012190.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "사실 우리 강아지는 귀에도 염증이 자주 발생해. 이게 다 알레르기성 피부염 때문이라고 생각하니 너무 속상하네.",
            "turn_id": "BK22012190-10",
            "utterance_id": "BK22012190.19"
        },
        {
            "reference_date": "2022-07-07",
            "reference_text": [
                {
                    "value": "외이염은 한 번 걸리면 재발 가능성이 매우 높아 발병 초기에 적절한 치료를 하는 것이 중요하다.",
                    "value_time": "2022-08-14",
                    "value_type": "constant"
                },
                {
                    "value": "경증은 간단한 주사나 연고로 치료 가능하다.",
                    "value_time": "2022-08-14",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://kormedi.com/1392353/%ec%9c%84%eb%93%9c%ed%8e%ab-%ec%9a%b0%eb%a6%ac-%ea%b0%95%ec%95%84%ec%a7%80%eb%8f%84-%ea%b3%a0%ec%a7%88%eb%b3%91%ec%9d%b4-%ea%b2%ac%ec%a2%85%eb%b3%84-%ec%89%bd%ea%b2%8c-%ea%b1%b8%eb%a6%ac%eb%8a%94/",
            "search_query": "강아지 외이염",
            "terminate": false,
            "text": "그래도 치료를 잘 받고 있으니까 괜찮을 거야. 외이염은 한 번 걸리면 재발 가능성이 굉장히 높기 때문에 발병 초기에 치료를 잘 받는 것이 중요해. 그리고 증상이 가벼우면 간단한 주사나 연고로도 치료를 할 수 있어.",
            "turn_id": "BK22012190-10",
            "utterance_id": "BK22012190.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "꾸준히 병원을 다닌 게 도움이 되겠구나. 우리 강아지 걱정도 해주고 조언도 해줘서 고마워.",
            "turn_id": "BK22012190-11",
            "utterance_id": "BK22012190.21"
        }
    ]
}