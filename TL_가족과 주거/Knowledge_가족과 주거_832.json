    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 아이 사교육에 대해 어떻게 생각하세요?",
            "turn_id": "BK22002735-1",
            "utterance_id": "BK22002735.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러고 보니 아이가 초등학생이라고 그랬었죠? 슬슬 사교육에 대해 생각할 때이긴 하네요.",
            "turn_id": "BK22002735-1",
            "utterance_id": "BK22002735.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "하지만 우리 아이는 아직 초등학생인데요? 초등학생도 사교육을 받는 비율이 높나요?",
            "turn_id": "BK22002735-2",
            "utterance_id": "BK22002735.3"
        },
        {
            "reference_date": "2022-05-03",
            "reference_text": [
                {
                    "value": "우리나라 초등학교 고학년 10명 중 9명이 학원이나 과외 등 사교육을 받고 있으며, 이 가운데 약 65%는 2개 이상의 사교육을 받는 것으로 나타났다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.kado.net/news/articleView.html?idxno=1124813",
            "search_query": "초등 사교육",
            "terminate": false,
            "text": "그럼요, 초등 고학년 10명 중 9명은 사교육을 받고 있는 실정인 걸요. 무려 65퍼센트가 2개 이상의 사교육을 받고 있으니 말 다했죠.",
            "turn_id": "BK22002735-2",
            "utterance_id": "BK22002735.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "초등학생에게 벌써 그렇게 높은 수치라니 신기하네요. 고등학생이 되면 비율이 더 높아지지 않나요?",
            "turn_id": "BK22002735-3",
            "utterance_id": "BK22002735.5"
        },
        {
            "reference_date": "2022-03-25",
            "reference_text": [
                {
                    "value": "사교육 참여율은 초등학생이 82.0%로 가장 높았고, 고등학생이 64.6%로 가장 낮았다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://news.kmib.co.kr/article/view.asp?arcid=0924237611&code=11151100&cp=nv",
            "search_query": "초등 사교육 참여율",
            "terminate": false,
            "text": "사실 사교육을 가장 많이 하는 게 초등학생이에요. 사교육 참여율이 무려 82퍼센트라고요. 반면에 고등학생은 64.6퍼센트로 가장 낮은 비율을 차지해요.",
            "turn_id": "BK22002735-3",
            "utterance_id": "BK22002735.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어머, 그렇군요. 사교육을 왜 그렇게 많이 시키는 걸까요?",
            "turn_id": "BK22002735-4",
            "utterance_id": "BK22002735.7"
        },
        {
            "reference_date": "2022-03-31",
            "reference_text": [
                {
                    "value": "코로나19 장기화로 자영업 등 소상공인들의 어려움이 가중되는 것과 달리 사교육 시장은 규모가 되레 확장하는 추세다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.cctimes.kr/news/articleView.html?idxno=698838",
            "search_query": "사교육 증가",
            "terminate": false,
            "text": "사실 코로나로 사교육 시장의 규모가 도리어 확장했거든요.",
            "turn_id": "BK22002735-4",
            "utterance_id": "BK22002735.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그건 저도 동의하는 부분이에요. 그래서 초등학생도 사교육비가 엄청 증가한 것 같던데 맞나요?",
            "turn_id": "BK22002735-5",
            "utterance_id": "BK22002735.9"
        },
        {
            "reference_date": "2022-03-11",
            "reference_text": [
                {
                    "value": "학교급별 통계에서는 초등학생 사교육비가 큰폭 증가했다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                },
                {
                    "value": "과목별 사교육비는 사회와 과학과목 지출이 늘어난게 특징이다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                },
                {
                    "value": "사교육비가 국,영,수 전통적 강세과목에서 범위가 확대되는 추세를 보였다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.edupress.kr/news/articleView.html?idxno=8755",
            "search_query": "사교육비 증가",
            "terminate": false,
            "text": "맞아요, 초등학생 사교육비가 크게 증가했어요. 특히 기존 국, 영, 수 과목에만 치중하던 사교육비가 사회와 과학 과목까지 늘어났죠.",
            "turn_id": "BK22002735-5",
            "utterance_id": "BK22002735.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "국, 영, 수에 이어 사회와 과학까지요?",
            "turn_id": "BK22002735-6",
            "utterance_id": "BK22002735.11"
        },
        {
            "reference_date": "2022-05-31",
            "reference_text": [
                {
                    "value": "코로나19 장기화로 대면 수업이 차질을 빚은 기간 인강(인터넷 강의) 등 온라인 교육 동영상에 고액을 지출하는 경우가 늘었다는 조사 결과가 나왔다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.yna.co.kr/view/AKR20220530138600017?input=1195m",
            "search_query": "코로나 인강",
            "terminate": false,
            "text": "하하, 정말 많기는 많죠? 코로나가 만들어낸 결과는 또 있어요. 바로 인터넷 강의에도 큰 돈을 쓰는 경우가 늘었다는 사실이죠.",
            "turn_id": "BK22002735-6",
            "utterance_id": "BK22002735.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "나 참, 사교육 하다가 가세가 기울겠네요.",
            "turn_id": "BK22002735-7",
            "utterance_id": "BK22002735.13"
        },
        {
            "reference_date": "2022-06-09",
            "reference_text": [
                {
                    "value": "물가 상승과 경기 침체 우려에도 학부모들의 사교육을 향한 열기가 뜨거워 ‘에듀 푸어’(edu-poor·가계 형편이 좋지 않은데도 교육비를 평균 이상으로 지출한 탓에 빈곤하게 생활하는 사람)가 속출하고 있다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.munhwa.com/news/view.html?no=2022060901071018358001",
            "search_query": "에듀푸어",
            "terminate": false,
            "text": "네, 그래서 에듀 푸어가 늘어가고 있는 추세예요. 에듀 푸어는 가정 형편이 좋지 않아도 교육비를 많이 지출해서 빈곤하게 생활하는 사람을 말하죠.",
            "turn_id": "BK22002735-7",
            "utterance_id": "BK22002735.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러니까요, 저번에 보니까 무슨 학세권이라고도 얘기 하던데요.",
            "turn_id": "BK22002735-8",
            "utterance_id": "BK22002735.15"
        },
        {
            "reference_date": "2022-06-30",
            "reference_text": [
                {
                    "value": "부동산 시장 내 초·중·고교가 모두 가까워 도보 통학이 가능한 일명 ‘원스톱 학세권’ 아파트의 인기가 나날이 높아지고 있다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                },
                {
                    "value": "이에 원스톱 학세권 주거단지의 집값도 강세다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.gpkorea.com/news/articleView.html?idxno=87407",
            "search_query": "학세권 아파트",
            "terminate": false,
            "text": "집 근처에 초, 중, 고가 다 있는 아파트를 학세권 아파트라고 하죠. 이런 학세권은 집값도 높아요.",
            "turn_id": "BK22002735-8",
            "utterance_id": "BK22002735.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "초, 중, 고가 근처에 있는 건 확실히 좋긴 하겠네요. 학원이 근처에 있어도 좋겠어요.",
            "turn_id": "BK22002735-9",
            "utterance_id": "BK22002735.17"
        },
        {
            "reference_date": "2022-07-06",
            "reference_text": [
                {
                    "value": "특히 2025년 자율형사립고·외국어고·국제고가 일괄 폐지를 앞두고 있어 전통적인 명문 학군과 유명 입시학원이 몰려 있는 학원가 지역이 재조명되고 있는 점도 인기 요인으로 작용할 것으로 보인다.",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.nocutnews.co.kr/news/5782475",
            "search_query": "학원가 분양",
            "terminate": false,
            "text": "네, 2025년에는 각종 특목고가 일괄 폐지를 앞두고 있어서 입시학원이 몰려있는 학원가 지역도 인기예요.",
            "turn_id": "BK22002735-9",
            "utterance_id": "BK22002735.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그놈의 사교육이 뭔지, 전 아이가 스트레스 받을까봐 그게 걱정이에요.",
            "turn_id": "BK22002735-10",
            "utterance_id": "BK22002735.19"
        },
        {
            "reference_date": "2022-07-07",
            "reference_text": [
                {
                    "value": "학생의 51.4%, 학부모 64.8%가 경쟁교육과 대학입시때문에 고통스럽다고 답했으며, 경쟁교육 고통의 원인 1순위는 자녀의 성적 스트레스(54.9%), 2순위는 사교육비 지출 부담으로 나타났다(54.9%).",
                    "value_time": "2022-07-09",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.ibabynews.com/news/articleView.html?idxno=106247",
            "search_query": "성적 스트레스",
            "terminate": false,
            "text": "경쟁교육에 고통받는 건 비단 아이들 뿐만은 아니죠. 학부모의 64.8퍼센트가 자녀의 성적 스트레스와 사교육비 지출 부담으로 고통을 호소했어요.",
            "turn_id": "BK22002735-10",
            "utterance_id": "BK22002735.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "하, 역시 아이랑 진지하게 대화해 보고 결정하는 게 좋겠어요.",
            "turn_id": "BK22002735-11",
            "utterance_id": "BK22002735.21"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "맞아요, 사실 그게 가장 좋은 방법이죠. 부디 좋은 답을 찾길 바랄게요.",
            "turn_id": "BK22002735-11",
            "utterance_id": "BK22002735.22"
        }
    ]
}