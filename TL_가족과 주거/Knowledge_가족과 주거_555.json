    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아내가 벌써 임신 33주가 되었어요. 출산 시기가 가까워져 오니 걱정도 많고 궁금한 점도 많아요.",
            "turn_id": "BK22015740-1",
            "utterance_id": "BK22015740.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 어떤 점들이 궁금하세요?",
            "turn_id": "BK22015740-1",
            "utterance_id": "BK22015740.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "음, 먼저 33주 태아의 크기는 어느 정도 인가요?",
            "turn_id": "BK22015740-2",
            "utterance_id": "BK22015740.3"
        },
        {
            "reference_date": "2017-03-02",
            "reference_text": [
                {
                    "value": "33주가 되면 아기는 키가 43cm, 체중은 2,000g에 가까워집니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.ksmnews.co.kr/default/index_view_page.php?idx=168583&part_idx=197",
            "search_query": "임신 33주 태아 크기",
            "terminate": false,
            "text": "33주 태아의 키는 43cm 정도이며, 몸무게는 2kg 정도예요.",
            "turn_id": "BK22015740-2",
            "utterance_id": "BK22015740.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "43cm라니, 정말 많이 컸네요. 그럼 발달은 어느 정도 되었나요?",
            "turn_id": "BK22015740-3",
            "utterance_id": "BK22015740.5"
        },
        {
            "reference_date": "2015-09-18",
            "reference_text": [
                {
                    "value": "피부색은 피하지방이 늘어나 붉은 기운이 옅어지고 포동포동해지며 예뻐집니다.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                },
                {
                    "value": "태아의 피부밑에 축적되는 백색의 지방은 태아에게 에너지를 주고 태어난 이후 체중을 조절해주는 역할을 합니다.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                },
                {
                    "value": "장기도 거의 발달해 피부의 털도 거의 사라지고 손톱은 손가락 끝에 닿을 만큼 자랍니다.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108381",
            "search_query": "임신 33주 태아 특징",
            "terminate": false,
            "text": "피하지방이 늘어나서 피부는 붉은 색이 옅어지고 포동포동해지며 예뻐지기 시작해요. 태아 피부 밑에는 백색의 지방이 축적되는데 이 지방은 태아에게 에너지를 주고 태어난 이후 몸무게를 조절해 주는 역할을 해요. 또, 장기도 거의 다 발달을 했어요. 피부의 털들도 다 사라지고 손톱과 발톱도 손가락 끝까지 자랐고요.",
            "turn_id": "BK22015740-3",
            "utterance_id": "BK22015740.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "엄청 많이 발달을 했네요. 이렇게 컸는데 뱃속에 양수가 남아있나요?",
            "turn_id": "BK22015740-4",
            "utterance_id": "BK22015740.7"
        },
        {
            "reference_date": "2017-03-02",
            "reference_text": [
                {
                    "value": "자궁 내의 양수 량은 약 1 리터 정도가 됩니다.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                },
                {
                    "value": "아기는 지속적으로 양수를 마시면서 소화기관과 호흡기관의 운동을 합니다.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.ksmnews.co.kr/default/index_view_page.php?idx=168583&part_idx=197",
            "search_query": "임신 33주 양수 량",
            "terminate": false,
            "text": "그럼요, 자궁 내 양수량은 약 1리터 정도 되고 아기는 계속 양수를 마시면서 소화기관과 호흡기관의 운동을 하죠.",
            "turn_id": "BK22015740-4",
            "utterance_id": "BK22015740.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 그럼 이 시기에 아내의 몸 상태는 어떤가요?",
            "turn_id": "BK22015740-5",
            "utterance_id": "BK22015740.9"
        },
        {
            "reference_date": "2015-09-18",
            "reference_text": [
                {
                    "value": "어깨로 숨을 쉰다는 말이 나올 정도로 숨이 차고 힘들어지는 시기에요.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                },
                {
                    "value": "늘어난 자궁의 무게로 치골도 아프고 변비와 치질이 생기기 쉬워요.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                },
                {
                    "value": "복부는 배꼽이 튀어나올 정도로 불룩해지고 배가 단단해지면서 소변보는 횟수도 늘어나죠.",
                    "value_time": "2022-10-11",
                    "value_type": "constant"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108381",
            "search_query": "임신 33주 엄마의 증상",
            "terminate": false,
            "text": "숨이 많이 차고 힘들어지는 시기예요. 커진 자궁의 무게 때문에 치골도 아프고 변비와 치질이 생길 수도 있어요. 배꼽이 튀어나올 정도로 배가 많이 나오고 단단해지며 소변을 보는 횟수가 늘어나죠.",
            "turn_id": "BK22015740-5",
            "utterance_id": "BK22015740.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아내가 정말 힘들겠네요. 그리고 요즘 배도 자주 아프다고 하던데, 괜찮은 건가요?",
            "turn_id": "BK22015740-6",
            "utterance_id": "BK22015740.11"
        },
        {
            "reference_date": "2015-09-18",
            "reference_text": [
                {
                    "value": "분만의 연습과정으로 불규칙한 자궁수축이 잦아집니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108381",
            "search_query": "임신 33주 자궁수축",
            "terminate": false,
            "text": "네, 출산이 가까워 지면서 자궁 수축이 자주 반복돼요. 분만의 연습과정이라고 생각하시고 너무 걱정 마세요.",
            "turn_id": "BK22015740-6",
            "utterance_id": "BK22015740.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 또 요즘 빈혈 증세가 있다고 하던데, 따로 검사를 받아야 되는 건 아닌가요?",
            "turn_id": "BK22015740-7",
            "utterance_id": "BK22015740.13"
        },
        {
            "reference_date": "2015-09-18",
            "reference_text": [
                {
                    "value": "혈액량이 임신 전보다 1.5배가 증가해 빈혈증세가 나타날 수도 있어요.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                },
                {
                    "value": "빈혈 검사를 다시 한 번 실시하고 혈색소와 적혈구 용적률 검사를 받습니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                },
                {
                    "value": "또한, 임신 중의 돌발사고로 인해 수술이나 마취를 대비해 X-선 촬영을 미리 해두거나 간 기능 검사, 성병 검사도 다시 받는 것이 좋습니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108381",
            "search_query": "임신 33주 빈혈검사",
            "terminate": false,
            "text": "혈액량이 임신 전보다 1.5배 많아지기 때문에 빈혈 증상이 나타날 수 있는데, 빈혈 검사와 혈색소, 적혈구 용적률 검사를 다시 한번 받아보는 게 좋아요. 또, 임신 중 돌발사고로 인한 수술이나 마취를 대비해 X-선 촬영을 미리 해두거나 간 기능 검사, 성병 검사도 다시 한번 받아 보시는 걸 권해요.",
            "turn_id": "BK22015740-7",
            "utterance_id": "BK22015740.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 요즘 배가 많이 뭉치는 것 같던데, 배가 뭉치면 어떻게 해야 하나요?",
            "turn_id": "BK22015740-8",
            "utterance_id": "BK22015740.15"
        },
        {
            "reference_date": "2015-09-18",
            "reference_text": [
                {
                    "value": "A. 바로 누워서 휴식을 취하는 것이 좋으며, 특히 깊게 심호흡을 하는 것이 효과적입니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108381",
            "search_query": "임신 33주 배가 뭉칠 때",
            "terminate": false,
            "text": "배가 뭉칠 땐 똑바로 누워서 쉬는 게 좋아요. 특히 깊게 심호흡을 하는 게 중요해요.",
            "turn_id": "BK22015740-8",
            "utterance_id": "BK22015740.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "똑바로 눕는 것 자체가 힘들던데요, 어떻게 눕고 어떻게 움직여야 하나요?",
            "turn_id": "BK22015740-9",
            "utterance_id": "BK22015740.17"
        },
        {
            "reference_date": "2015-09-18",
            "reference_text": [
                {
                    "value": "누울 때는 무릎 아래에 쿠션을 대 허리를 편안히 하고 자리에 누웠다가 일어날 때는 갑작스러운 움직임이 없도록 해야 합니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                },
                {
                    "value": "천천히 옆으로 일어나고 양손으로 지탱하면서 상체를 일으키며, 외출 시에는 한 손으로 배를 감싸 보호를 해 외부의 충격으로부터 보호합니다.",
                    "value_time": "2022-10-11",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.hidoc.co.kr/healthstory/news/C0000108381",
            "search_query": "임신 33주 배가 뭉칠 때",
            "terminate": false,
            "text": "누울 때는 무릎 아래에 쿠션을 대고 허리를 편하게 하고 누우면 돼요. 그리고 일어날 때는 갑작스럽게 일어나지 말고 옆으로 천천히 일어나며 양손으로 상체를 지탱하며 일어나는 게 좋아요. 또 외출 시에는 한 손으로 배를 감싸 충격으로부터 배를 보호 해야 해요.",
            "turn_id": "BK22015740-9",
            "utterance_id": "BK22015740.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 그렇군요. 오늘 좋은 여러가지 좋은 정보 친절하게 알려주셔서 정말 감사해요. 덕분에 많은 도움이 되었어요.",
            "turn_id": "BK22015740-10",
            "utterance_id": "BK22015740.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "별말씀음요, 도움이 되셨다니 정말 다행이네요. 또 궁금한 점 있으시면 언제든지 물어보세요.",
            "turn_id": "BK22015740-10",
            "utterance_id": "BK22015740.20"
        }
    ]
}