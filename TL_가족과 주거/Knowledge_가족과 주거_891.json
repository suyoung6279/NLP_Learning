    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "있잖아, 이번에 동생이랑 같이 사촌 결혼식에 다녀오게 되었어.",
            "turn_id": "BK22003598-1",
            "utterance_id": "BK22003598.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 잘 다녀오면 좋겠네.",
            "turn_id": "BK22003598-1",
            "utterance_id": "BK22003598.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그런데 조금 걱정이 돼. 사실, 나랑 동생 둘 다 다른 사람 결혼식에 참석하는 게 처음이거든. 우리 두 사람 다, 이런 경우에 어떤 옷을 입어야 하는지 잘 모르겠어.",
            "turn_id": "BK22003598-2",
            "utterance_id": "BK22003598.3"
        },
        {
            "reference_date": "2013-03-28",
            "reference_text": [
                {
                    "value": "다들 알고 있겠지만, 가장 중요한 사항은 바로 흰색 옷을 입지 않는 것이다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.allurekorea.com/2013/03/28/%EC%B6%94%EC%B2%9C-%EB%A9%8B%EA%B3%BC-%EC%98%88%EC%9D%98%EB%A5%BC-%EA%B0%96%EC%B6%98-%ED%95%98%EA%B0%9D-%ED%8C%A8%EC%85%98/",
            "search_query": "결혼식 어떤 옷 예의",
            "terminate": false,
            "text": "음, 일단 옷을 고를 때 흰색 옷은 반드시 피하도록 해. 이게 제일 중요한 규칙이야.",
            "turn_id": "BK22003598-2",
            "utterance_id": "BK22003598.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어, 하객들은 결혼식에서 흰옷을 입으면 안 되는 거야?",
            "turn_id": "BK22003598-3",
            "utterance_id": "BK22003598.5"
        },
        {
            "reference_date": "2014-03-30",
            "reference_text": [
                {
                    "value": "결혼식 하객이 입지 말아야 할 금기사항 중 한가지는 상·하의를 모두 하얀색으로 입는 것이다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                },
                {
                    "value": "결혼식에서 백색은 신부의 상징이며 신부가 주인공이라는 것을 돋보여주는 색이다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.metroseoul.co.kr/article/2014033000055",
            "search_query": "결혼식 하객 흰 옷 금지",
            "terminate": false,
            "text": "응, 결혼식에서 흰색은 신부를 상징하는 색이거든. 동시에 신부가 결혼식의 주인공이라는 것을 보여주는 색이기도 해. 이런 이유로, 결혼식 하객들은 상하의 모두 흰색으로 입는 것을 반드시 피해야 해.",
            "turn_id": "BK22003598-3",
            "utterance_id": "BK22003598.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "아, 신부 드레스가 하얀색이라서 그렇구나. 알겠어, 그러면 흰색은 꼭 피하도록 할게. 혹시 흰색 옷을 피해야 하는 것 말고도, 의상 관련해서 또 다른 금기사항이 있을까?",
            "turn_id": "BK22003598-4",
            "utterance_id": "BK22003598.7"
        },
        {
            "reference_date": "2014-03-30",
            "reference_text": [
                {
                    "value": "허벅지 위로 올라오는 짧은 미니스커트나 속옷이 비치는 시스루 블라우스, 가슴골이 드러나는 상의는 모두 금지다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                },
                {
                    "value": "몸의 굴곡이 과도하게 드러나는 옷도 마찬가지다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.metroseoul.co.kr/article/2014033000055",
            "search_query": "결혼식 의상 금기",
            "terminate": false,
            "text": "지나치게 몸의 굴곡을 드러내는 옷들은 피하는 게 좋아. 또, 가슴골이 보이는 상의나, 속옷이 비치는 시스루 블라우스 계열의 옷들, 그리고 길이가 허벅지 위로 올라오는 미니스커트도 입으면 안 되는 옷들이지.",
            "turn_id": "BK22003598-4",
            "utterance_id": "BK22003598.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "음, 그러니까 노출이 많은 옷도 피하라는 거구나. 그러면 혹시 여자 말고, 남자 같은 경우엔 어떻게 하는 게 좋을까? 드레스 코드나 특별히 금지된 옷들이 있나?",
            "turn_id": "BK22003598-5",
            "utterance_id": "BK22003598.9"
        },
        {
            "reference_date": "2016-06-07",
            "reference_text": [
                {
                    "value": "흰색 외에도 자극적인 옷이나 원색의 옷은 피하는 것이 좋다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                },
                {
                    "value": "이는 남녀 하객 모두에게 해당하는 사항이므로 참고하도록 하자.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.tiptipnews.co.kr/news/articleView.html?idxno=6426",
            "search_query": "남자하객 결혼식 드레스 코드 금지",
            "terminate": false,
            "text": "조금 전에 흰색 옷을 입지 말라고 했는데, 흰색 말고도 원색 계통의 옷이나 자극적인 옷은 피해야 해. 이건 여성뿐만 아니라, 남자 하객들에게도 해당하는 이야기야.",
            "turn_id": "BK22003598-5",
            "utterance_id": "BK22003598.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇구나, 그러면 남자 하객들은 보통 결혼식에서 뭘 입어?",
            "turn_id": "BK22003598-6",
            "utterance_id": "BK22003598.11"
        },
        {
            "reference_date": "2016-03-03",
            "reference_text": [
                {
                    "value": "남성들의 하객 패션은 ‘정장’이 정답이다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.edaily.co.kr/news/read?newsid=01230006612579712",
            "search_query": "남자 하객 결혼식 의상",
            "terminate": false,
            "text": "보통 남자 하객들은 정장을 입는 게 공식이지.",
            "turn_id": "BK22003598-6",
            "utterance_id": "BK22003598.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "집에 정장 자켓이랑, 와이셔츠, 그리고 넥타이가 있긴 한데, 얘네들을 어떻게 조합해서 입어야 할지 잘 모르겠어. 그냥 아예 차라리 캐주얼하게 입고 결혼식에 갈까?",
            "turn_id": "BK22003598-7",
            "utterance_id": "BK22003598.13"
        },
        {
            "reference_date": "2016-06-07",
            "reference_text": [
                {
                    "value": "또한, 남자 하객은 밝은 와이셔츠와 너무 튀지 않는 넥타이를 선택하는 것이 좋으며, 지나치게 캐주얼한 복장이나 반바지 차림은 삼가도록 하고 무난한 감색, 회색, 짙은 회색의 정장을 입는 것이 좋다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.tiptipnews.co.kr/news/articleView.html?idxno=6426",
            "search_query": "남자하객 결혼식장 와이셔츠 넥타이 캐주얼 복장",
            "terminate": false,
            "text": "너무 심하게 캐주얼한 복장은 피하는 게 좋아. 반바지를 입는 것도 되도록 자제하는 게 좋지. 그리고 만약에 진짜 정장을 입는다면, 색은 감색이나 회색 내지 짙은 회색 중에서 입는 걸 추천할게. 그리고 와이셔츠 색은 밝게, 넥타이는 너무 눈에 띄지 않는 넥타이를 고르도록 해.",
            "turn_id": "BK22003598-7",
            "utterance_id": "BK22003598.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혹시 결혼식장에서 반드시 넥타이를 해야 할까? 사실 넥타이가 꽤 불편하다 보니, 가능하다면 다른 소품으로 대체하고 싶어.",
            "turn_id": "BK22003598-8",
            "utterance_id": "BK22003598.15"
        },
        {
            "reference_date": "2016-03-03",
            "reference_text": [
                {
                    "value": "넥타이가 불편하다면 색다른 소품을 선택해보자.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                },
                {
                    "value": "또 행커치프, 커프스 버튼 등 셔츠나 재킷의 디테일을 활용하면 보다 센스 있는 정장 스타일링이 가능하다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://www.edaily.co.kr/news/read?newsid=01230006612579712",
            "search_query": "결혼식 넥타이 다른 소품",
            "terminate": false,
            "text": "넥타이를 착용하기 힘들다면, 조금 색다른 소품으로 대체해도 괜찮아. 행커치프를 활용해도 좋고, 아니면 커프스 버튼 같은 셔츠나 재킷의 디테일을 활용해서 정장을 멋지게 스타일링할 수도 있어.",
            "turn_id": "BK22003598-8",
            "utterance_id": "BK22003598.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "어, 행커치프라면 혹시 손수건을 말하는 건가? 난 손 씻고 나서 닦을 때만 손수건을 쓰는데, 이걸 패션에도 활용한다고?",
            "turn_id": "BK22003598-9",
            "utterance_id": "BK22003598.17"
        },
        {
            "reference_date": "2014-08-19",
            "reference_text": [
                {
                    "value": "행커치프는 본래 손수건으로 사용하던 아이템이었다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                },
                {
                    "value": "그러나 시간이 지나면서 손수건으로써의 실용성보다는 옷을 꾸미는 용도로 변했다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                },
                {
                    "value": "그러나 행커치프는 재킷 외에 수중에 갖고 있는 슈트나 캐주얼 재킷, 심지어 코트에도 할 수 있으니 가격대비 활용도가 높은 아이템이다.",
                    "value_time": "2022-07-26",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://news.mt.co.kr/mtview.php?no=2014081808572569015",
            "search_query": "행커치프 손수건 패션",
            "terminate": false,
            "text": "맞아, 네 말대로 원래 행커치프는 손수건으로 사용되었던 물건이었어. 하지만 시간이 흘러서, 손수건으로서의 실용성을 살리기보단 옷을 꾸미는 쪽으로 그 용도가 바뀌게 되었지. 행커치프는 재킷 뿐만 아니라 슈트나 캐쥬얼 재킷, 심지어 코트에도 사용할 수 있다 보니, 가격에 비해 굉장히 활용도가 높은 물건이기도 해.",
            "turn_id": "BK22003598-9",
            "utterance_id": "BK22003598.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그러면 이번에 결혼식에 가는 김에, 한번 행커치프를 활용하는 패션에도 도전해봐야겠다! 덕분에 결혼식에 뭘 입고 가야 할지, 조금 윤곽이 보이는 것 같아. 도와줘서 정말 고맙고, 나는 이만 옷장에 있는 옷들이랑 손수건을 한번 점검하러 가볼게!",
            "turn_id": "BK22003598-10",
            "utterance_id": "BK22003598.19"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "그래, 옷 멋지게 잘 준비해서 결혼식에도 잘 다녀와.",
            "turn_id": "BK22003598-10",
            "utterance_id": "BK22003598.20"
        }
    ]
}