    "utterances": [
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "이번에 방을 빼게 돼서 이사 준비를 해야 하는데 이사 비용이 만만치 않아서 걱정이야.",
            "turn_id": "BK22003997-1",
            "utterance_id": "BK22003997.1"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "이번에 이사 가니? 이사 비용 만만치 않지. 너는 직장을 다니니까 주말에 해야 되지?",
            "turn_id": "BK22003997-1",
            "utterance_id": "BK22003997.2"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "응. 나는 주말밖에 시간이 안 되어 주말에 이사 갈 예정이야.",
            "turn_id": "BK22003997-2",
            "utterance_id": "BK22003997.3"
        },
        {
            "reference_date": "2022-02-25",
            "reference_text": [
                {
                    "value": "주말과 손없는 날에 진행하는 이사는 평일보다 최소 10만원~20만원 더 비싸다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.mdilbo.com/detail/DDAuq0/663181",
            "search_query": "주말 이사 비용",
            "terminate": false,
            "text": "주말은 평일보다 최소 10만원에서 20만원 정도 더 비싼데 괜찮겠어?",
            "turn_id": "BK22003997-2",
            "utterance_id": "BK22003997.4"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "비싸긴 하지만 어쩔 수 없지. 심지어 나는 이삿날과 입주일도 달라.",
            "turn_id": "BK22003997-3",
            "utterance_id": "BK22003997.5"
        },
        {
            "reference_date": "2022-02-25",
            "reference_text": [
                {
                    "value": "이삿날과 입주하는 날을 같게 조정하는 것도 필요하다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                },
                {
                    "value": "보관이사는 추가비용이 들기 때문이다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.mdilbo.com/detail/DDAuq0/663181",
            "search_query": "이삿날 입주하는 날 추가비용",
            "terminate": false,
            "text": "이삿날과 입주하는 날이 다르면 추가 비용이 들기 때문에 이삿날과 입주하는 날짜를 같게 조정하는 게 좋아.",
            "turn_id": "BK22003997-3",
            "utterance_id": "BK22003997.6"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "여러 가지 계산하다 보면 비용이 너무 부담돼서 나 혼자서 해야 하나 생각 중인데 괜찮을까?",
            "turn_id": "BK22003997-4",
            "utterance_id": "BK22003997.7"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "혼자 이사를 한다고? 그건 너무 힘들 것 같은데. 혹시 지역은 어디로 이사 가는 거니?",
            "turn_id": "BK22003997-4",
            "utterance_id": "BK22003997.8"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "이사 갈 지역은 마포구로 생각하고 있어.",
            "turn_id": "BK22003997-5",
            "utterance_id": "BK22003997.9"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "서울 마포구(구청장 유동균)는 관내에서 이사하거나 마포구로 전입하는 청년 1인 가구를 대상으로 이사를 돕는 ‘마포손길’ 사업을 20일부터 시행한다고 16일 밝혔다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://n.news.naver.com/article/016/0002003939?sid=102",
            "search_query": "마포손길 사업",
            "terminate": false,
            "text": "마포구로 이사 가니? 잘됐다. 이번 6월 20일부터 마포구로 이사가거나 전입하는 1인 가구 청년을 위해 이사를 돕는 마포 손길 사업을 시행하는 데 한번 참여해봐.",
            "turn_id": "BK22003997-5",
            "utterance_id": "BK22003997.10"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그래? 그 사업은 이사를 도와주는 서비스 같은 거야?",
            "turn_id": "BK22003997-6",
            "utterance_id": "BK22003997.11"
        },
        {
            "reference_date": "2022-06-20",
            "reference_text": [
                {
                    "value": "이사 서비스는 ‘기본 이사’와 ‘포장 이사’ 중에서 선택 가능하며 오는 11월까지 총 65가구를 지원한다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                },
                {
                    "value": "기본 이사는 지정 업체를 통해 1t 트럭과 운반 인력을 지원하며, 포장 이사는 최대 40만원까지 지원한다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://n.news.naver.com/article/081/0003281110?sid=102",
            "search_query": "마포손길 이사 서비스",
            "terminate": false,
            "text": "맞아. 기본 이사와 포장 이사 둘 중에 하나를 선택할 수 있고 기본 이사를 선택할 경우 지정업체를 통해서 1톤 트럭과 운반 인력을 제공해주고 포장이사를 선택하게 되면 최대 40만원을 지원해 줘.",
            "turn_id": "BK22003997-6",
            "utterance_id": "BK22003997.12"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그거 정말 좋은 서비스다. 나는 나이가 만 35세인데 해당될까?",
            "turn_id": "BK22003997-7",
            "utterance_id": "BK22003997.13"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "신청 대상은 마포구 내에서 이사하거나 서울시 타 자치구에서 마포구로 이사 오는 만19세에서 만39세 청년 1인 가구다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://n.news.naver.com/article/016/0002003939?sid=102",
            "search_query": "마포손길 1인가구",
            "terminate": false,
            "text": "응. 1인 가구여야 하고 만 19세에서 만 39세 청년이 신청할 수 있으니 너는 해당되지.",
            "turn_id": "BK22003997-7",
            "utterance_id": "BK22003997.14"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "다행이다. 참여해볼까 하는데 혹시 소득 기준도 보니? 중위소득 몇퍼센트 이하여야 하는 커트라인이 있니?",
            "turn_id": "BK22003997-8",
            "utterance_id": "BK22003997.15"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "중위소득 150% 이하 소득수준자여야 하며, 신청 기간 중 신청서와 증빙서류를 제출하면 자격 심사를 통해 선착순으로 이사 서비스를 제공한다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://n.news.naver.com/article/016/0002003939?sid=102",
            "search_query": "마포손길 소득",
            "terminate": false,
            "text": "응. 있어. 중위소득 150퍼센트 이하여야 하고 신청 기간 중 신청서와 증빙서류를 제출하면 자격 심사를 통해 선착순으로 서비스를 제공하니 얼른 신청해봐.",
            "turn_id": "BK22003997-8",
            "utterance_id": "BK22003997.16"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "그렇다면 얼른 신청해봐야겠다. 어떻게 신청해야 하는 거야?",
            "turn_id": "BK22003997-9",
            "utterance_id": "BK22003997.17"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "신청 방법은 구글폼 서식 ‘2022마포손길신청서’를 작성하고 자격을 증빙하는 서류는 이메일로 별도 제출해야 한다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "https://n.news.naver.com/article/016/0002003939?sid=102",
            "search_query": "마포손길 신청방법",
            "terminate": false,
            "text": "신청 방법은 간단해. 구글폼 작성해본 적 있지? 구글폼 서식 2022마포 손길 신청서를 작성하고 증빙서류는 이메일로 별도로 제출하면 끝이야.",
            "turn_id": "BK22003997-9",
            "utterance_id": "BK22003997.18"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "오 생각보다 간단하다. 혹시 기본 이사는 투룸은 안되고 원룸 이사로만 가능한 거야?",
            "turn_id": "BK22003997-10",
            "utterance_id": "BK22003997.19"
        },
        {
            "reference_date": "2022-06-16",
            "reference_text": [
                {
                    "value": "기본 이사는 원룸 이사를 기준으로 지정 업체를 통해 1톤 트럭과 운반 인력을 제공하며, 포장 이사는 전체 소요 비용 중 40만원까지 지원 받을 수 있다.",
                    "value_time": "2022-07-18",
                    "value_type": "variable"
                }
            ],
            "role": "전문가",
            "search_URL": "http://www.hg-times.com/news/articleView.html?idxno=242048",
            "search_query": "마포손길 원룸",
            "terminate": false,
            "text": "맞아. 기본이사는 투룸은 아니고 원룸 이사를 기준으로 1톤 트럭과 운반 인력에 제공되는 거야.",
            "turn_id": "BK22003997-10",
            "utterance_id": "BK22003997.20"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "네 덕분에 좋은 정보 알아간다. 오늘 당장 신청해봐야겠어.",
            "turn_id": "BK22003997-11",
            "utterance_id": "BK22003997.21"
        },
        {
            "reference_date": null,
            "reference_text": null,
            "role": "전문가",
            "search_URL": null,
            "search_query": null,
            "terminate": true,
            "text": "얼른 신청해봐. 돈을 절약해서 이사 할 수 있을 거야.",
            "turn_id": "BK22003997-11",
            "utterance_id": "BK22003997.22"
        }
    ]
}