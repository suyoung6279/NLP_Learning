        {
            "reference_date": null,
            "reference_text": null,
            "role": "질문자",
            "search_URL": null,
            "search_query": null,
            "terminate": false,
            "text": "두뇌 훈련도 ADHD의 증상을 완화시켜주는 하나의 방법이라는 게 신기하네요. 그런데 ADHD는 반드시 치료를 해야만 하는 건가요? 아이가 자라면 자연스럽게 나아질 확률은 없나요?",
            "turn_id": "BK22008618-5",
